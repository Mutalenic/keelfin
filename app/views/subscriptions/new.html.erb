<% content_for(:page_title) { "Welcome" } %>
<% content_for(:skip_card_wrapper, true) %>

<div class="space-y-8 max-w-3xl mx-auto">
  <!-- Hero Banner -->
  <div class="rounded-3xl p-6 sm:p-8 text-white shadow-[0_25px_80px_rgba(15,23,42,0.45)] border border-white/10 text-center"
       style="background: linear-gradient(135deg, #4f46e5 0%, #4338ca 55%, #1e1b4b 100%);">
    <div class="mb-6">
      <i class="fa-solid fa-wallet text-6xl text-white/90"></i>
    </div>
    <h1 class="text-3xl font-bold mb-4">Welcome to Keelfin Premium</h1>
    <p class="text-white/80 max-w-lg mx-auto">
      Take control of your finances with our powerful budgeting tools and insights.
    </p>
  </div>

  <div class="bg-surface border border-default backdrop-blur-2xl rounded-3xl shadow-2xl p-6 sm:p-8">
    <h2 class="text-xl font-bold text-content mb-4 text-center">Activate Your Free Account</h2>
    <p class="text-subtle mb-6 text-center">Start with our free plan and upgrade anytime to unlock more powerful features.</p>

    <div class="space-y-3 mb-8 max-w-md mx-auto">
      <div class="flex items-center p-3 rounded-xl bg-content/5">
        <i class="fa-solid fa-check text-emerald-500 mr-3"></i>
        <span class="text-content">Up to 10 categories</span>
      </div>
      <div class="flex items-center p-3 rounded-xl bg-content/5">
        <i class="fa-solid fa-check text-emerald-500 mr-3"></i>
        <span class="text-content">Up to 5 budgets</span>
      </div>
      <div class="flex items-center p-3 rounded-xl bg-content/5">
        <i class="fa-solid fa-check text-emerald-500 mr-3"></i>
        <span class="text-content">Basic expense tracking</span>
      </div>
    </div>

    <div class="text-center">
      <%= button_to "Activate Free Account", subscription_path, method: :post, class: "inline-flex items-center justify-center px-8 py-3 rounded-xl text-sm font-semibold bg-brand-600 text-white shadow hover:bg-brand-500 transition" %>
    </div>
  </div>

  <div class="text-center">
    <p class="text-faint mb-2">Want more features?</p>
    <%= link_to "View Premium Plans", plans_subscription_path, class: "inline-flex items-center text-accent hover:text-subtle font-semibold transition" do %>
      <i class="fa-solid fa-crown mr-2"></i>
      See all plans
    <% end %>
  </div>
</div>
