<% content_for(:page_title) { "Premium Plans" } %>
<% content_for(:skip_card_wrapper, true) %>

<div class="space-y-8">
  <!-- Hero Banner -->
  <div class="rounded-3xl p-6 sm:p-8 text-white shadow-[0_25px_80px_rgba(15,23,42,0.45)] border border-white/10 text-center"
       style="background: linear-gradient(135deg, #f59e0b 0%, #d97706 55%, #1e1b4b 100%);">
    <div class="mb-6">
      <i class="fa-solid fa-crown text-6xl text-white/90"></i>
    </div>
    <h1 class="text-3xl font-bold mb-4">Choose Your Keelfin Plan</h1>
    <p class="text-white/80 max-w-2xl mx-auto">
      Pick the plan that works for you. You can always upgrade later when you need more.
    </p>
  </div>

  <div class="max-w-6xl mx-auto">
  
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Free Plan -->
      <div class="bg-surface border border-default backdrop-blur-2xl rounded-3xl shadow-2xl overflow-hidden hover:shadow-2xl transition-shadow">
      <div class="p-6">
        <h2 class="text-2xl font-bold text-content mb-2">Free</h2>
        <div class="text-4xl font-bold text-content mb-6">
          K0<span class="text-lg text-subtle font-normal">/month</span>
        </div>
        
        <ul class="space-y-3 mb-8">
          <li class="flex items-center">
            <i class="fa-solid fa-check text-green-500 mr-2"></i>
            <span>Up to <%= @plans[:free][:features][:max_categories] %> categories</span>
          </li>
          <li class="flex items-center">
            <i class="fa-solid fa-check text-green-500 mr-2"></i>
            <span>Up to <%= @plans[:free][:features][:max_budgets] %> budgets</span>
          </li>
          <li class="flex items-center">
            <i class="fa-solid fa-check text-green-500 mr-2"></i>
            <span>Basic expense tracking</span>
          </li>
          <li class="flex items-center text-faint">
            <i class="fa-solid fa-xmark text-red-400 mr-2"></i>
            <span>Advanced analytics</span>
          </li>
          <li class="flex items-center text-faint">
            <i class="fa-solid fa-xmark text-red-400 mr-2"></i>
            <span>Export reports</span>
          </li>
        </ul>
        
          <% if @current_plan == 'free' %>
            <button class="w-full bg-content/10 text-subtle py-3 px-4 rounded-xl font-bold" disabled>Current Plan</button>
          <% else %>
            <%= button_to "Downgrade", upgrade_subscription_path(plan_name: 'free'), class: "w-full bg-gray-500 hover:bg-gray-600 text-white py-3 px-4 rounded-xl font-bold transition" %>
          <% end %>
        </div>
      </div>

      <!-- Standard Plan -->
      <div class="bg-surface border-2 border-brand-500 backdrop-blur-2xl rounded-3xl shadow-2xl overflow-hidden hover:shadow-2xl transition-shadow transform scale-105 relative">
        <div class="bg-gradient-to-r from-brand-500 to-brand-600 text-white text-center py-2 text-sm font-bold">MOST POPULAR</div>
      <div class="p-6">
        <h2 class="text-2xl font-bold text-content mb-2">Standard</h2>
        <div class="text-4xl font-bold text-content mb-6">
          K<%= number_with_precision(@plans[:standard][:price], precision: 0) %><span class="text-lg text-subtle font-normal">/month</span>
        </div>
        
        <ul class="space-y-3 mb-8">
          <li class="flex items-center">
            <i class="fa-solid fa-check text-green-500 mr-2"></i>
            <span>Up to <%= @plans[:standard][:features][:max_categories] %> categories</span>
          </li>
          <li class="flex items-center">
            <i class="fa-solid fa-check text-green-500 mr-2"></i>
            <span>Up to <%= @plans[:standard][:features][:max_budgets] %> budgets</span>
          </li>
          <li class="flex items-center">
            <i class="fa-solid fa-check text-green-500 mr-2"></i>
            <span>Advanced analytics</span>
          </li>
          <li class="flex items-center">
            <i class="fa-solid fa-check text-green-500 mr-2"></i>
            <span>Export reports</span>
          </li>
          <li class="flex items-center">
            <i class="fa-solid fa-check text-green-500 mr-2"></i>
            <span>Shopping lists</span>
          </li>
          <li class="flex items-center text-faint">
            <i class="fa-solid fa-xmark text-red-400 mr-2"></i>
            <span>AI insights</span>
          </li>
        </ul>
        
          <% if @current_plan == 'standard' %>
            <button class="w-full bg-content/10 text-subtle py-3 px-4 rounded-xl font-bold" disabled>Current Plan</button>
          <% else %>
            <%= button_to "Upgrade with DPO Pay", checkout_subscription_path(plan_name: 'standard'), class: "w-full bg-brand-600 hover:bg-brand-500 text-white py-3 px-4 rounded-xl font-bold transition shadow-lg" %>
          <% end %>
        </div>
      </div>

      <!-- Premium Plan -->
      <div class="bg-surface border border-default backdrop-blur-2xl rounded-3xl shadow-2xl overflow-hidden hover:shadow-2xl transition-shadow relative">
      <div class="p-6">
        <h2 class="text-2xl font-bold text-content mb-2">Premium</h2>
        <div class="text-4xl font-bold text-content mb-6">
          K<%= number_with_precision(@plans[:premium][:price], precision: 0) %><span class="text-lg text-subtle font-normal">/month</span>
        </div>
        
        <ul class="space-y-3 mb-8">
          <li class="flex items-center">
            <i class="fa-solid fa-check text-green-500 mr-2"></i>
            <span>Unlimited categories</span>
          </li>
          <li class="flex items-center">
            <i class="fa-solid fa-check text-green-500 mr-2"></i>
            <span>Unlimited budgets</span>
          </li>
          <li class="flex items-center">
            <i class="fa-solid fa-check text-green-500 mr-2"></i>
            <span>Advanced analytics</span>
          </li>
          <li class="flex items-center">
            <i class="fa-solid fa-check text-green-500 mr-2"></i>
            <span>Export reports</span>
          </li>
          <li class="flex items-center">
            <i class="fa-solid fa-check text-green-500 mr-2"></i>
            <span>Shopping lists</span>
          </li>
          <li class="flex items-center">
            <i class="fa-solid fa-check text-green-500 mr-2"></i>
            <span>AI insights & recommendations</span>
          </li>
          <li class="flex items-center">
            <i class="fa-solid fa-check text-green-500 mr-2"></i>
            <span>Debt payoff strategies</span>
          </li>
        </ul>
        
          <% if @current_plan == 'premium' %>
            <button class="w-full bg-content/10 text-subtle py-3 px-4 rounded-xl font-bold" disabled>Current Plan</button>
          <% else %>
            <%= button_to "Upgrade with DPO Pay", checkout_subscription_path(plan_name: 'premium'), class: "w-full bg-gradient-to-r from-amber-400 to-yellow-500 hover:from-amber-500 hover:to-yellow-600 text-amber-950 py-3 px-4 rounded-xl font-bold transition shadow-lg" %>
          <% end %>
        </div>
      </div>
    </div>

    <div class="mt-8 text-center">
      <p class="text-white/70 mb-2">All plans include our core budgeting and expense tracking features.</p>
      <p class="text-sm text-white/50">Prices shown in Zambian Kwacha (ZMW). Billed monthly. Cancel anytime.</p>
      <p class="text-sm text-white/40 mt-2">Payments processed securely via <strong class="text-white/60">DPO Pay</strong>.</p>
    </div>
  </div>
</div>
