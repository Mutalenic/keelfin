<% content_for(:page_title) { "Subscription" } %>
<% content_for(:skip_card_wrapper, true) %>

<div class="space-y-8 max-w-3xl mx-auto">
    <!-- Subscription Status Card -->
    <div class="bg-surface border border-default backdrop-blur-2xl rounded-3xl shadow-2xl overflow-hidden mb-6">
      <div class="p-6">
        <div class="flex justify-between items-center mb-6">
          <h2 class="text-2xl font-bold text-content">Your Subscription</h2>
          <span class="px-4 py-1 rounded-full text-sm font-semibold <%= @subscription.active? ? 'bg-success/10 text-success border border-success/30' : 'bg-danger/10 text-danger border border-danger/30' %>">
            <%= @subscription.active? ? 'Active' : 'Inactive' %>
          </span>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <p class="text-subtle text-sm">Current Plan</p>
            <p class="text-xl font-semibold"><%= @subscription.plan_name.capitalize %></p>
          </div>
          
          <div>
            <p class="text-subtle text-sm">Monthly Price</p>
            <p class="text-xl font-semibold">K<%= number_with_precision(@subscription.amount, precision: 2) %></p>
          </div>
          
          <div>
            <p class="text-subtle text-sm">Start Date</p>
            <p class="text-xl font-semibold"><%= @subscription.start_date.strftime("%B %d, %Y") %></p>
          </div>
          
          <div>
            <p class="text-subtle text-sm">Renewal Date</p>
            <p class="text-xl font-semibold">
              <% if @subscription.end_date.present? %>
                <%= @subscription.end_date.strftime("%B %d, %Y") %>
              <% else %>
                N/A
              <% end %>
            </p>
          </div>
        </div>
        
        <% if @subscription.plan_name != 'free' && @subscription.active? %>
          <div class="mt-6 pt-6 border-t border-default">
            <div class="flex justify-between items-center">
              <div>
                <p class="text-subtle">Next billing date</p>
                <p class="text-sm text-subtle">You will be charged K<%= number_with_precision(@subscription.amount, precision: 2) %> on <%= @subscription.end_date.strftime("%B %d, %Y") %></p>
              </div>
              <%= button_to "Cancel Subscription", cancel_subscription_path, method: :post, data: { turbo_confirm: "Are you sure you want to cancel your subscription?" }, class: "text-red-600 hover:text-red-800 font-semibold" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
    
    <!-- Features Card -->
    <div class="bg-surface border border-default backdrop-blur-2xl rounded-3xl shadow-2xl overflow-hidden mb-6">
      <div class="p-6">
        <h3 class="text-xl font-bold text-content mb-4">Your Plan Features</h3>
        
        <div class="space-y-4">
          <div class="flex justify-between items-center">
            <span class="text-content">Categories</span>
            <span class="font-semibold">
              <% if @subscription.features['max_categories'] == -1 %>
                Unlimited
              <% else %>
                Up to <%= @subscription.features['max_categories'] %>
              <% end %>
            </span>
          </div>
          
          <div class="flex justify-between items-center">
            <span class="text-content">Budgets</span>
            <span class="font-semibold">
              <% if @subscription.features['max_budgets'] == -1 %>
                Unlimited
              <% else %>
                Up to <%= @subscription.features['max_budgets'] %>
              <% end %>
            </span>
          </div>
          
          <div class="flex justify-between items-center">
            <span class="text-content">Advanced Analytics</span>
            <span>
              <% if @subscription.features['advanced_analytics'] %>
                <i class="fa-solid fa-check text-green-500"></i>
              <% else %>
                <i class="fa-solid fa-xmark text-red-400"></i>
              <% end %>
            </span>
          </div>
          
          <div class="flex justify-between items-center">
            <span class="text-content">Export Reports</span>
            <span>
              <% if @subscription.features['export_reports'] %>
                <i class="fa-solid fa-check text-green-500"></i>
              <% else %>
                <i class="fa-solid fa-xmark text-red-400"></i>
              <% end %>
            </span>
          </div>
          
          <div class="flex justify-between items-center">
            <span class="text-content">Shopping Lists</span>
            <span>
              <% if @subscription.features['shopping_lists'] %>
                <i class="fa-solid fa-check text-green-500"></i>
              <% else %>
                <i class="fa-solid fa-xmark text-red-400"></i>
              <% end %>
            </span>
          </div>
          
          <div class="flex justify-between items-center">
            <span class="text-content">AI Insights</span>
            <span>
              <% if @subscription.features['ai_insights'] %>
                <i class="fa-solid fa-check text-green-500"></i>
              <% else %>
                <i class="fa-solid fa-xmark text-red-400"></i>
              <% end %>
            </span>
          </div>
          
          <div class="flex justify-between items-center">
            <span class="text-content">Debt Strategies</span>
            <span>
              <% if @subscription.features['debt_strategies'] %>
                <i class="fa-solid fa-check text-green-500"></i>
              <% else %>
                <i class="fa-solid fa-xmark text-red-400"></i>
              <% end %>
            </span>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Action Buttons -->
    <div class="flex justify-center">
      <%= link_to plans_subscription_path, class: "inline-flex items-center px-6 py-3 rounded-xl text-sm font-semibold bg-brand-600 text-white shadow hover:bg-brand-500 transition" do %>
        <i class="fa-solid fa-crown mr-2"></i>
        View Available Plans
      <% end %>
    </div>
  </div>
</div>
