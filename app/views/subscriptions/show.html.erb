<div class="space-y-8">
  <!-- Page Header -->
  <div class="bg-white/10 border border-white/20 backdrop-blur-2xl rounded-3xl p-6 sm:p-8 shadow-[0_25px_70px_rgba(15,23,42,0.35)]">
    <div class="flex flex-wrap items-start justify-between gap-6">
      <div>
        <p class="text-sm uppercase tracking-[0.2em] text-white/60">Billing & plans</p>
        <h1 class="mt-2 text-3xl sm:text-4xl font-semibold text-white tracking-tight">Subscription</h1>
        <p class="mt-3 text-sm sm:text-base text-white/70 max-w-2xl">
          Manage your plan, track features, and control your billing preferences.
        </p>
      </div>
      <div class="flex flex-wrap gap-3">
        <%= link_to plans_subscription_path, class: "inline-flex items-center px-5 py-3 rounded-2xl text-sm font-semibold bg-white text-brand-700 shadow-lg shadow-white/30" do %>
          <i class="fa-solid fa-crown mr-2"></i>
          View plans
        <% end %>
      </div>
    </div>
  </div>

  <!-- Subscription Status Card -->
  <div class="rounded-3xl border border-white/15 bg-white/95 backdrop-blur-xl shadow-2xl p-6">
    <div class="flex flex-wrap justify-between items-center gap-4 mb-8">
      <div>
        <p class="text-xs uppercase tracking-[0.3em] text-brand-500">Current plan</p>
        <h2 class="text-2xl font-semibold text-gray-900">Your subscription</h2>
      </div>
      <span class="inline-flex items-center px-4 py-2 rounded-full text-sm font-semibold
        <%= @subscription.active? ? 'bg-emerald-50 text-emerald-700 border border-emerald-200' : 'bg-rose-50 text-rose-700 border border-rose-200' %>">
        <i class="<%= @subscription.active? ? 'fa-solid fa-circle-check mr-2' : 'fa-solid fa-circle-xmark mr-2' %>"></i>
        <%= @subscription.active? ? 'Active' : 'Inactive' %>
      </span>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div class="bg-gray-50/80 rounded-2xl p-4 border border-gray-100">
        <p class="text-sm uppercase tracking-wide text-gray-500">Current plan</p>
        <p class="mt-2 text-xl font-semibold text-gray-900"><%= @subscription.plan_name.capitalize %></p>
      </div>

      <div class="bg-gray-50/80 rounded-2xl p-4 border border-gray-100">
        <p class="text-sm uppercase tracking-wide text-gray-500">Monthly price</p>
        <p class="mt-2 text-xl font-semibold text-gray-900">K<%= number_with_precision(@subscription.amount, precision: 2) %></p>
      </div>

      <div class="bg-gray-50/80 rounded-2xl p-4 border border-gray-100">
        <p class="text-sm uppercase tracking-wide text-gray-500">Start date</p>
        <p class="mt-2 text-xl font-semibold text-gray-900"><%= @subscription.start_date.strftime("%B %d, %Y") %></p>
      </div>

      <div class="bg-gray-50/80 rounded-2xl p-4 border border-gray-100">
        <p class="text-sm uppercase tracking-wide text-gray-500">Renewal date</p>
        <p class="mt-2 text-xl font-semibold text-gray-900">
          <% if @subscription.end_date.present? %>
            <%= @subscription.end_date.strftime("%B %d, %Y") %>
          <% else %>
            N/A
          <% end %>
        </p>
      </div>
    </div>

    <% if @subscription.plan_name != 'free' && @subscription.active? %>
      <div class="border-t border-gray-200 pt-6">
        <div class="flex flex-wrap justify-between items-center gap-4">
          <div>
            <p class="text-gray-600 font-medium">Next billing date</p>
            <p class="text-sm text-gray-500 mt-1">You will be charged K<%= number_with_precision(@subscription.amount, precision: 2) %> on <%= @subscription.end_date.strftime("%B %d, %Y") %></p>
          </div>
          <%= button_to "Cancel subscription", cancel_subscription_path, method: :post, data: { turbo_confirm: "Are you sure you want to cancel your subscription?" }, class: "inline-flex items-center px-4 py-2 rounded-2xl text-sm font-semibold border border-red-200 text-red-600 hover:bg-red-50" %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Features Card -->
  <div class="rounded-3xl border border-white/15 bg-white/95 backdrop-blur-xl shadow-2xl p-6">
    <div class="flex items-center gap-3 mb-6">
      <div class="w-10 h-10 rounded-xl bg-brand-50 flex items-center justify-center text-brand-600">
        <i class="fa-solid fa-star"></i>
      </div>
      <div>
        <p class="text-xs uppercase tracking-[0.3em] text-brand-500">Plan features</p>
        <h3 class="text-xl font-semibold text-gray-900">Your plan includes</h3>
      </div>
    </div>

    <div class="space-y-5">
      <div class="flex flex-wrap justify-between items-center p-4 rounded-2xl bg-gray-50/80 border border-gray-100">
        <span class="text-gray-700 font-medium">Categories</span>
        <span class="font-semibold text-gray-900">
          <% if @subscription.features['max_categories'] == -1 %>
            Unlimited
          <% else %>
            Up to <%= @subscription.features['max_categories'] %>
          <% end %>
        </span>
      </div>

      <div class="flex flex-wrap justify-between items-center p-4 rounded-2xl bg-gray-50/80 border border-gray-100">
        <span class="text-gray-700 font-medium">Budgets</span>
        <span class="font-semibold text-gray-900">
          <% if @subscription.features['max_budgets'] == -1 %>
            Unlimited
          <% else %>
            Up to <%= @subscription.features['max_budgets'] %>
          <% end %>
        </span>
      </div>

      <div class="flex flex-wrap justify-between items-center p-4 rounded-2xl bg-gray-50/80 border border-gray-100">
        <span class="text-gray-700 font-medium">Advanced Analytics</span>
        <span class="font-semibold">
          <% if @subscription.features['advanced_analytics'] %>
            <i class="fa-solid fa-check text-emerald-500"></i>
          <% else %>
            <i class="fa-solid fa-xmark text-red-400"></i>
          <% end %>
        </span>
      </div>

      <div class="flex flex-wrap justify-between items-center p-4 rounded-2xl bg-gray-50/80 border border-gray-100">
        <span class="text-gray-700 font-medium">Export Reports</span>
        <span class="font-semibold">
          <% if @subscription.features['export_reports'] %>
            <i class="fa-solid fa-check text-emerald-500"></i>
          <% else %>
            <i class="fa-solid fa-xmark text-red-400"></i>
          <% end %>
        </span>
      </div>

      <div class="flex flex-wrap justify-between items-center p-4 rounded-2xl bg-gray-50/80 border border-gray-100">
        <span class="text-gray-700 font-medium">Shopping Lists</span>
        <span class="font-semibold">
          <% if @subscription.features['shopping_lists'] %>
            <i class="fa-solid fa-check text-emerald-500"></i>
          <% else %>
            <i class="fa-solid fa-xmark text-red-400"></i>
          <% end %>
        </span>
      </div>

      <div class="flex flex-wrap justify-between items-center p-4 rounded-2xl bg-gray-50/80 border border-gray-100">
        <span class="text-gray-700 font-medium">AI Insights</span>
        <span class="font-semibold">
          <% if @subscription.features['ai_insights'] %>
            <i class="fa-solid fa-check text-emerald-500"></i>
          <% else %>
            <i class="fa-solid fa-xmark text-red-400"></i>
          <% end %>
        </span>
      </div>

      <div class="flex flex-wrap justify-between items-center p-4 rounded-2xl bg-gray-50/80 border border-gray-100">
        <span class="text-gray-700 font-medium">Debt Strategies</span>
        <span class="font-semibold">
          <% if @subscription.features['debt_strategies'] %>
            <i class="fa-solid fa-check text-emerald-500"></i>
          <% else %>
            <i class="fa-solid fa-xmark text-red-400"></i>
          <% end %>
        </span>
      </div>
    </div>
  </div>

  <!-- Action Buttons -->
  <div class="flex justify-center">
    <%= link_to "View available plans", plans_subscription_path, class: "inline-flex items-center px-6 py-3 rounded-2xl text-sm font-semibold bg-brand-600 text-white shadow hover:bg-brand-500 transition" %>
  </div>
</div>
