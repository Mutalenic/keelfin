<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f3f4f6; margin: 0; padding: 24px; }
    .container { max-width: 560px; margin: 0 auto; background: #fff; border-radius: 16px; overflow: hidden; box-shadow: 0 4px 24px rgba(0,0,0,0.08); }
    .header { background: linear-gradient(135deg, #059669 0%, #047857 100%); padding: 32px 32px 24px; color: #fff; }
    .header h1 { margin: 0 0 4px; font-size: 22px; font-weight: 700; }
    .header p { margin: 0; font-size: 14px; opacity: 0.8; }
    .body { padding: 28px 32px; }
    .section-title { font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #6b7280; margin: 0 0 12px; }
    .budget-row { display: flex; align-items: center; justify-content: space-between; padding: 10px 14px; border-radius: 10px; margin-bottom: 8px; }
    .budget-row.overspent { background: #fef2f2; border: 1px solid #fecaca; }
    .budget-row.near { background: #fffbeb; border: 1px solid #fde68a; }
    .budget-name { font-weight: 600; font-size: 14px; }
    .budget-meta { font-size: 12px; color: #6b7280; margin-top: 2px; }
    .badge { font-size: 12px; font-weight: 700; padding: 3px 10px; border-radius: 99px; }
    .badge.red { background: #fee2e2; color: #dc2626; }
    .badge.amber { background: #fef3c7; color: #d97706; }
    .cta { display: block; text-align: center; background: #059669; color: #fff; text-decoration: none; padding: 14px 24px; border-radius: 12px; font-weight: 600; font-size: 15px; margin: 24px 0 0; }
    .footer { padding: 20px 32px; background: #f9fafb; border-top: 1px solid #e5e7eb; font-size: 12px; color: #9ca3af; text-align: center; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>Budget Alert</h1>
      <p>Hi <%= @user.name.split(' ').first %> — here's a heads up on your budgets this month.</p>
    </div>
    <div class="body">
      <% if @overspent.any? %>
        <p class="section-title" style="color:#dc2626;">Exceeded</p>
        <% @overspent.each do |b| %>
          <div class="budget-row overspent">
            <div>
              <div class="budget-name"><%= b[:name] %></div>
              <div class="budget-meta">Spent K<%= number_with_precision(b[:spent], precision: 2, delimiter: ',') %> of K<%= number_with_precision(b[:limit], precision: 2, delimiter: ',') %> limit</div>
            </div>
            <span class="badge red"><%= b[:pct].round %>%</span>
          </div>
        <% end %>
      <% end %>

      <% if @near_limit.any? %>
        <p class="section-title" style="margin-top:<%= @overspent.any? ? '20px' : '0' %>">Approaching Limit</p>
        <% @near_limit.each do |b| %>
          <div class="budget-row near">
            <div>
              <div class="budget-name"><%= b[:name] %></div>
              <div class="budget-meta">Spent K<%= number_with_precision(b[:spent], precision: 2, delimiter: ',') %> of K<%= number_with_precision(b[:limit], precision: 2, delimiter: ',') %> limit</div>
            </div>
            <span class="badge amber"><%= b[:pct].round %>%</span>
          </div>
        <% end %>
      <% end %>

      <a href="<%= budgets_url %>" class="cta">View My Budgets</a>
    </div>
    <div class="footer">
      You're receiving this because budget alerts are enabled on your Keelfin account.<br>
      © <%= Date.current.year %> Keelfin
    </div>
  </div>
</body>
</html>
