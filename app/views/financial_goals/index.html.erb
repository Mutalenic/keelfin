<% content_for(:page_title) { "Financial Goals" } %>
<% content_for(:skip_card_wrapper, true) %>

<div class="space-y-8">
  <!-- Hero Banner -->
  <div class="rounded-3xl p-6 sm:p-8 text-white shadow-[0_25px_80px_rgba(15,23,42,0.45)] border border-white/10"
       style="background: linear-gradient(135deg, #10b981 0%, #059669 55%, #1e1b4b 100%);">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
      <div>
        <p class="text-xs uppercase tracking-[0.3em] text-white/70 mb-3">Wealth building</p>
        <h1 class="text-2xl sm:text-3xl font-semibold tracking-tight">Financial Goals</h1>
        <p class="mt-2 text-sm sm:text-base text-white/80 max-w-2xl">
          Track your progress and achieve your financial milestones.
        </p>
      </div>
      <div class="flex items-center gap-3">
        <%= link_to new_financial_goal_path, class: "inline-flex items-center px-5 py-3 rounded-2xl text-sm font-semibold bg-white text-emerald-700 shadow-lg shadow-white/20" do %>
          <i class="fa-solid fa-plus mr-2"></i>
          New Goal
        <% end %>
      </div>
    </div>
  </div>

  <!-- Goals Summary -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div class="rounded-2xl border border-white/15 backdrop-blur-xl p-5 text-white shadow-lg"
         style="background: linear-gradient(150deg, rgba(16,185,129,0.9) 0%, rgba(5,150,105,0.85) 100%);">
      <p class="text-xs uppercase tracking-wide text-white/60">Active Goals</p>
      <p class="text-3xl font-semibold mt-3"><%= @active_goals.count %></p>
      <p class="text-xs text-white/60 mt-1">goals in progress</p>
    </div>

    <div class="rounded-2xl border border-white/15 backdrop-blur-xl p-5 text-white shadow-lg"
         style="background: linear-gradient(150deg, rgba(20,184,166,0.95) 0%, rgba(13,148,136,0.85) 100%);">
      <p class="text-xs uppercase tracking-wide text-white/60">Completion Rate</p>
      <p class="text-3xl font-semibold mt-3"><%= @completion_rate %>%</p>
      <p class="text-xs text-white/60 mt-1">goals achieved</p>
    </div>

    <div class="rounded-2xl border border-white/15 backdrop-blur-xl p-5 text-white shadow-lg"
         style="background: linear-gradient(150deg, rgba(139,92,246,0.95) 0%, rgba(124,58,237,0.85) 100%);">
      <p class="text-xs uppercase tracking-wide text-white/60">Total Saved</p>
      <p class="text-3xl font-semibold mt-3">K<%= number_with_precision(@total_saved, precision: 2) %></p>
      <p class="text-xs text-white/60 mt-1">towards your goals</p>
    </div>
  </div>
  
  <!-- Goals Progress Chart -->
  <%= render 'goals_chart' if @active_goals.any? %>

  <!-- Active Goals -->
  <div class="bg-surface border border-white/30 backdrop-blur-2xl rounded-3xl shadow-2xl p-6 sm:p-8">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
      <div>
        <h2 class="text-xl font-semibold text-content">Active Goals</h2>
        <p class="text-sm text-subtle">Goals you're currently working towards.</p>
      </div>
      <%= link_to new_financial_goal_path, class: "inline-flex items-center px-4 py-2 rounded-xl text-sm font-semibold bg-emerald-600 text-white shadow hover:bg-emerald-500 transition" do %>
        <i class="fa-solid fa-plus mr-2"></i>
        New Goal
      <% end %>
    </div>
    
    <% if @active_goals.any? %>
      <div class="space-y-6">
        <% @active_goals.each do |goal| %>
          <div class="border rounded-lg p-4 hover:bg-content/5 transition-colors">
            <div class="flex justify-between items-start">
              <div>
                <h3 class="font-semibold text-lg"><%= link_to goal.name, financial_goal_path(goal) %></h3>
                <p class="text-sm text-subtle"><%= goal.goal_type.humanize %> • Due <%= goal.target_date.strftime('%b %d, %Y') %></p>
                <p class="mt-2"><span class="font-medium">Target:</span> K<%= number_with_precision(goal.target_amount, precision: 2) %></p>
              </div>
              <div class="text-right">
                <span class="inline-block px-3 py-1 rounded-full text-sm font-semibold 
                  <%= case goal.priority
                      when 'high' then 'bg-red-100 text-red-800'
                      when 'medium' then 'bg-yellow-100 text-yellow-800'
                      else 'bg-green-100 text-green-800'
                      end %>">
                  <%= goal.priority.capitalize %>
                </span>
                <p class="mt-2 font-bold"><%= goal.progress_percentage %>% Complete</p>
              </div>
            </div>
            
            <!-- Progress Bar -->
            <div class="mt-4 w-full bg-content/10 rounded-full h-2.5">
              <div class="bg-blue-600 h-2.5 rounded-full" style="width: <%= goal.progress_percentage %>%"></div>
            </div>
            
            <div class="mt-3 flex justify-between text-sm text-subtle">
              <span>K<%= number_with_precision(goal.current_amount, precision: 2) %> of K<%= number_with_precision(goal.target_amount, precision: 2) %></span>
              <span><%= goal.days_remaining %> days left</span>
            </div>
            
            <div class="mt-4 flex justify-end space-x-2">
              <%= link_to "Update Progress", edit_financial_goal_path(goal), class: "text-sm px-3 py-1.5 rounded-lg bg-emerald-50 text-emerald-700 hover:bg-emerald-100" %>
              <%= link_to "Details", financial_goal_path(goal), class: "text-sm px-3 py-1.5 rounded-lg bg-content/5 text-content hover:bg-content/10" %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-12 bg-content/5 rounded-2xl border border-dashed border-default">
        <p class="text-subtle mb-4">You don't have any active financial goals yet.</p>
        <%= link_to "Create Your First Goal", new_financial_goal_path, class: "inline-flex items-center px-5 py-2.5 rounded-xl bg-emerald-600 text-white font-semibold shadow hover:bg-emerald-500" %>
      </div>
    <% end %>
  </div>

  <!-- Completed Goals -->
  <% if @completed_goals.any? %>
    <div class="bg-surface border border-white/30 backdrop-blur-2xl rounded-3xl shadow-2xl p-6 sm:p-8">
      <h2 class="text-xl font-semibold text-content mb-6">Completed Goals</h2>
      
      <div class="space-y-4">
        <% @completed_goals.each do |goal| %>
          <div class="border rounded-lg p-4 bg-green-50">
            <div class="flex justify-between items-center">
              <div>
                <h3 class="font-semibold"><%= goal.name %></h3>
                <p class="text-sm text-subtle">Completed on <%= goal.completion_date.strftime('%b %d, %Y') %></p>
              </div>
              <div class="text-right">
                <p class="font-bold text-green-600">K<%= number_with_precision(goal.target_amount, precision: 2) %></p>
                <p class="text-sm text-green-800">100% Complete</p>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Overdue Goals -->
  <% if @overdue_goals.any? %>
    <div class="bg-surface border border-white/30 backdrop-blur-2xl rounded-3xl shadow-2xl p-6 sm:p-8 border-l-4 border-red-500">
      <h2 class="text-xl font-semibold text-content mb-6">Overdue Goals</h2>
      
      <div class="space-y-4">
        <% @overdue_goals.each do |goal| %>
          <div class="border rounded-lg p-4 bg-red-50">
            <div class="flex justify-between items-center">
              <div>
                <h3 class="font-semibold"><%= goal.name %></h3>
                <p class="text-sm text-red-600">Due on <%= goal.target_date.strftime('%b %d, %Y') %></p>
              </div>
              <div class="text-right">
                <p class="font-bold">K<%= number_with_precision(goal.current_amount, precision: 2) %> of K<%= number_with_precision(goal.target_amount, precision: 2) %></p>
                <p class="text-sm"><%= goal.progress_percentage %>% Complete</p>
              </div>
            </div>
            
            <div class="mt-4 flex justify-end space-x-2">
              <%= link_to "Update Progress", edit_financial_goal_path(goal), class: "text-sm px-3 py-1.5 rounded-lg bg-emerald-50 text-emerald-700 hover:bg-emerald-100" %>
              <%= link_to "Extend Deadline", edit_financial_goal_path(goal), class: "text-sm px-3 py-1.5 rounded-lg bg-red-50 text-red-700 hover:bg-red-100" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
