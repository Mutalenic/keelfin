<div class="space-y-8">
  <!-- Page Header -->
  <div class="bg-white/10 border border-white/20 backdrop-blur-2xl rounded-3xl p-6 sm:p-8 shadow-[0_25px_70px_rgba(15,23,42,0.35)]">
    <div class="flex flex-wrap items-start justify-between gap-6">
      <div>
        <p class="text-sm uppercase tracking-[0.2em] text-white/60">Goals & Growth</p>
        <h1 class="mt-2 text-3xl sm:text-4xl font-semibold text-white tracking-tight">Financial goals</h1>
        <p class="mt-3 text-sm sm:text-base text-white/70 max-w-2xl">
          Plant milestones and track contributions toward your future — school fees, plot purchases, dream businesses, and life upgrades.
        </p>
      </div>
      <div class="flex flex-wrap gap-3">
        <%= link_to dashboard_path(anchor: 'financial-goals'), class: "inline-flex items-center px-4 py-2.5 rounded-2xl text-sm font-semibold border border-white/30 text-white/80 hover:bg-white/5 transition" do %>
          <i class="fa-solid fa-chart-line mr-2"></i>
          Insights
        <% end %>
        <%= link_to new_financial_goal_path, class: "inline-flex items-center px-5 py-3 rounded-2xl text-sm font-semibold bg-white text-brand-700 shadow-lg shadow-white/30" do %>
          <i class="fa-solid fa-plus mr-2"></i>
          New goal
        <% end %>
      </div>
    </div>
  </div>

  <!-- Goals Summary -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div class="rounded-2xl border border-white/15 bg-white/10 backdrop-blur-xl p-5 text-white shadow-lg">
      <p class="text-sm uppercase tracking-wide text-white/60">Active goals</p>
      <p class="mt-2 text-4xl font-semibold"><%= @active_goals.count %></p>
      <p class="mt-1 text-xs text-white/50">Tracking live ambitions</p>
    </div>
    <div class="rounded-2xl border border-white/15 bg-white/10 backdrop-blur-xl p-5 text-white shadow-lg">
      <p class="text-sm uppercase tracking-wide text-white/60">Completion rate</p>
      <p class="mt-2 text-4xl font-semibold"><%= @completion_rate %>%</p>
      <p class="mt-1 text-xs text-white/50">Momentum toward targets</p>
    </div>
    <div class="rounded-2xl border border-white/15 bg-white/10 backdrop-blur-xl p-5 text-white shadow-lg">
      <p class="text-sm uppercase tracking-wide text-white/60">Total saved</p>
      <p class="mt-2 text-4xl font-semibold">K<%= number_with_precision(@total_saved, precision: 2) %></p>
      <p class="mt-1 text-xs text-white/50">Across all goal vaults</p>
    </div>
  </div>

  <!-- Goals Progress Chart -->
  <% if @active_goals.any? %>
    <div class="rounded-3xl border border-white/15 bg-white/10 backdrop-blur-2xl shadow-xl p-6">
      <%= render 'goals_chart' %>
    </div>
  <% end %>

  <!-- Active Goals -->
  <div class="rounded-3xl border border-white/15 bg-white/95 backdrop-blur-xl shadow-2xl p-6">
    <div class="flex flex-wrap items-center justify-between gap-4 mb-6">
      <div>
        <p class="text-xs uppercase tracking-[0.3em] text-brand-500">Active</p>
        <h2 class="text-2xl font-semibold text-gray-900">Goals with momentum</h2>
      </div>
      <%= link_to "New Goal", new_financial_goal_path, class: "inline-flex items-center px-4 py-2 rounded-2xl text-sm font-semibold bg-brand-600 text-white shadow hover:bg-brand-500 transition" %>
    </div>

    <% if @active_goals.any? %>
      <div class="space-y-5">
        <% @active_goals.each do |goal| %>
          <div class="rounded-2xl border border-gray-100/60 bg-white shadow hover:border-brand-200 transition">
            <div class="p-5">
              <div class="flex flex-wrap justify-between gap-4">
                <div>
                  <h3 class="text-lg font-semibold text-gray-900"><%= link_to goal.name, financial_goal_path(goal), class: "hover:text-brand-600" %></h3>
                  <p class="mt-1 text-sm text-gray-500"><%= goal.goal_type.humanize %> • Due <%= goal.target_date.strftime('%b %d, %Y') %></p>
                  <p class="mt-2 text-sm text-gray-600"><span class="font-medium text-gray-800">Target:</span> K<%= number_with_precision(goal.target_amount, precision: 2) %></p>
                </div>
                <div class="text-right">
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold
                    <%= case goal.priority
                        when 'high' then 'bg-red-100 text-red-700'
                        when 'medium' then 'bg-amber-100 text-amber-700'
                        else 'bg-emerald-100 text-emerald-700'
                        end %>">
                    <i class="fa-solid fa-signal mr-1"></i>
                    <%= goal.priority.capitalize %>
                  </span>
                  <p class="mt-2 text-lg font-semibold text-gray-900"><%= goal.progress_percentage %>% complete</p>
                </div>
              </div>

              <div class="mt-4">
                <div class="w-full bg-gray-100 rounded-full h-2.5 overflow-hidden">
                  <div class="bg-gradient-to-r from-brand-500 to-brand-300 h-2.5 rounded-full" style="width: <%= goal.progress_percentage %>%"></div>
                </div>
                <div class="mt-3 flex flex-wrap justify-between text-xs text-gray-500">
                  <span>K<%= number_with_precision(goal.current_amount, precision: 2) %> of K<%= number_with_precision(goal.target_amount, precision: 2) %></span>
                  <span><%= goal.days_remaining %> days left</span>
                </div>
              </div>

              <div class="mt-4 flex flex-wrap justify-end gap-3 text-sm">
                <%= link_to "Update progress", edit_financial_goal_path(goal), class: "inline-flex items-center px-3 py-1.5 rounded-xl border border-gray-200 text-gray-700 hover:border-brand-300" %>
                <%= link_to "Details", financial_goal_path(goal), class: "inline-flex items-center px-3 py-1.5 rounded-xl border border-brand-100 text-brand-600 hover:bg-brand-50" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-10 rounded-2xl border border-dashed border-gray-200 bg-gray-50">
        <p class="text-gray-500 mb-4">You don't have any active financial goals yet.</p>
        <%= link_to "Create your first goal", new_financial_goal_path, class: "inline-flex items-center px-5 py-3 rounded-2xl text-sm font-semibold bg-brand-600 text-white shadow hover:bg-brand-500" %>
      </div>
    <% end %>
  </div>

  <!-- Completed Goals -->
  <% if @completed_goals.any? %>
    <div class="rounded-3xl border border-emerald-200/40 bg-emerald-50/80 backdrop-blur-md shadow-xl p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-xl font-semibold text-emerald-900">Completed goals</h2>
        <p class="text-sm text-emerald-700"><%= @completed_goals.count %> celebrated</p>
      </div>
      <div class="space-y-4">
        <% @completed_goals.each do |goal| %>
          <div class="rounded-2xl border border-emerald-200 bg-white/80 p-4">
            <div class="flex flex-wrap justify-between gap-3">
              <div>
                <h3 class="font-semibold text-emerald-900"><%= goal.name %></h3>
                <p class="text-sm text-emerald-600">Completed on <%= goal.completion_date.strftime('%b %d, %Y') %></p>
              </div>
              <div class="text-right">
                <p class="text-lg font-semibold text-emerald-700">K<%= number_with_precision(goal.target_amount, precision: 2) %></p>
                <p class="text-sm text-emerald-600">100% complete</p>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Overdue Goals -->
  <% if @overdue_goals.any? %>
    <div class="rounded-3xl border border-rose-200/50 bg-rose-50/80 backdrop-blur-md shadow-xl p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-xl font-semibold text-rose-900">Overdue goals</h2>
        <p class="text-sm text-rose-600">Needs attention</p>
      </div>
      <div class="space-y-4">
        <% @overdue_goals.each do |goal| %>
          <div class="rounded-2xl border border-rose-200 bg-white/90 p-4">
            <div class="flex flex-wrap justify-between gap-3">
              <div>
                <h3 class="font-semibold text-rose-900"><%= goal.name %></h3>
                <p class="text-sm text-rose-600">Due on <%= goal.target_date.strftime('%b %d, %Y') %></p>
              </div>
              <div class="text-right">
                <p class="text-base font-semibold text-rose-800">K<%= number_with_precision(goal.current_amount, precision: 2) %> of K<%= number_with_precision(goal.target_amount, precision: 2) %></p>
                <p class="text-sm text-rose-600"><%= goal.progress_percentage %>% complete</p>
              </div>
            </div>
            <div class="mt-4 flex flex-wrap justify-end gap-2 text-sm">
              <%= link_to "Update progress", edit_financial_goal_path(goal), class: "inline-flex items-center px-3 py-1.5 rounded-xl border border-rose-200 text-rose-700 hover:bg-rose-100" %>
              <%= link_to "Extend deadline", edit_financial_goal_path(goal), class: "inline-flex items-center px-3 py-1.5 rounded-xl border border-transparent text-white bg-rose-500 hover:bg-rose-400" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>

<!-- Quick Actions -->
<div class="fixed bottom-6 right-6 z-10">
  <div class="flex flex-col space-y-2">
    <%= link_to new_financial_goal_path, class: "bg-gradient-to-br from-brand-500 to-brand-700 text-white p-4 rounded-full shadow-2xl shadow-brand-900/40 hover:scale-105 transition" do %>
      <i class="fa-solid fa-plus"></i>
    <% end %>
  </div>
</div>
