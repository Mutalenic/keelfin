<div class="bg-surface border border-default backdrop-blur-2xl rounded-3xl shadow-2xl shadow-black/20 p-6">
  <div class="flex justify-between items-center mb-4">
    <h2 class="text-xl font-semibold text-content">Goals Progress Overview</h2>
    <div class="flex space-x-2">
      <button id="view-as-chart" class="bg-content/5 text-subtle px-3 py-1 rounded-xl hover:bg-content/10 border border-default">
        <i class="fa-solid fa-chart-bar mr-1"></i> Chart
      </button>
      <button id="view-as-table" class="bg-content/5 text-subtle px-3 py-1 rounded-xl hover:bg-content/10 border border-default">
        <i class="fa-solid fa-table mr-1"></i> Table
      </button>
    </div>
  </div>

  <div id="goals-chart" class="mb-6">
    <!-- Chart will be rendered here -->
    <div class="h-64">
      <canvas id="goals-progress-chart"></canvas>
    </div>
  </div>

  <script>
    // Make goals progress data available to the charts.js script
    const goalsProgressData = <%= raw json_escape(@active_goals.to_json(only: [:name, :current_amount, :target_amount])) %>;
  </script>

  <div id="goals-table" class="hidden">
    <% if @active_goals.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-default">
          <thead class="bg-content/5">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-subtle uppercase tracking-wider">Goal</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-subtle uppercase tracking-wider">Current</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-subtle uppercase tracking-wider">Target</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-subtle uppercase tracking-wider">Progress</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-default">
            <% @active_goals.each do |goal| %>
              <tr class="hover:bg-content/10">
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm font-medium text-content"><%= goal.name %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm font-medium text-content">K<%= number_with_precision(goal.current_amount, precision: 2) %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm font-medium text-content">K<%= number_with_precision(goal.target_amount, precision: 2) %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <% pct = goal.progress_percentage %>
                  <div class="flex items-center">
                    <div class="w-full bg-content/5 rounded-full h-2.5 mr-2 w-24">
                      <div class="bg-brand-400 h-2.5 rounded-full" style="width: <%= [[pct.to_f, 0].max, 100].min %>%"></div>
                    </div>
                    <span class="text-sm font-medium text-subtle"><%= pct %>&#37;</span>
                  </div>
                </td>
              </tr>
            <% end -%>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="text-accent text-center py-4">No active goals available</p>
    <% end %>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const chartButton = document.getElementById('view-as-chart');
    const tableButton = document.getElementById('view-as-table');
    const chartDiv = document.getElementById('goals-chart');
    const tableDiv = document.getElementById('goals-table');
    
    if (chartButton && tableButton && chartDiv && tableDiv) {
      chartButton.addEventListener('click', function() {
        chartDiv.classList.remove('hidden');
        tableDiv.classList.add('hidden');
        chartButton.classList.remove('bg-content/5', 'text-subtle');
        chartButton.classList.add('bg-brand-600', 'text-white');
        tableButton.classList.remove('bg-brand-600', 'text-white');
        tableButton.classList.add('bg-content/5', 'text-subtle');
      });

      tableButton.addEventListener('click', function() {
        chartDiv.classList.add('hidden');
        tableDiv.classList.remove('hidden');
        tableButton.classList.remove('bg-content/5', 'text-subtle');
        tableButton.classList.add('bg-brand-600', 'text-white');
        chartButton.classList.remove('bg-brand-600', 'text-white');
        chartButton.classList.add('bg-content/5', 'text-subtle');
      });
    }
  });
</script>
