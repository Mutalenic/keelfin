<div class="bg-brand-900/80 border border-brand-700/40 backdrop-blur-2xl rounded-3xl shadow-2xl shadow-black/20 p-6">
  <div class="flex justify-between items-center mb-4">
    <h2 class="text-xl font-semibold text-brand-100">Goals Progress Overview</h2>
    <div class="flex space-x-2">
      <button id="view-as-chart" class="bg-brand-800 text-brand-300 px-3 py-1 rounded-xl hover:bg-brand-700 border border-brand-700/50">
        <i class="fa-solid fa-chart-bar mr-1"></i> Chart
      </button>
      <button id="view-as-table" class="bg-brand-800 text-brand-300 px-3 py-1 rounded-xl hover:bg-brand-700 border border-brand-700/50">
        <i class="fa-solid fa-table mr-1"></i> Table
      </button>
    </div>
  </div>

  <div id="goals-chart" class="mb-6">
    <!-- Chart will be rendered here -->
    <div class="h-64">
      <canvas id="goals-progress-chart"></canvas>
    </div>
  </div>

  <script>
    // Make goals progress data available to the charts.js script
    const goalsProgressData = <%= json_escape(@active_goals.to_json(only: [:name, :current_amount, :target_amount])) %>;
  </script>

  <div id="goals-table" class="hidden">
    <% if @active_goals.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-brand-700/30">
          <thead class="bg-brand-800/60">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-brand-300 uppercase tracking-wider">Goal</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-brand-300 uppercase tracking-wider">Current</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-brand-300 uppercase tracking-wider">Target</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-brand-300 uppercase tracking-wider">Progress</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-brand-700/30">
            <% @active_goals.each do |goal| %>
              <tr class="hover:bg-brand-800/40">
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm font-medium text-brand-100"><%= goal.name %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm font-medium text-brand-100">K<%= number_with_precision(goal.current_amount, precision: 2) %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm font-medium text-brand-100">K<%= number_with_precision(goal.target_amount, precision: 2) %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <% pct = goal.progress_percentage %>
                  <div class="flex items-center">
                    <div class="w-full bg-brand-800 rounded-full h-2.5 mr-2 w-24">
                      <div class="bg-brand-400 h-2.5 rounded-full" style="width: <%= pct %>"></div>
                    </div>
                    <span class="text-sm font-medium text-brand-200"><%= pct %>&#37;</span>
                  </div>
                </td>
              </tr>
            <% end -%>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="text-brand-400 text-center py-4">No active goals available</p>
    <% end %>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const chartButton = document.getElementById('view-as-chart');
    const tableButton = document.getElementById('view-as-table');
    const chartDiv = document.getElementById('goals-chart');
    const tableDiv = document.getElementById('goals-table');
    
    if (chartButton && tableButton && chartDiv && tableDiv) {
      chartButton.addEventListener('click', function() {
        chartDiv.classList.remove('hidden');
        tableDiv.classList.add('hidden');
        chartButton.className = chartButton.className.replace('bg-brand-800','bg-brand-600').replace('text-brand-300','text-white');
        tableButton.className = tableButton.className.replace('bg-brand-600','bg-brand-800').replace('text-white','text-brand-300');
      });

      tableButton.addEventListener('click', function() {
        chartDiv.classList.add('hidden');
        tableDiv.classList.remove('hidden');
        tableButton.className = tableButton.className.replace('bg-brand-800','bg-brand-600').replace('text-brand-300','text-white');
        chartButton.className = chartButton.className.replace('bg-brand-600','bg-brand-800').replace('text-white','text-brand-300');
      });
    }
  });
</script>
