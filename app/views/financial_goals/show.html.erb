<% content_for(:page_title) { @financial_goal.name } %>
<% content_for(:skip_card_wrapper, true) %>

<div class="space-y-8">
  <!-- Hero Banner -->
  <div class="rounded-3xl p-6 sm:p-8 text-white shadow-[0_25px_80px_rgba(15,23,42,0.45)] border border-white/10"
       style="background: linear-gradient(135deg, #10b981 0%, #059669 55%, #1e1b4b 100%);">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
      <div>
        <p class="text-xs uppercase tracking-[0.3em] text-white/70 mb-3">Goal Details</p>
        <h1 class="text-2xl sm:text-3xl font-semibold tracking-tight"><%= @financial_goal.name %></h1>
        <p class="mt-2 text-sm sm:text-base text-white/80 max-w-2xl">
          <%= @financial_goal.description %>
        </p>
      </div>
      <div class="flex items-center gap-3">
        <%= link_to financial_goals_path, class: "inline-flex items-center px-5 py-3 rounded-2xl text-sm font-semibold border border-white/30 text-white/90 hover:bg-white/5 transition" do %>
          <i class="fa-solid fa-arrow-left mr-2"></i>
          Back to Goals
        <% end %>
        <%= link_to edit_financial_goal_path(@financial_goal), class: "inline-flex items-center px-5 py-3 rounded-2xl text-sm font-semibold bg-white text-emerald-700 shadow-lg shadow-white/20" do %>
          <i class="fa-solid fa-pencil mr-2"></i>
          Edit Goal
        <% end %>
      </div>
    </div>

    <!-- Status Tags -->
    <div class="mt-6 flex flex-wrap gap-2">
      <span class="inline-block px-3 py-1 rounded-full text-sm font-semibold bg-white/20 text-white">
        <%= @financial_goal.goal_type.humanize %>
      </span>
      <span class="inline-block px-3 py-1 rounded-full text-sm font-semibold
        <%= case @financial_goal.priority
            when 'high' then 'bg-red-400/30 text-white'
            when 'medium' then 'bg-amber-400/30 text-white'
            else 'bg-emerald-400/30 text-white'
            end %>">
        <%= @financial_goal.priority.capitalize %> Priority
      </span>
      <% if @financial_goal.recurring %>
        <span class="inline-block px-3 py-1 rounded-full text-sm font-semibold bg-purple-400/30 text-white">
          Recurring: <%= @financial_goal.recurrence_period %>
        </span>
      <% end %>
      <% if @financial_goal.category %>
        <span class="inline-block px-3 py-1 rounded-full text-sm font-semibold bg-white/20 text-white">
          <%= @financial_goal.category.name %>
        </span>
      <% end %>
    </div>
  </div>

  <!-- Goal Header -->
  <div class="bg-brand-900/80 border border-brand-700/40 backdrop-blur-2xl rounded-3xl shadow-2xl shadow-black/20 p-6">
    <div class="flex justify-between items-start">
      <div class="flex items-center gap-3">
        <% if @financial_goal.completed? %>
          <span class="inline-flex items-center px-4 py-2 rounded-xl text-sm font-bold bg-emerald-900/40 text-emerald-300 border border-emerald-700/40">
            <i class="fa-solid fa-check-circle mr-2"></i> Completed
          </span>
        <% elsif @financial_goal.target_date < Date.current %>
          <span class="inline-flex items-center px-4 py-2 rounded-xl text-sm font-bold bg-red-900/40 text-red-300 border border-red-700/40">
            <i class="fa-solid fa-exclamation-circle mr-2"></i> Overdue
          </span>
        <% else %>
          <span class="inline-flex items-center px-4 py-2 rounded-xl text-sm font-bold bg-brand-800/60 text-brand-300 border border-brand-700/40">
            <i class="fa-solid fa-circle-notch mr-2"></i> Active
          </span>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Progress Section -->
  <div class="bg-brand-900/80 border border-brand-700/40 backdrop-blur-2xl rounded-3xl shadow-2xl shadow-black/20 p-6">
    <h2 class="text-xl font-semibold text-brand-100 mb-4">Progress</h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
      <div class="bg-brand-800/60 border border-brand-700/30 rounded-lg p-4">
        <p class="text-sm text-brand-400 mb-1">Current Amount</p>
        <p class="text-2xl font-bold text-brand-100">K<%= number_with_precision(@financial_goal.current_amount, precision: 2) %></p>
      </div>

      <div class="bg-brand-800/60 border border-brand-700/30 rounded-lg p-4">
        <p class="text-sm text-brand-400 mb-1">Target Amount</p>
        <p class="text-2xl font-bold text-brand-100">K<%= number_with_precision(@financial_goal.target_amount, precision: 2) %></p>
      </div>

      <div class="bg-brand-800/60 border border-brand-700/30 rounded-lg p-4">
        <p class="text-sm text-brand-400 mb-1">Remaining</p>
        <p class="text-2xl font-bold text-brand-100">K<%= number_with_precision(@financial_goal.target_amount - @financial_goal.current_amount, precision: 2) %></p>
      </div>
    </div>

    <!-- Progress Bar -->
    <div class="mb-2">
      <div class="flex justify-between text-sm mb-1 text-brand-300">
        <span>Progress: <%= @financial_goal.progress_percentage %>%</span>
        <span><%= @financial_goal.days_remaining %> days remaining</span>
      </div>
      <div class="w-full bg-brand-800 rounded-full h-4">
        <div class="bg-brand-500 h-4 rounded-full" style="width: <%= @financial_goal.progress_percentage %>"></div>
      </div>
    </div>

    <!-- Daily Target -->
    <div class="mt-4 bg-brand-800/60 border border-brand-700/30 rounded-lg p-4">
      <div class="flex items-center">
        <div class="mr-4 text-brand-400">
          <i class="fa-solid fa-calendar-day text-2xl"></i>
        </div>
        <div>
          <p class="font-medium text-brand-200">Daily Target</p>
          <p class="text-sm text-brand-300">You need to save <strong class="text-brand-100">K<%= number_with_precision(@financial_goal.daily_target, precision: 2) %></strong> per day to reach your goal on time.</p>
        </div>
      </div>
    </div>

    <!-- Update Progress Form -->
    <% unless @financial_goal.completed? %>
      <div class="mt-6">
        <%= form_with url: update_progress_financial_goal_path(@financial_goal), method: :patch, class: "flex items-center space-x-4" do |f| %>
          <div class="flex-grow">
            <%= f.label :current_amount, "Update Current Amount", class: "block text-sm font-medium text-brand-300 mb-1" %>
            <div class="mt-1 flex rounded-md shadow-sm">
              <span class="inline-flex items-center px-3 rounded-l-md border border-r-0 border-brand-700/50 bg-brand-800/60 text-brand-400">K</span>
              <%= f.number_field :current_amount, value: @financial_goal.current_amount, step: "0.01", min: "0", class: "flex-1 min-w-0 block w-full px-3 py-2 rounded-none rounded-r-md border border-brand-700/50 bg-brand-800/60 text-brand-100 focus:ring-brand-500 focus:border-brand-500" %>
            </div>
          </div>
          <%= f.submit "Update Progress", class: "inline-flex items-center px-4 py-2 rounded-xl text-sm font-semibold bg-emerald-600 text-white shadow hover:bg-emerald-500 transition" %>
        <% end %>
      </div>
    <% end %>
  </div>
  
  <!-- Timeline & Milestones -->
  <div class="bg-brand-900/80 border border-brand-700/40 backdrop-blur-2xl rounded-3xl shadow-2xl shadow-black/20 p-6">
    <h2 class="text-xl font-semibold text-brand-100 mb-4">Timeline & Milestones</h2>

    <div class="flex justify-between mb-6 text-sm">
      <div>
        <p class="text-brand-400">Start Date</p>
        <p class="font-semibold text-brand-100"><%= @financial_goal.start_date.strftime('%b %d, %Y') %></p>
      </div>
      <div class="text-center">
        <p class="text-brand-400">Duration</p>
        <p class="font-semibold text-brand-100"><%= (@financial_goal.target_date - @financial_goal.start_date).to_i %> days</p>
      </div>
      <div class="text-right">
        <p class="text-brand-400">Target Date</p>
        <p class="font-semibold text-brand-100"><%= @financial_goal.target_date.strftime('%b %d, %Y') %></p>
      </div>
    </div>

    <!-- Milestones -->
    <% if @financial_goal.milestones.present? && @financial_goal.milestones.any? %>
      <h3 class="font-medium text-lg text-brand-200 mb-3">Milestones</h3>
      <div class="space-y-4">
        <% @financial_goal.milestones.each do |milestone| %>
          <div class="flex items-center">
            <div class="relative mr-4">
              <div class="h-full w-0.5 absolute left-2.5 bg-brand-700/50"></div>
              <div class="w-5 h-5 rounded-full <%= milestone['completed'] ? 'bg-emerald-500' : 'bg-brand-700' %> flex items-center justify-center">
                <% if milestone['completed'] %>
                  <i class="fa-solid fa-check text-white text-xs"></i>
                <% end %>
              </div>
            </div>
            <div class="flex-grow">
              <p class="font-medium text-brand-100"><%= milestone['name'] %></p>
              <p class="text-sm text-brand-400"><%= milestone['target_date'] %> • <%= number_with_precision(milestone['amount'], precision: 2) %></p>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-brand-400 italic">No milestones set for this goal.</p>
    <% end %>
  </div>
  
  <!-- Recommendations -->
  <% if @recommendations.present? %>
    <div class="bg-brand-900/80 border border-brand-700/40 backdrop-blur-2xl rounded-3xl shadow-2xl shadow-black/20 p-6">
      <h2 class="text-xl font-semibold text-brand-100 mb-4">Recommendations</h2>

      <div class="space-y-4">
        <% @recommendations.each do |recommendation| %>
          <div class="flex items-start">
            <div class="mr-3 text-brand-400">
              <i class="fa-solid fa-lightbulb"></i>
            </div>
            <p class="text-brand-200"><%= recommendation %></p>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Related Transactions -->
  <% if @related_transactions&.any? %>
    <div class="bg-brand-900/80 border border-brand-700/40 backdrop-blur-2xl rounded-3xl shadow-2xl shadow-black/20 p-6">
      <h2 class="text-xl font-semibold text-brand-100 mb-4">Related Transactions</h2>

      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-brand-700/30">
          <thead class="bg-brand-800/60">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-brand-300 uppercase tracking-wider">Name</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-brand-300 uppercase tracking-wider">Date</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-brand-300 uppercase tracking-wider">Amount</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-brand-700/30">
            <% @related_transactions.each do |transaction| %>
              <tr class="hover:bg-brand-800/40">
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm font-medium text-brand-100"><%= transaction.name %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm text-brand-400"><%= transaction.created_at.strftime('%b %d, %Y') %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm font-medium text-brand-100">K<%= number_with_precision(transaction.amount, precision: 2) %></div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>
  
  <!-- Action Buttons -->
  <div class="flex justify-between">
    <%= link_to financial_goals_path, class: "inline-flex items-center px-5 py-3 rounded-2xl text-sm font-semibold border border-white/30 text-white/90 hover:bg-white/5 transition" do %>
      <i class="fa-solid fa-arrow-left mr-2"></i>
      Back to Goals
    <% end %>

    <div class="flex items-center gap-3">
      <%= link_to edit_financial_goal_path(@financial_goal), class: "inline-flex items-center px-5 py-3 rounded-2xl text-sm font-semibold bg-emerald-600 text-white shadow hover:bg-emerald-500 transition" do %>
        <i class="fa-solid fa-pencil mr-2"></i>
        Edit Goal
      <% end %>
      <%= button_to financial_goal_path(@financial_goal), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this goal?" }, class: "inline-flex items-center px-5 py-3 rounded-2xl text-sm font-semibold bg-red-600 text-white shadow hover:bg-red-500 transition" do %>
        <i class="fa-solid fa-trash mr-2"></i>
        Delete Goal
      <% end %>
    </div>
  </div>
</div>
