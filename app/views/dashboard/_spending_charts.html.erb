<div class="bg-surface border border-default backdrop-blur-2xl rounded-3xl shadow-xl p-6">
  <div class="flex justify-between items-center mb-4">
    <h2 class="text-xl font-semibold text-content">Spending Analytics</h2>
    <div class="flex space-x-2">
      <button id="view-as-chart" class="bg-content/5 text-subtle px-3 py-1 rounded-xl hover:bg-content/10 border border-default">
        <i class="fa-solid fa-chart-bar mr-1"></i> Chart
      </button>
      <button id="view-as-table" class="bg-content/5 text-subtle px-3 py-1 rounded-xl hover:bg-content/10 border border-default">
        <i class="fa-solid fa-table mr-1"></i> Table
      </button>
    </div>
  </div>

  <div id="spending-chart" class="mb-6">
    <!-- Chart will be rendered here -->
    <div class="h-64">
      <canvas id="spending-by-category-chart"></canvas>
    </div>
  </div>

  <script>
    // Make spending by category data available to the charts.js script
    const spendingByCategoryData = <%= raw json_escape(@spending_by_category.to_json) %>;
  </script>

  <div id="spending-table" class="hidden">
    <% if @spending_by_category.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-default">
          <thead class="bg-content/5">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-subtle uppercase tracking-wider">Category</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-subtle uppercase tracking-wider">Amount</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-subtle uppercase tracking-wider">Percentage</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-default">
            <% @spending_by_category.each do |category, amount| %>
              <% cat_pct = @total_spending > 0 ? (amount / @total_spending * 100).round(1) : 0 %>
              <tr class="hover:bg-content/5">
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm font-medium text-content"><%= category %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm font-medium text-content">K<%= number_with_precision(amount, precision: 2) %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center">
                    <div class="w-full bg-content/10 rounded-full h-2.5 mr-2 w-24">
                      <div class="bg-accent h-2.5 rounded-full" style="width: <%= cat_pct %>%"></div>
                    </div>
                    <span class="text-sm font-medium text-subtle"><%= number_with_precision(cat_pct, precision: 1) %>%</span>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="text-faint text-center py-4">No spending data available</p>
    <% end %>
  </div>
</div>

<%
  btn_active   = "bg-accent text-white border-accent"
  btn_inactive = "bg-content/5 text-subtle border-default"
%>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    var chartButton = document.getElementById('view-as-chart');
    var tableButton = document.getElementById('view-as-table');
    var chartDiv    = document.getElementById('spending-chart');
    var tableDiv    = document.getElementById('spending-table');
    var ACTIVE   = "<%= btn_active %>".split(' ');
    var INACTIVE = "<%= btn_inactive %>".split(' ');

    if (chartButton && tableButton && chartDiv && tableDiv) {
      chartButton.addEventListener('click', function() {
        chartDiv.classList.remove('hidden');
        tableDiv.classList.add('hidden');
        INACTIVE.forEach(function(c){ chartButton.classList.remove(c); });
        ACTIVE.forEach(function(c){   chartButton.classList.add(c); });
        ACTIVE.forEach(function(c){   tableButton.classList.remove(c); });
        INACTIVE.forEach(function(c){ tableButton.classList.add(c); });
      });
      tableButton.addEventListener('click', function() {
        chartDiv.classList.add('hidden');
        tableDiv.classList.remove('hidden');
        ACTIVE.forEach(function(c){   chartButton.classList.remove(c); });
        INACTIVE.forEach(function(c){ chartButton.classList.add(c); });
        INACTIVE.forEach(function(c){ tableButton.classList.remove(c); });
        ACTIVE.forEach(function(c){   tableButton.classList.add(c); });
      });
    }
  });
</script>
