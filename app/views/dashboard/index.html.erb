<% content_for :page_title, "Dashboard" %>
<% content_for :skip_card_wrapper, true %>

<div class="space-y-8">
  <!-- Hero Banner -->
  <div class="rounded-3xl p-6 sm:p-8 text-white shadow-[0_25px_80px_rgba(2,44,34,0.45)] border border-brand-400/20"
       style="background: linear-gradient(135deg, #059669 0%, #047857 55%, #022c22 100%);">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
      <div>
        <p class="text-xs uppercase tracking-[0.3em] text-white/70 mb-3">Overview</p>
        <h1 class="text-2xl sm:text-3xl font-semibold tracking-tight">Dashboard</h1>
        <p class="mt-2 text-sm sm:text-base text-white/80 max-w-2xl">
          Your financial overview and insights.
        </p>
      </div>
      <div class="flex items-center gap-3">
        <%= link_to coming_soon_path(feature: "Dashboard Customization"), id: "customize-dashboard", class: "inline-flex items-center px-4 py-2 rounded-xl text-sm font-semibold border border-white/30 text-white/90 hover:bg-white/5 transition" do %>
          <i class="fa-solid fa-gear mr-2"></i> Customize
        <% end %>
        <div class="relative" id="date-filter-container">
          <%= form_with url: dashboard_path, method: :get, class: "flex items-center gap-2" do |f| %>
            <%= f.select :month,
                options_for_select(
                  (0..11).map { |i| d = Date.current - i.months; [d.strftime('%B %Y'), d.strftime('%Y-%m')] },
                  params[:month] || Date.current.strftime('%Y-%m')
                ),
                {},
                class: "bg-white/20 text-white text-sm rounded-xl px-3 py-2 border border-white/30 focus:outline-none focus:ring-2 focus:ring-white/30 cursor-pointer",
                onchange: "this.form.submit()" %>
            <i class="fa-solid fa-calendar text-white/70"></i>
          <% end %>
        </div>
      </div>
    </div>
  </div>
  
  <%= render 'onboarding_checklist' %>

  <%= render 'budget_alerts' %>

  <!-- Debt Alert -->
  <% if @debt_analysis && @debt_analysis[:is_over_indebted] %>
    <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4 mb-6" role="alert">
      <p class="font-bold">⚠️ Debt Alert</p>
      <p>Your debt payments (<%= @debt_analysis[:debt_to_income] %>%) exceed the safe 40% threshold.</p>
      <%= link_to "Manage Debts", debts_path, class: "underline font-semibold" %>
    </div>
  <% end %>
  
  <!-- Financial Insights & Economic Indicators -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
    <!-- Economic Indicators -->
    <% if @latest_economic_data %>
      <div class="bg-surface border border-default rounded-2xl p-4">
        <h2 class="text-lg font-semibold mb-2 text-content">📊 Current Economic Indicators (2026)</h2>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <p class="text-sm text-subtle">USD/ZMW Exchange Rate</p>
            <p class="text-xl font-bold text-content"><%= @latest_economic_data.usd_zmw_rate ? "K#{number_with_precision(@latest_economic_data.usd_zmw_rate, precision: 2)}" : 'N/A' %></p>
          </div>
          <div>
            <p class="text-sm text-subtle">Inflation Rate</p>
            <p class="text-xl font-bold text-content"><%= @latest_economic_data.inflation_rate ? "#{number_with_precision(@latest_economic_data.inflation_rate, precision: 1)}%" : 'N/A' %></p>
          </div>
        </div>
        <div class="mt-3 text-xs text-faint">Source: Bank of Zambia, February 2026</div>
      </div>
    <% end %>

    <!-- Financial Insights -->
    <div class="bg-surface border border-default rounded-2xl p-4">
      <div class="flex items-center mb-3">
        <div class="p-2 bg-accent/15 rounded-full mr-3">
          <i class="fa-solid fa-lightbulb text-subtle"></i>
        </div>
        <h2 class="text-lg font-semibold text-content">Smart Financial Insights</h2>
      </div>
      <% if @financial_insights && @financial_insights.any? %>
        <ul class="space-y-3">
          <% @financial_insights.each do |insight| %>
            <li class="flex items-start">
              <i class="fa-solid fa-circle-check text-accent mt-1 mr-2"></i>
              <span class="text-subtle"><%= insight %></span>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="text-subtle italic">Continue tracking your finances to receive personalized insights.</p>
      <% end %>
      <div class="mt-4 text-right">
        <%= link_to financial_analysis_path, class: "text-accent hover:text-accent-hover text-sm font-medium flex items-center justify-end w-full" do %>
          <span>View Detailed Analysis</span>
          <i class="fa-solid fa-arrow-right ml-1"></i>
        <% end %>
      </div>
    </div>
  </div>

  <!-- BNNB Comparison -->
  <% if @bnnb_comparison %>
    <div class="bg-surface border border-default rounded-2xl p-6">
      <h2 class="text-xl font-semibold mb-4 text-content">📊 Your Spending vs. JCTR Benchmark</h2>
      <div class="grid grid-cols-2 gap-4 mb-4">
        <div>
          <p class="text-sm text-subtle">JCTR Total Basket</p>
          <p class="text-2xl font-bold text-content">K<%= number_with_precision(@bnnb_comparison[:bnnb_total], precision: 2) %></p>
        </div>
        <div>
          <p class="text-sm text-subtle">Your Total Spending</p>
          <p class="text-2xl font-bold text-content">K<%= number_with_precision(@bnnb_comparison[:user_total], precision: 2) %></p>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-4 mb-4">
        <div>
          <p class="text-sm text-subtle">JCTR Food Basket</p>
          <p class="text-lg font-semibold text-content">K<%= number_with_precision(@bnnb_comparison[:bnnb_food], precision: 2) %></p>
        </div>
        <div>
          <p class="text-sm text-subtle">Your Food Spending</p>
          <p class="text-lg font-semibold text-content">K<%= number_with_precision(@bnnb_comparison[:user_food], precision: 2) %></p>
        </div>
      </div>
      <div class="mt-4">
        <% @bnnb_comparison[:insights].each do |insight| %>
          <p class="text-sm mt-2 text-subtle"><%= insight %></p>
        <% end %>
      </div>
      <p class="text-xs text-faint mt-4">Source: JCTR BNNB January 2026</p>
    </div>
  <% end %>
  
  <!-- Spending Summary -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
    <div class="rounded-2xl border border-brand-400/30 backdrop-blur-xl p-5 text-white shadow-lg"
         style="background: linear-gradient(150deg, rgba(5,150,105,0.9) 0%, rgba(4,120,87,0.85) 100%);">
      <p class="text-xs uppercase tracking-wide text-white/70">Monthly Income</p>
      <p class="text-2xl font-semibold mt-3">K<%= number_with_precision(@total_monthly_income, precision: 2, delimiter: ',') %></p>
      <% if current_user.income_sources.any? %>
        <p class="text-xs text-white/50 mt-1"><%= current_user.income_sources.active.count %> source<%= current_user.income_sources.active.count == 1 ? '' : 's' %></p>
      <% end %>
    </div>

    <div class="rounded-2xl border border-brand-400/30 backdrop-blur-xl p-5 text-white shadow-lg"
         style="background: linear-gradient(150deg, rgba(239,68,68,0.75) 0%, rgba(185,28,28,0.7) 100%);">
      <p class="text-xs uppercase tracking-wide text-white/70">Spending (<%= @start_date.strftime('%b') %>)</p>
      <p class="text-2xl font-semibold mt-3">K<%= number_with_precision(@total_spending, precision: 2, delimiter: ',') %></p>
      <p class="text-xs text-white/50 mt-1">K<%= number_with_precision(@burn_rate, precision: 2) %>/day burn rate</p>
    </div>

    <% if @actual_balance %>
      <div class="rounded-2xl border border-brand-400/30 backdrop-blur-xl p-5 text-white shadow-lg"
           style="background: linear-gradient(150deg, rgba(16,185,129,0.95) 0%, rgba(5,150,105,0.85) 100%);">
        <p class="text-xs uppercase tracking-wide text-white/70">Current Balance</p>
        <p class="text-2xl font-semibold mt-3 <%= @actual_balance < 0 ? 'text-red-300' : '' %>">
          K<%= number_with_precision(@actual_balance, precision: 2, delimiter: ',') %>
        </p>
        <p class="text-xs text-white/50 mt-1">Based on opening balance</p>
      </div>
    <% else %>
      <div class="rounded-2xl border border-brand-600/30 backdrop-blur-xl p-5 text-white shadow-lg col-span-1"
           style="background: linear-gradient(150deg, rgba(6,95,70,0.5) 0%, rgba(4,78,56,0.4) 100%);">
        <p class="text-xs uppercase tracking-wide text-white/50">Current Balance</p>
        <p class="text-sm text-brand-400 mt-3">Not set</p>
        <%= link_to edit_user_registration_path, class: "text-xs text-white/70 underline hover:text-white mt-1 inline-block" do %>Set opening balance<% end %>
      </div>
    <% end %>

    <div class="rounded-2xl border border-brand-400/30 backdrop-blur-xl p-5 text-white shadow-lg"
         style="background: linear-gradient(150deg, rgba(6,95,70,0.95) 0%, rgba(4,78,56,0.85) 100%);">
      <p class="text-xs uppercase tracking-wide text-white/70">Projected Month-End</p>
      <p class="text-2xl font-semibold mt-3 <%= @projected_balance < 0 ? 'text-red-300' : '' %>">
        K<%= number_with_precision(@projected_balance, precision: 2, delimiter: ',') %>
      </p>
      <p class="text-xs text-white/50 mt-1">At current burn rate</p>
    </div>
  </div>

  <!-- Spending Analytics with Charts -->
  <%= render 'spending_charts' %>

  <!-- Monthly Spending Trend -->
  <% cache ["monthly-trend", current_user.id, Date.current.strftime('%Y-%m'),
            current_user.payments.cache_key_with_version] do %>
    <%= render 'monthly_trend_chart' %>
  <% end %>

  <!-- Recent Transactions -->
  <div class="bg-surface border border-default backdrop-blur-2xl rounded-3xl shadow-xl p-6">
    <h2 class="text-xl font-semibold mb-4 text-content">Recent Transactions</h2>
    <% if @recent_payments && @recent_payments.any? %>
      <% @recent_payments.each do |payment| %>
        <div class="flex justify-between items-center py-3 border-b border-default">
          <div>
            <p class="font-medium text-content"><%= payment.name %></p>
            <p class="text-sm text-subtle">
              <%= payment.category.name %> •
              <%= payment.created_at.strftime('%b %d, %Y') %>
              <% if payment.payment_method %>
                • <%= payment.payment_method.titleize %>
              <% end %>
            </p>
          </div>
          <p class="font-bold text-content">K<%= number_with_precision(payment.amount, precision: 2) %></p>
        </div>
      <% end %>
    <% else %>
      <p class="text-faint">No transactions yet.</p>
    <% end %>
  </div>

  <!-- Financial Goals & Investments -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <!-- Financial Goals -->
    <% cache ["goals-widget", current_user.id,
              current_user.financial_goals.cache_key_with_version] do %>
      <div class="bg-surface border border-default backdrop-blur-2xl rounded-3xl shadow-xl p-6">
        <div class="flex justify-between items-center mb-4">
          <h2 class="text-xl font-semibold text-content">Financial Goals</h2>
          <%= link_to "View All", financial_goals_path, class: "text-accent hover:text-accent-hover" %>
        </div>

        <% if @active_goals && @active_goals.any? %>
          <div class="space-y-4">
            <% @active_goals.each do |goal| %>
              <div class="border border-default rounded-xl p-3 hover:bg-content/5 transition-colors">
                <div class="flex justify-between items-center">
                  <div>
                    <h3 class="font-medium text-content"><%= link_to goal.name, financial_goal_path(goal), class: "text-content hover:text-subtle" %></h3>
                    <p class="text-sm text-subtle"><%= goal.days_remaining %> days left</p>
                  </div>
                  <div class="text-right">
                    <p class="font-bold text-content">K<%= number_with_precision(goal.current_amount, precision: 2) %> / K<%= number_with_precision(goal.target_amount, precision: 2) %></p>
                    <p class="text-sm text-subtle"><%= goal.progress_percentage %>% Complete</p>
                  </div>
                </div>

                <!-- Progress Bar -->
                <div class="mt-2 w-full bg-content/10 rounded-full h-2">
                  <div class="bg-accent h-2 rounded-full" style="width: <%= goal.progress_percentage %>%"></div>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-4 bg-content/5 rounded-xl border border-default">
            <p class="text-subtle mb-2">No active financial goals</p>
            <%= link_to "Create a Goal", new_financial_goal_path, class: "text-accent hover:text-accent-hover" %>
          </div>
        <% end %>
      </div>
    <% end %>

    <!-- Investments Summary -->
    <% cache ["investments-widget", current_user.id,
              current_user.investments.cache_key_with_version] do %>
      <div class="bg-surface border border-default backdrop-blur-2xl rounded-3xl shadow-xl p-6">
        <div class="flex justify-between items-center mb-4">
          <h2 class="text-xl font-semibold text-content">Investment Portfolio</h2>
          <%= link_to "View All", investments_path, class: "text-accent hover:text-accent-hover" %>
        </div>

        <% if @investments && @investments.any? %>
          <div class="mb-4">
            <div class="flex justify-between items-center mb-2">
              <p class="text-sm text-subtle">Total Portfolio Value</p>
              <p class="text-xl font-bold text-content">K<%= number_with_precision(@total_invested, precision: 2) %></p>
            </div>

            <div class="flex justify-between items-center">
              <p class="text-sm text-subtle">Total Return</p>
              <p class="text-lg font-bold <%= @investment_return[:percentage] >= 0 ? 'text-emerald-400' : 'text-red-400' %>">
                <%= @investment_return[:percentage] >= 0 ? '+' : '' %><%= number_with_precision(@investment_return[:percentage], precision: 2) %>%
              </p>
            </div>
          </div>

          <div class="space-y-4">
            <% @investments.each do |investment| %>
              <div class="border border-default rounded-xl p-3 hover:bg-content/5 transition-colors">
                <div class="flex justify-between items-center">
                  <div>
                    <h3 class="font-medium text-content"><%= link_to investment.name, investment_path(investment), class: "text-content hover:text-subtle" %></h3>
                    <p class="text-sm text-subtle"><%= investment.investment_type_text %></p>
                  </div>
                  <div class="text-right">
                    <p class="font-bold text-content">K<%= number_with_precision(investment.current_value, precision: 2) %></p>
                    <% return_percentage = investment.return_percentage %>
                    <p class="text-sm <%= return_percentage >= 0 ? 'text-emerald-400' : 'text-red-400' %>">
                      <%= return_percentage >= 0 ? '+' : '' %><%= number_with_precision(return_percentage, precision: 2) %>%
                    </p>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-4 bg-content/5 rounded-xl border border-default">
            <p class="text-subtle mb-2">No investments yet</p>
            <%= link_to "Add Investment", new_investment_path, class: "text-accent hover:text-accent-hover" %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Upcoming Recurring Transactions -->
  <div class="bg-surface border border-default backdrop-blur-2xl rounded-3xl shadow-xl p-6">
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-xl font-semibold text-content">Upcoming Recurring Transactions</h2>
      <%= link_to "View All", recurring_transactions_path, class: "text-accent hover:text-accent-hover" %>
    </div>

    <% if @upcoming_recurring && @upcoming_recurring.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-default">
          <thead class="bg-content/5">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-subtle uppercase tracking-wider">Name</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-subtle uppercase tracking-wider">Amount</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-subtle uppercase tracking-wider">Category</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-subtle uppercase tracking-wider">Next Date</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-default">
            <% @upcoming_recurring.each do |transaction| %>
              <tr class="hover:bg-content/5">
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm font-medium text-content"><%= link_to transaction.name, recurring_transaction_path(transaction), class: "text-content hover:text-subtle" %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm font-medium text-content">K<%= number_with_precision(transaction.amount, precision: 2) %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm text-subtle"><%= transaction.category.name %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <% if transaction.next_occurrence %>
                    <div class="text-sm text-content"><%= transaction.next_occurrence.strftime('%b %d, %Y') %></div>
                    <% days_until = (transaction.next_occurrence - Date.current).to_i %>
                    <div class="text-xs <%= days_until <= 0 ? 'text-danger font-bold' : 'text-faint' %>">
                      <%= days_until <= 0 ? 'Due today' : "in #{days_until} days" %>
                    </div>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="text-center py-4 bg-content/5 rounded-xl border border-default">
        <p class="text-subtle mb-2">No upcoming recurring transactions</p>
        <%= link_to "Set Up Recurring Transactions", recurring_transactions_path, class: "text-accent hover:text-accent-hover" %>
      </div>
    <% end %>
  </div>
  
  <!-- Quick Actions -->
  <div class="flex flex-wrap gap-3">
    <%= link_to new_category_payment_path(current_user.categories.first || Category.first), class: "inline-flex items-center px-5 py-3 rounded-2xl text-sm font-semibold bg-brand-600 text-white shadow hover:bg-brand-500 transition" do %>
      <i class="fa-solid fa-plus mr-2"></i> Add Transaction
    <% end if current_user.categories.any? %>

    <%= link_to financial_goals_path, class: "inline-flex items-center px-5 py-3 rounded-2xl text-sm font-semibold bg-emerald-600 text-white shadow hover:bg-emerald-500 transition" do %>
      <i class="fa-solid fa-bullseye mr-2"></i> Goals
    <% end %>

    <%= link_to investments_path, class: "inline-flex items-center px-5 py-3 rounded-2xl text-sm font-semibold bg-cyan-600 text-white shadow hover:bg-cyan-500 transition" do %>
      <i class="fa-solid fa-chart-line mr-2"></i> Investments
    <% end %>

    <%= link_to recurring_transactions_path, class: "inline-flex items-center px-5 py-3 rounded-2xl text-sm font-semibold bg-violet-600 text-white shadow hover:bg-violet-500 transition" do %>
      <i class="fa-solid fa-repeat mr-2"></i> Recurring
    <% end %>

    <%= link_to debts_path, class: "inline-flex items-center px-5 py-3 rounded-2xl text-sm font-semibold bg-red-600 text-white shadow hover:bg-red-500 transition" do %>
      <i class="fa-solid fa-credit-card mr-2"></i> Debts
    <% end %>

    <%= link_to categories_path, class: "inline-flex items-center px-5 py-3 rounded-2xl text-sm font-semibold bg-indigo-600 text-white shadow hover:bg-indigo-500 transition" do %>
      <i class="fa-solid fa-tags mr-2"></i> Categories
    <% end %>
  </div>
</div>
