<% content_for(:page_title) { "New Budget" } %>
<% content_for(:skip_card_wrapper, true) %>

<div class="space-y-8">
  <!-- Hero Banner -->
  <div class="rounded-3xl p-6 sm:p-8 text-white shadow-[0_25px_80px_rgba(15,23,42,0.45)] border border-white/10"
       style="background: linear-gradient(135deg, #4f46e5 0%, #4338ca 55%, #0f172a 100%);">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
      <div>
        <p class="text-xs uppercase tracking-[0.3em] text-white/70 mb-3">Spending plan</p>
        <h1 class="text-2xl sm:text-3xl font-semibold tracking-tight">Create a new budget</h1>
        <p class="mt-2 text-sm sm:text-base text-white/80 max-w-2xl">
          Set a monthly spending limit for a category and track how you measure up against it.
        </p>
      </div>
      <div class="flex items-center gap-3">
        <%= link_to budgets_path, class: "inline-flex items-center px-5 py-3 rounded-2xl text-sm font-semibold border border-white/30 text-white/90 hover:bg-white/5 transition" do %>
          <i class="fa-solid fa-arrow-left mr-2"></i>
          Back to budgets
        <% end %>
      </div>
    </div>
  </div>

  <!-- Form Card -->
  <div class="rounded-3xl shadow-2xl p-6 sm:p-8 max-w-2xl" style="background:#161b22; border:1px solid #30363d;">
    <%= form_with(model: @budget, url: budgets_path, method: :post, class: "space-y-6") do |f| %>
      <% if @budget.errors.any? %>
        <div class="rounded-2xl p-4" style="background:rgba(248,81,73,0.1); border:1px solid rgba(248,81,73,0.4);">
          <h2 class="font-semibold mb-2" style="color:#ff7b72;">
            <%= pluralize(@budget.errors.count, "error") %> prohibited this budget from being saved:
          </h2>
          <ul class="list-disc list-inside text-sm" style="color:#ffa198;">
            <% @budget.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :category_id, "Category", class: "block text-sm font-medium mb-2" %>
        <%= f.collection_select :category_id, @categories, :id, :name,
              { prompt: "Select a category" },
              { class: "w-full px-4 py-3 rounded-xl text-sm" } %>
        <p class="mt-1 text-xs" style="color:#8b949e;">Choose the spending category this budget applies to.</p>
      </div>

      <div>
        <%= f.label :monthly_limit, "Monthly Limit (ZMW)", class: "block text-sm font-medium mb-2" %>
        <div class="relative">
          <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
            <span class="font-semibold text-sm" style="color:#8b949e;">K</span>
          </div>
          <%= f.number_field :monthly_limit, step: 0.01, min: 0, placeholder: "e.g., 2500.00",
              class: "w-full pl-10 pr-4 py-3 rounded-xl text-sm" %>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <%= f.label :start_date, "Start Date", class: "block text-sm font-medium mb-2" %>
          <%= f.date_field :start_date, value: @budget.start_date || Date.current.beginning_of_month,
              class: "w-full px-4 py-3 rounded-xl text-sm" %>
        </div>
        <div>
          <%= f.label :end_date, "End Date", class: "block text-sm font-medium mb-2" %>
          <%= f.date_field :end_date, value: @budget.end_date || Date.current.end_of_month,
              class: "w-full px-4 py-3 rounded-xl text-sm" %>
        </div>
      </div>

      <div class="flex items-center">
        <%= f.check_box :inflation_adjusted, class: "h-4 w-4 rounded" %>
        <%= f.label :inflation_adjusted, "Auto-adjust for inflation", class: "ml-2 block text-sm" %>
        <p class="ml-6 text-xs" style="color:#8b949e;">Automatically increase this budget limit when inflation data is updated.</p>
      </div>

      <div class="flex items-center gap-4 pt-2">
        <%= f.submit "Create Budget", class: "inline-flex items-center px-6 py-3 rounded-xl text-sm font-semibold bg-brand-600 text-white shadow hover:bg-brand-500 transition cursor-pointer" %>
        <a href="<%= budgets_path %>" class="inline-flex items-center px-6 py-3 rounded-xl text-sm font-semibold transition" style="background:#21262d; color:#8b949e; border:1px solid #30363d;">Cancel</a>
      </div>
    <% end %>
  </div>

  <!-- Tip -->
  <div class="rounded-3xl p-6 max-w-2xl" style="background:#161b22; border:1px solid #30363d;">
    <div class="flex items-start gap-3">
      <i class="fa-solid fa-lightbulb text-amber-400 mt-0.5"></i>
      <div>
        <h3 class="font-semibold text-sm" style="color:#e6edf3;">Budgeting tip</h3>
        <p class="text-sm mt-1" style="color:#8b949e;">
          Allocate no more than 50% of your income to needs, 30% to wants, and 20% to savings and debt repayment.
          The JCTR Basic Needs Basket can help you benchmark essential spending.
        </p>
      </div>
    </div>
  </div>
</div>
