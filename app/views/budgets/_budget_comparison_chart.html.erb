<div class="bg-brand-900/80 border border-brand-700/40 backdrop-blur-2xl rounded-3xl shadow-2xl shadow-black/20 p-6">
  <div class="flex justify-between items-center mb-4">
    <h2 class="text-xl font-semibold text-brand-100">Budget vs Actual Spending</h2>
    <div class="flex space-x-2">
      <button id="view-as-chart" class="bg-brand-800 text-brand-300 px-3 py-1 rounded-xl hover:bg-brand-700 border border-brand-700/50">
        <i class="fa-solid fa-chart-bar mr-1"></i> Chart
      </button>
      <button id="view-as-table" class="bg-brand-800 text-brand-300 px-3 py-1 rounded-xl hover:bg-brand-700 border border-brand-700/50">
        <i class="fa-solid fa-table mr-1"></i> Table
      </button>
    </div>
  </div>

  <div id="budget-chart" class="mb-6">
    <!-- Chart will be rendered here -->
    <div class="h-64">
      <canvas id="budget-vs-actual-chart"></canvas>
    </div>
  </div>

  <script>
    // Make budget vs actual data available to the charts.js script
    const budgetVsActualData = {
      categories: <%= json_escape(@budget_categories.to_json) %>,
      budgetAmounts: <%= json_escape(@budget_amounts.to_json) %>,
      actualAmounts: <%= json_escape(@actual_amounts.to_json) %>
    };
  </script>

  <div id="budget-table" class="hidden">
    <% if @budget_categories.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-brand-700/30">
          <thead class="bg-brand-800/60">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-brand-300 uppercase tracking-wider">Category</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-brand-300 uppercase tracking-wider">Budget</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-brand-300 uppercase tracking-wider">Actual</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-brand-300 uppercase tracking-wider">Variance</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-brand-700/30">
            <% @budget_categories.each_with_index do |category, index| %>
              <tr class="hover:bg-brand-800/40">
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm font-medium text-brand-100"><%= category %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm font-medium text-brand-100">K<%= number_with_precision(@budget_amounts[index], precision: 2) %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm font-medium text-brand-100">K<%= number_with_precision(@actual_amounts[index], precision: 2) %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <% variance = @actual_amounts[index] - @budget_amounts[index] %>
                  <div class="text-sm font-medium <%= variance > 0 ? 'text-red-400' : 'text-emerald-400' %>">
                    <%= variance > 0 ? '+' : '' %>K<%= number_with_precision(variance, precision: 2) %>
                    (<%= number_with_precision((variance / @budget_amounts[index] * 100).abs, precision: 1) %>% <%= variance > 0 ? 'over' : 'under' %>)
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="text-brand-400 text-center py-4">No budget data available</p>
    <% end %>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const chartButton = document.getElementById('view-as-chart');
    const tableButton = document.getElementById('view-as-table');
    const chartDiv = document.getElementById('budget-chart');
    const tableDiv = document.getElementById('budget-table');
    
    if (chartButton && tableButton && chartDiv && tableDiv) {
      chartButton.addEventListener('click', function() {
        chartDiv.classList.remove('hidden');
        tableDiv.classList.add('hidden');
        chartButton.classList.remove('bg-brand-800', 'text-brand-300', 'border-brand-700/50');
        chartButton.classList.add('bg-brand-600', 'text-white', 'border-brand-500');
        tableButton.classList.remove('bg-brand-600', 'text-white', 'border-brand-500');
        tableButton.classList.add('bg-brand-800', 'text-brand-300', 'border-brand-700/50');
      });

      tableButton.addEventListener('click', function() {
        chartDiv.classList.add('hidden');
        tableDiv.classList.remove('hidden');
        chartButton.classList.remove('bg-brand-600', 'text-white', 'border-brand-500');
        chartButton.classList.add('bg-brand-800', 'text-brand-300', 'border-brand-700/50');
        tableButton.classList.remove('bg-brand-800', 'text-brand-300', 'border-brand-700/50');
        tableButton.classList.add('bg-brand-600', 'text-white', 'border-brand-500');
      });
    }
  });
</script>
