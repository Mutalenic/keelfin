<% content_for :page_title, "Annual Overview #{@year}" %>
<% content_for :skip_card_wrapper, true %>

<div class="space-y-6">
  <!-- Header -->
  <div class="rounded-3xl p-6 sm:p-8 text-white shadow-[0_25px_80px_rgba(2,44,34,0.45)] border border-brand-400/20"
       style="background: linear-gradient(135deg, #059669 0%, #047857 55%, #022c22 100%);">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div>
        <p class="text-xs uppercase tracking-[0.3em] text-white/70 mb-2">Overview</p>
        <h1 class="text-2xl sm:text-3xl font-semibold tracking-tight">Annual Budget — <%= @year %></h1>
        <p class="mt-1 text-sm text-white/70">Your full year at a glance: income, spending, and balance by month.</p>
      </div>
      <div class="flex items-center gap-2">
        <%= link_to annual_overview_path(year: @year - 1), class: "px-4 py-2 rounded-xl text-sm font-semibold bg-white/20 text-white border border-white/30 hover:bg-white/30 transition" do %>
          <i class="fa-solid fa-chevron-left mr-1"></i> <%= @year - 1 %>
        <% end %>
        <% if @year < Date.current.year + 1 %>
          <%= link_to annual_overview_path(year: @year + 1), class: "px-4 py-2 rounded-xl text-sm font-semibold bg-white/20 text-white border border-white/30 hover:bg-white/30 transition" do %>
            <%= @year + 1 %> <i class="fa-solid fa-chevron-right ml-1"></i>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Annual Totals Summary -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    <div class="rounded-2xl border border-brand-400/30 backdrop-blur-xl p-5 text-white shadow-lg"
         style="background: linear-gradient(150deg, rgba(5,150,105,0.9) 0%, rgba(4,120,87,0.85) 100%);">
      <p class="text-xs uppercase tracking-wide text-brand-100/70">Annual Income</p>
      <p class="text-2xl font-bold mt-2">K<%= number_with_precision(@annual_totals[:income], precision: 2, delimiter: ',') %></p>
    </div>
    <div class="rounded-2xl border border-brand-400/30 backdrop-blur-xl p-5 text-white shadow-lg"
         style="background: linear-gradient(150deg, rgba(239,68,68,0.7) 0%, rgba(185,28,28,0.7) 100%);">
      <p class="text-xs uppercase tracking-wide text-white/70">Annual Spending</p>
      <p class="text-2xl font-bold mt-2">K<%= number_with_precision(@annual_totals[:spending], precision: 2, delimiter: ',') %></p>
    </div>
    <div class="rounded-2xl border border-brand-400/30 backdrop-blur-xl p-5 text-white shadow-lg <%= @annual_totals[:balance] >= 0 ? '' : 'bg-red-900/60' %>"
         style="<%= @annual_totals[:balance] >= 0 ? 'background: linear-gradient(150deg, rgba(6,95,70,0.95) 0%, rgba(4,78,56,0.85) 100%);' : 'background: linear-gradient(150deg, rgba(127,29,29,0.9) 0%, rgba(153,27,27,0.85) 100%);' %>">
      <p class="text-xs uppercase tracking-wide text-white/70">Net Balance</p>
      <p class="text-2xl font-bold mt-2 <%= @annual_totals[:balance] < 0 ? 'text-red-300' : '' %>">
        K<%= number_with_precision(@annual_totals[:balance], precision: 2, delimiter: ',') %>
      </p>
    </div>
  </div>

  <!-- 12-Month Table -->
  <div class="bg-brand-900/80 border border-brand-700/40 backdrop-blur-2xl rounded-3xl shadow-2xl overflow-hidden">
    <div class="p-6 border-b border-brand-700/30">
      <h2 class="text-lg font-semibold text-brand-100">Month-by-Month Breakdown</h2>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full">
        <thead class="bg-brand-800/60">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-semibold text-brand-300 uppercase tracking-wider w-28">Month</th>
            <th class="px-4 py-3 text-right text-xs font-semibold text-brand-300 uppercase tracking-wider">Income</th>
            <th class="px-4 py-3 text-right text-xs font-semibold text-brand-300 uppercase tracking-wider">Spending</th>
            <th class="px-4 py-3 text-right text-xs font-semibold text-brand-300 uppercase tracking-wider">Balance</th>
            <th class="px-4 py-3 text-right text-xs font-semibold text-brand-300 uppercase tracking-wider">vs Budget</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-brand-700/20">
          <% @monthly_data.each_with_index do |data, idx| %>
            <% is_future = data[:month] > Date.current.end_of_month %>
            <% balance_color = data[:balance] >= 0 ? "text-emerald-400" : "text-red-400" %>
            <% if data[:is_current] %>
            <tr class="bg-brand-500/10 border-l-2 border-l-brand-400 transition-colors">
            <% elsif idx.odd? %>
            <tr class="bg-brand-800/20 hover:bg-brand-800/40 transition-colors">
            <% else %>
            <tr class="hover:bg-brand-800/30 transition-colors">
            <% end %>
              <td class="px-4 py-3 whitespace-nowrap">
                <div class="flex items-center gap-2">
                  <% if data[:is_current] %>
                    <span class="w-2 h-2 rounded-full bg-brand-400 flex-shrink-0"></span>
                  <% end %>
                  <div>
                    <p class="text-sm font-semibold text-brand-100"><%= data[:month].strftime('%B') %></p>
                    <p class="text-xs text-brand-500"><%= data[:month].strftime('%Y') %></p>
                  </div>
                </div>
              </td>
              <td class="px-4 py-3 text-right whitespace-nowrap">
                <p class="text-sm font-medium text-brand-100">K<%= number_with_precision(data[:income], precision: 2, delimiter: ',') %></p>
              </td>
              <td class="px-4 py-3 text-right whitespace-nowrap">
                <% if is_future %>
                  <p class="text-sm text-brand-500 italic">—</p>
                <% else %>
                  <p class="text-sm font-medium text-brand-100">K<%= number_with_precision(data[:spending], precision: 2, delimiter: ',') %></p>
                <% end %>
              </td>
              <td class="px-4 py-3 text-right whitespace-nowrap">
                <% if is_future %>
                  <p class="text-sm text-brand-500 italic">—</p>
                <% else %>
                  <p class="text-sm font-bold <%= balance_color %>">K<%= number_with_precision(data[:balance], precision: 2, delimiter: ',') %></p>
                <% end %>
              </td>
              <td class="px-4 py-3 text-right whitespace-nowrap">
                <% total_budget = data[:budget_limits].values.sum.to_f %>
                <% if total_budget > 0 && !is_future %>
                  <% diff = total_budget - data[:spending] %>
                  <% if diff >= 0 %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-lg text-xs font-medium bg-emerald-900/40 text-emerald-400">
                  <% else %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-lg text-xs font-medium bg-red-900/40 text-red-400">
                  <% end %>
                    <%= diff >= 0 ? '▼' : '▲' %> K<%= number_with_precision(diff.abs, precision: 0, delimiter: ',') %>
                  </span>
                <% else %>
                  <p class="text-xs text-brand-600">—</p>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
        <tfoot class="bg-brand-800/40 border-t-2 border-brand-600/40">
          <tr>
            <td class="px-4 py-3 text-sm font-bold text-brand-100">Total</td>
            <td class="px-4 py-3 text-right text-sm font-bold text-brand-100">K<%= number_with_precision(@annual_totals[:income], precision: 2, delimiter: ',') %></td>
            <td class="px-4 py-3 text-right text-sm font-bold text-brand-100">K<%= number_with_precision(@annual_totals[:spending], precision: 2, delimiter: ',') %></td>
            <td class="px-4 py-3 text-right text-sm font-bold <%= @annual_totals[:balance] >= 0 ? 'text-emerald-400' : 'text-red-400' %>">K<%= number_with_precision(@annual_totals[:balance], precision: 2, delimiter: ',') %></td>
            <td class="px-4 py-3"></td>
          </tr>
        </tfoot>
      </table>
    </div>
  </div>

  <!-- Link to income sources -->
  <div class="bg-brand-900/80 border border-brand-700/40 backdrop-blur-2xl rounded-3xl p-5 flex items-center justify-between">
    <div>
      <p class="text-sm font-medium text-brand-100">Income not accurate?</p>
      <p class="text-xs text-brand-400 mt-0.5">Manage your salary, side hustles, and other income streams.</p>
    </div>
    <%= link_to income_sources_path, class: "inline-flex items-center px-4 py-2 rounded-xl text-sm font-semibold bg-brand-600 text-white hover:bg-brand-500 transition flex-shrink-0" do %>
      <i class="fa-solid fa-money-bill-wave mr-2"></i> Manage Income
    <% end %>
  </div>
</div>
