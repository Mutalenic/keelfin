<% content_for(:page_title) { "Investment Transactions" } %>
<% content_for(:skip_card_wrapper, true) %>

<div class="space-y-8">
  <!-- Hero Banner -->
  <div class="rounded-3xl p-6 sm:p-8 text-white shadow-[0_25px_80px_rgba(15,23,42,0.45)] border border-white/10"
       style="background: linear-gradient(135deg, #06b6d4 0%, #0891b2 55%, #1e1b4b 100%);">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
      <div>
        <p class="text-xs uppercase tracking-[0.3em] text-white/70 mb-3"><%= @investment.investment_type_text %></p>
        <h1 class="text-2xl sm:text-3xl font-semibold tracking-tight"><%= @investment.name %></h1>
        <p class="mt-2 text-sm sm:text-base text-white/80 max-w-2xl">
          Transaction history for this investment.
        </p>
      </div>
      <div class="flex items-center gap-3">
        <%= link_to investment_path(@investment), class: "inline-flex items-center px-5 py-3 rounded-2xl text-sm font-semibold border border-white/30 text-white/90 hover:bg-white/5 transition" do %>
          <i class="fa-solid fa-arrow-left mr-2"></i>
          Back to Investment
        <% end %>
        <%= link_to new_investment_investment_transaction_path(@investment), class: "inline-flex items-center px-5 py-3 rounded-2xl text-sm font-semibold bg-white text-cyan-700 shadow-lg shadow-white/20" do %>
          <i class="fa-solid fa-plus mr-2"></i>
          New Transaction
        <% end %>
      </div>
    </div>
  </div>

  <!-- Transaction Summary -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
    <div class="rounded-2xl border border-white/15 backdrop-blur-xl p-5 text-white shadow-lg"
         style="background: linear-gradient(150deg, rgba(16,185,129,0.9) 0%, rgba(5,150,105,0.85) 100%);">
      <p class="text-xs uppercase tracking-wide text-white/60">Contributions</p>
      <p class="text-2xl font-semibold mt-3">K<%= number_with_precision(@total_contributions, precision: 2) %></p>
    </div>

    <div class="rounded-2xl border border-white/15 backdrop-blur-xl p-5 text-white shadow-lg"
         style="background: linear-gradient(150deg, rgba(239,68,68,0.9) 0%, rgba(220,38,38,0.85) 100%);">
      <p class="text-xs uppercase tracking-wide text-white/60">Withdrawals</p>
      <p class="text-2xl font-semibold mt-3">K<%= number_with_precision(@total_withdrawals, precision: 2) %></p>
    </div>

    <div class="rounded-2xl border border-white/15 backdrop-blur-xl p-5 text-white shadow-lg"
         style="background: linear-gradient(150deg, rgba(59,130,246,0.9) 0%, rgba(37,99,235,0.85) 100%);">
      <p class="text-xs uppercase tracking-wide text-white/60">Income</p>
      <p class="text-2xl font-semibold mt-3">K<%= number_with_precision(@total_income, precision: 2) %></p>
    </div>

    <div class="rounded-2xl border border-white/15 backdrop-blur-xl p-5 text-white shadow-lg"
         style="background: linear-gradient(150deg, rgba(251,191,36,0.9) 0%, rgba(245,158,11,0.85) 100%);">
      <p class="text-xs uppercase tracking-wide text-white/60">Fees</p>
      <p class="text-2xl font-semibold mt-3">K<%= number_with_precision(@total_fees, precision: 2) %></p>
    </div>
  </div>

  <!-- Filters -->
  <div class="bg-surface border border-white/30 backdrop-blur-2xl rounded-3xl shadow-2xl p-6">
    <h3 class="text-lg font-medium mb-4">Filter Transactions</h3>
    
    <%= form_with url: investment_investment_transactions_path(@investment), method: :get, class: "flex flex-wrap gap-4" do |f| %>
      <div class="flex-grow min-w-[200px]">
        <%= f.label :type, "Transaction Type", class: "block text-sm font-medium text-content mb-1" %>
        <%= f.select :type, 
          [
            ['All Types', ''],
            ['Contributions', 'contribution'],
            ['Withdrawals', 'withdrawal'],
            ['Dividends', 'dividend'],
            ['Interest', 'interest'],
            ['Fees', 'fee']
          ],
          { selected: params[:type] },
          { class: "mt-1 block w-full rounded-md border-default shadow-sm focus:border-blue-500 focus:ring-blue-500" }
        %>
      </div>
      
      <div class="flex-grow min-w-[200px]">
        <%= f.label :start_date, "From", class: "block text-sm font-medium text-content mb-1" %>
        <%= f.date_field :start_date, value: params[:start_date], class: "mt-1 block w-full rounded-md border-default shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>
      
      <div class="flex-grow min-w-[200px]">
        <%= f.label :end_date, "To", class: "block text-sm font-medium text-content mb-1" %>
        <%= f.date_field :end_date, value: params[:end_date], class: "mt-1 block w-full rounded-md border-default shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>
      
      <div class="flex items-end">
        <%= f.submit "Apply Filters", class: "inline-flex items-center px-4 py-2 rounded-xl text-sm font-semibold bg-cyan-600 text-white shadow hover:bg-cyan-500 transition" %>
        <% if params[:type].present? || params[:start_date].present? || params[:end_date].present? %>
          <%= link_to "Clear", investment_investment_transactions_path(@investment), class: "ml-2 text-subtle hover:text-content" %>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Transactions List -->
  <div class="bg-surface border border-white/30 backdrop-blur-2xl rounded-3xl shadow-2xl p-6">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
      <div>
        <h2 class="text-xl font-semibold text-content">Transactions</h2>
        <p class="text-sm text-subtle">All transaction history for this investment.</p>
      </div>
      <%= link_to new_investment_investment_transaction_path(@investment), class: "inline-flex items-center px-4 py-2 rounded-xl text-sm font-semibold bg-cyan-600 text-white shadow hover:bg-cyan-500 transition" do %>
        <i class="fa-solid fa-plus mr-2"></i>
        New Transaction
      <% end %>
    </div>
    
    <% if @transactions.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-default">
          <thead class="bg-content/5">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-subtle uppercase tracking-wider">Date</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-subtle uppercase tracking-wider">Type</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-subtle uppercase tracking-wider">Amount</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-subtle uppercase tracking-wider">Description</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-subtle uppercase tracking-wider">Reference</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-subtle uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="bg-surface divide-y divide-default">
            <% @transactions.each do |transaction| %>
              <tr class="hover:bg-content/5">
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm text-content"><%= transaction.transaction_date.strftime('%b %d, %Y') %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full 
                    <%= case transaction.transaction_type
                        when 'contribution' then 'bg-green-100 text-green-800'
                        when 'withdrawal' then 'bg-red-100 text-red-800'
                        when 'dividend', 'interest' then 'bg-blue-100 text-blue-800'
                        when 'fee' then 'bg-yellow-100 text-yellow-800'
                        end %>">
                    <%= transaction.transaction_type_text %>
                  </span>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm font-medium <%= ['withdrawal', 'fee'].include?(transaction.transaction_type) ? 'text-red-600' : 'text-green-600' %>">
                    <%= ['withdrawal', 'fee'].include?(transaction.transaction_type) ? '-' : '+' %>
                    K<%= number_with_precision(transaction.amount, precision: 2) %>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm text-content"><%= transaction.description.present? ? transaction.description : '-' %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm text-content"><%= transaction.reference_number.present? ? transaction.reference_number : '-' %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                  <div class="flex items-center justify-end gap-2 text-xs font-semibold">
                    <%= link_to "Edit", edit_investment_investment_transaction_path(@investment, transaction), class: "px-3 py-1.5 rounded-lg bg-cyan-50 text-cyan-700 hover:bg-cyan-100" %>
                    <%= button_to "Delete", investment_investment_transaction_path(@investment, transaction), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this transaction?" }, class: "px-3 py-1.5 rounded-lg bg-red-50 text-red-700 hover:bg-red-100 bg-transparent border-none cursor-pointer" %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="text-center py-12 bg-content/5 rounded-2xl border border-dashed border-default">
        <p class="text-subtle mb-4">No transactions found for this investment.</p>
        <%= link_to "Add Your First Transaction", new_investment_investment_transaction_path(@investment), class: "inline-flex items-center px-5 py-2.5 rounded-xl bg-cyan-600 text-white font-semibold shadow hover:bg-cyan-500" %>
      </div>
    <% end %>
  </div>
</div>
