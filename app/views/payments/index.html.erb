<% content_for(:page_title) { @category.name } %>
<% content_for(:skip_card_wrapper, true) %>

<div class="space-y-8">
  <!-- Hero Banner -->
  <div class="rounded-3xl p-6 sm:p-8 text-white shadow-[0_25px_80px_rgba(15,23,42,0.45)] border border-white/10"
       style="background: linear-gradient(135deg, <%= @category.color || '#059669' %> 0%, #022c22 100%);">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
      <div>
        <p class="text-xs uppercase tracking-[0.3em] text-white/70 mb-3">Transactions</p>
        <h1 class="text-2xl sm:text-3xl font-semibold tracking-tight"><%= @category.name %></h1>
        <p class="mt-2 text-sm sm:text-base text-white/80 max-w-2xl">
          All payments recorded under this category.
        </p>
      </div>
      <div class="flex items-center gap-3">
        <%= link_to new_category_payment_path(@category), class: "inline-flex items-center px-5 py-3 rounded-2xl text-sm font-semibold bg-white text-gray-800 shadow-lg shadow-white/20" do %>
          <i class="fa-solid fa-plus mr-2"></i>
          Add transaction
        <% end %>
        <%= link_to export_category_payments_path(@category), class: "inline-flex items-center px-5 py-3 rounded-2xl text-sm font-semibold border border-white/30 text-white/90 hover:bg-white/5 transition" do %>
          <i class="fa-solid fa-file-csv mr-2"></i>
          Export CSV
        <% end %>
        <%= link_to category_path(@category), class: "inline-flex items-center px-5 py-3 rounded-2xl text-sm font-semibold border border-white/30 text-white/90 hover:bg-white/5 transition" do %>
          <i class="fa-solid fa-arrow-left mr-2"></i>
          Back to category
        <% end %>
      </div>
    </div>
  </div>

  <!-- Summary Card -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div class="rounded-2xl border border-brand-400/30 backdrop-blur-xl p-5 text-white shadow-lg"
         style="background: linear-gradient(150deg, rgba(5,150,105,0.95) 0%, rgba(4,120,87,0.85) 100%);">
      <p class="text-xs uppercase tracking-wide text-brand-100/70">Total spent</p>
      <p class="text-3xl font-semibold mt-3">K<%= number_with_precision(@total_amount, precision: 2) %></p>
      <p class="text-xs text-brand-100/70 mt-1"><%= @payments.size %> transactions</p>
    </div>
  </div>

  <!-- Transactions Table -->
  <div class="bg-brand-900/80 border border-brand-700/40 backdrop-blur-2xl rounded-3xl shadow-2xl shadow-black/20 p-6 sm:p-8">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
      <div>
        <h2 class="text-xl font-semibold text-brand-100">Transactions</h2>
        <p class="text-sm text-brand-300">All payments for <%= @category.name %>.</p>
      </div>
      <%= link_to new_category_payment_path(@category), class: "inline-flex items-center px-4 py-2 rounded-xl text-sm font-semibold bg-brand-600 text-white shadow hover:bg-brand-500 transition" do %>
        <i class="fa-solid fa-plus mr-2"></i>
        Add transaction
      <% end %>
    </div>

    <% if @payments.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-brand-700/30 text-sm">
          <thead>
            <tr class="text-left text-brand-400 uppercase text-xs tracking-wider">
              <th class="px-6 py-3">Date</th>
              <th class="px-6 py-3">Description</th>
              <th class="px-6 py-3">Method</th>
              <th class="px-6 py-3">Amount</th>
              <th class="px-6 py-3 text-right">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-brand-700/30">
            <% @payments.each do |payment| %>
              <tr class="hover:bg-brand-800/40 transition">
                <td class="px-6 py-4 text-brand-400"><%= payment.created_at.strftime('%b %d, %Y') %></td>
                <td class="px-6 py-4">
                  <div class="font-semibold text-brand-100"><%= payment.name %></div>
                  <% if payment.is_essential %>
                    <span class="text-xs text-emerald-400">Essential</span>
                  <% end %>
                </td>
                <td class="px-6 py-4 text-brand-300"><%= payment.payment_method&.titleize || 'N/A' %></td>
                <td class="px-6 py-4 font-semibold text-brand-100">K<%= number_with_precision(payment.amount, precision: 2) %></td>
                <td class="px-6 py-4 text-right">
                  <div class="flex items-center justify-end gap-2 text-xs font-semibold">
                    <%= link_to "Edit", edit_category_payment_path(@category, payment), class: "px-3 py-1 rounded-lg bg-brand-800 text-brand-300 hover:bg-brand-700 border border-brand-700/50" %>
                    <%= button_to "Delete", category_payment_path(@category, payment), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this payment?" }, class: "px-3 py-1 rounded-lg bg-red-900/30 text-red-400 hover:bg-red-900/50 border-0" %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="text-center py-12 bg-brand-800/50 rounded-2xl border border-dashed border-brand-700/30">
        <p class="text-brand-300 mb-4">No transactions recorded yet.</p>
        <%= link_to "Add your first transaction", new_category_payment_path(@category), class: "inline-flex items-center px-5 py-2.5 rounded-xl bg-brand-600 text-white font-semibold shadow hover:bg-brand-500" %>
      </div>
    <% end %>
  </div>
</div>