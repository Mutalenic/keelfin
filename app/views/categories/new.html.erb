<% content_for(:page_title) { "New Category" } %>
<% content_for(:skip_card_wrapper, true) %>

<div class="space-y-8">
  <!-- Hero Banner -->
  <div class="rounded-3xl p-6 sm:p-8 text-white shadow-[0_25px_80px_rgba(2,44,34,0.45)] border border-brand-400/20"
       style="background: linear-gradient(130deg, #022c22 0%, #065f46 55%, #059669 100%);">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
      <div>
        <p class="text-xs uppercase tracking-[0.3em] text-white/70 mb-3">Money map</p>
        <h1 class="text-2xl sm:text-3xl font-semibold tracking-tight">Add new category</h1>
        <p class="mt-2 text-sm sm:text-base text-white/80 max-w-2xl">
          Create custom categories or choose from presets to organize your spending.
        </p>
      </div>
      <div class="flex items-center gap-3">
        <%= link_to categories_path, class: "inline-flex items-center px-5 py-3 rounded-2xl text-sm font-semibold border border-white/30 text-white/90 hover:bg-white/5 transition" do %>
          <i class="fa-solid fa-arrow-left mr-2"></i>
          Back to categories
        <% end %>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Custom Category Form -->
    <div class="bg-surface border border-default backdrop-blur-2xl rounded-3xl shadow-2xl shadow-black/20 p-6 sm:p-8">
      <h2 class="text-xl font-bold mb-6 text-content">Create Custom Category</h2>

      <%= form_with(model: @category, url: categories_path, method: :post, class: "space-y-5") do |form| %>
        <% if @category.errors.any? %>
          <div class="bg-red-900/30 border border-red-700/40 rounded-2xl p-4 mb-4">
            <h2 class="text-red-300 font-semibold mb-2"><%= pluralize(@category.errors.count, "error") %> prohibited this from being saved:</h2>
            <ul class="text-red-300 list-disc list-inside text-sm">
              <% @category.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div>
          <%= form.label :name, class: "block text-sm font-medium text-subtle mb-2" %>
          <%= form.text_field :name, class: "w-full px-4 py-3 bg-content/5 border border-default rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-brand-500 text-sm text-content placeholder-brand-500/50", placeholder: 'Enter category name' %>
        </div>

        <div>
          <%= form.label :description, class: "block text-sm font-medium text-subtle mb-2" %>
          <%= form.text_area :description, class: "w-full px-4 py-3 bg-content/5 border border-default rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-brand-500 text-sm text-content placeholder-brand-500/50", placeholder: 'Enter category description', rows: 3 %>
        </div>

        <div>
          <%= form.label :icon_name, class: "block text-sm font-medium text-subtle mb-2" %>
          <%= form.select :icon_name,
            [
              ['Apple', 'fa-solid fa-apple-whole'],
              ['Home', 'fa-solid fa-home'],
              ['Car', 'fa-solid fa-car'],
              ['Shopping', 'fa-solid fa-shopping-cart'],
              ['Food', 'fa-solid fa-utensils'],
              ['Health', 'fa-solid fa-hospital'],
              ['Education', 'fa-solid fa-graduation-cap'],
              ['Entertainment', 'fa-solid fa-film'],
              ['Bills', 'fa-solid fa-file-invoice-dollar'],
              ['Savings', 'fa-solid fa-piggy-bank']
            ],
            { include_blank: 'Select an icon' },
            { class: "w-full px-4 py-3 bg-content/5 border border-default rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-brand-500 text-sm text-content" }
          %>
        </div>

        <div>
          <%= form.label :color, class: "block text-sm font-medium text-subtle mb-2" %>
          <%= form.color_field :color, class: "w-full h-12 p-1 bg-content/5 border border-default rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-brand-500" %>
        </div>

        <div>
          <%= form.label :category_type, class: "block text-sm font-medium text-subtle mb-2" %>
          <%= form.select :category_type,
            @category_types.map { |type| [type.capitalize, type] },
            { include_blank: 'Select a type' },
            { class: "w-full px-4 py-3 bg-content/5 border border-default rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-brand-500 text-sm text-content" }
          %>
        </div>

        <div class="pt-2">
          <%= form.submit 'Create Category', class: "w-full inline-flex justify-center items-center px-6 py-3 rounded-xl text-sm font-semibold bg-brand-600 text-white shadow hover:bg-brand-500 transition cursor-pointer" %>
        </div>
      <% end %>
    </div>

    <!-- Preset Categories -->
    <div class="bg-surface border border-default backdrop-blur-2xl rounded-3xl shadow-2xl shadow-black/20 p-6 sm:p-8">
      <h2 class="text-xl font-bold mb-2 text-content">Quick Add Presets</h2>
      <p class="text-subtle mb-6">Choose from predefined categories to get started quickly.</p>

      <div class="space-y-3">
        <% @preset_categories.each do |preset| %>
          <div class="flex items-center justify-between p-4 rounded-2xl border border-default hover:shadow-md transition bg-content/5" style="border-left: 4px solid <%= preset[:color] %>">
            <div class="flex items-center">
              <div class="w-10 h-10 rounded-xl flex items-center justify-center text-white mr-3" style="background-color: <%= preset[:color] %>">
                <i class="<%= preset[:icon_name] %>"></i>
              </div>
              <div>
                <h3 class="font-semibold text-content"><%= preset[:name] %></h3>
                <p class="text-xs text-accent"><%= preset[:category_type].capitalize %></p>
              </div>
            </div>
            <%= button_to 'Add', add_preset_categories_path(preset_name: preset[:name]), class: "px-3 py-1.5 rounded-lg text-sm font-semibold bg-content/5 hover:bg-content/10 text-subtle transition border border-default" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
