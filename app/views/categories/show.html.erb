<% content_for(:page_title) { @category.name } %>
<% content_for(:skip_card_wrapper, true) %>

<div class="space-y-8">
  <!-- Hero Banner -->
  <div class="rounded-3xl p-6 sm:p-8 text-white shadow-[0_25px_80px_rgba(15,23,42,0.45)] border border-white/10"
       style="background: linear-gradient(135deg, <%= @category.color || '#4f46e5' %> 0%, #0f172a 100%);">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
      <div class="flex items-center gap-4">
        <div class="w-14 h-14 rounded-2xl flex items-center justify-center text-white shadow-lg" style="background-color: <%= @category.color || '#4f46e5' %>;">
          <i class="<%= @category.icon_name.presence || 'fa-solid fa-tag' %> text-2xl"></i>
        </div>
        <div>
          <p class="text-xs uppercase tracking-[0.3em] text-white/70 mb-1"><%= @category.category_type&.capitalize || "Category" %></p>
          <h1 class="text-2xl sm:text-3xl font-semibold tracking-tight"><%= @category.name %></h1>
          <p class="mt-1 text-sm text-white/80 max-w-xl"><%= @category.description.presence || "No description available" %></p>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <%= link_to new_category_payment_path(@category), class: "inline-flex items-center px-5 py-3 rounded-2xl text-sm font-semibold bg-surface text-content border border-default shadow-lg" do %>
          <i class="fa-solid fa-plus mr-2"></i>
          Add payment
        <% end %>
        <%= link_to categories_path, class: "inline-flex items-center px-5 py-3 rounded-2xl text-sm font-semibold border border-white/30 text-white/90 hover:bg-white/5 transition" do %>
          <i class="fa-solid fa-arrow-left mr-2"></i>
          Back
        <% end %>
      </div>
    </div>
  </div>

  <!-- Statistics Cards -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div class="rounded-2xl border border-white/15 backdrop-blur-xl p-5 text-white shadow-lg"
         style="background: linear-gradient(150deg, rgba(99,102,241,0.9) 0%, rgba(59,130,246,0.85) 100%);">
      <p class="text-xs uppercase tracking-wide text-white/60">Total Spending</p>
      <p class="text-3xl font-semibold mt-3">K<%= number_with_precision(@total_amount, precision: 2) %></p>
      <p class="text-xs text-white/60 mt-1">lifetime spend</p>
    </div>

    <div class="rounded-2xl border border-white/15 backdrop-blur-xl p-5 text-white shadow-lg"
         style="background: linear-gradient(150deg, rgba(16,185,129,0.95) 0%, rgba(5,150,105,0.85) 100%);">
      <p class="text-xs uppercase tracking-wide text-white/60">Monthly Average</p>
      <p class="text-3xl font-semibold mt-3">K<%= number_with_precision(@monthly_average, precision: 2) %></p>
      <p class="text-xs text-white/60 mt-1">smoothed over time</p>
    </div>

    <div class="rounded-2xl border border-white/15 backdrop-blur-xl p-5 text-white shadow-lg"
         style="background: linear-gradient(150deg, rgba(251,191,36,0.95) 0%, rgba(249,115,22,0.9) 100%);">
      <p class="text-xs uppercase tracking-wide text-white/60">% of Total Spend</p>
      <p class="text-3xl font-semibold mt-3"><%= number_with_precision(@percentage_of_total, precision: 1) %>%</p>
      <p class="text-xs text-white/60 mt-1">across all categories</p>
    </div>
  </div>

  <!-- Recent Transactions -->
  <div class="bg-surface border border-default backdrop-blur-2xl rounded-3xl shadow-2xl shadow-black/20 p-6 sm:p-8">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
      <div>
        <h2 class="text-xl font-semibold text-content">Recent Transactions</h2>
        <p class="text-sm text-accent">Latest payments in this category.</p>
      </div>
      <%= link_to category_payments_path(@category), class: "inline-flex items-center px-4 py-2 rounded-xl text-sm font-semibold bg-brand-600 text-white shadow hover:bg-brand-500 transition" do %>
        <i class="fa-solid fa-list mr-2"></i>
        View all
      <% end %>
    </div>

    <% if @payments.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-default text-sm">
          <thead>
            <tr class="text-left text-accent uppercase text-xs tracking-wider">
              <th class="px-6 py-3">Date</th>
              <th class="px-6 py-3">Description</th>
              <th class="px-6 py-3">Method</th>
              <th class="px-6 py-3 text-right">Amount</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-default">
            <% @payments.each do |payment| %>
              <tr class="hover:bg-content/10 transition">
                <td class="px-6 py-4 text-accent"><%= payment.created_at.strftime('%b %d, %Y') %></td>
                <td class="px-6 py-4">
                  <div class="font-semibold text-content"><%= payment.name %></div>
                  <% if payment.is_essential %>
                    <span class="text-xs text-emerald-400">Essential</span>
                  <% end %>
                </td>
                <td class="px-6 py-4 text-subtle"><%= payment.payment_method&.titleize || 'N/A' %></td>
                <td class="px-6 py-4 text-right font-semibold text-content">K<%= number_with_precision(payment.amount, precision: 2) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="text-center py-12 bg-content/5 rounded-2xl border border-dashed border-default">
        <p class="text-subtle mb-4">No transactions found for this category.</p>
        <%= link_to new_category_payment_path(@category), class: "inline-flex items-center px-5 py-2.5 rounded-xl bg-brand-600 text-white font-semibold shadow hover:bg-brand-500" do %>
          <i class="fa-solid fa-plus mr-2"></i>
          Add first payment
        <% end %>
      </div>
    <% end %>
  </div>

  <% if @category.bnnb_mapping.present? && @bnnb_data.present? %>
    <div class="bg-surface border border-default backdrop-blur-2xl rounded-3xl shadow-2xl p-6">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-9 h-9 rounded-xl bg-cyan-800/40 flex items-center justify-center flex-shrink-0">
          <i class="fa-solid fa-chart-bar text-cyan-400 text-sm"></i>
        </div>
        <div>
          <h2 class="text-base font-semibold text-content">JCTR Benchmark Comparison</h2>
          <p class="text-xs text-accent">Your "<%= @category.name %>" spend vs JCTR BNNB national basket</p>
        </div>
      </div>
      <div class="grid grid-cols-3 gap-4 text-center">
        <div class="bg-content/5 rounded-2xl p-4">
          <p class="text-xs text-accent uppercase tracking-wide mb-1">Your Monthly Avg</p>
          <p class="text-xl font-bold text-content">K<%= number_with_precision(@monthly_average, precision: 2, delimiter: ',') %></p>
        </div>
        <div class="bg-content/5 rounded-2xl p-4">
          <p class="text-xs text-accent uppercase tracking-wide mb-1">JCTR Benchmark</p>
          <p class="text-xl font-bold text-cyan-300">K<%= number_with_precision(@bnnb_benchmark, precision: 2, delimiter: ',') %></p>
        </div>
        <div class="bg-content/5 rounded-2xl p-4">
          <p class="text-xs text-accent uppercase tracking-wide mb-1">Difference</p>
          <% diff = @monthly_average - @bnnb_benchmark %>
          <p class="text-xl font-bold <%= diff > 0 ? 'text-red-400' : 'text-emerald-400' %>">
            <%= diff >= 0 ? '+' : '' %>K<%= number_with_precision(diff.abs, precision: 2, delimiter: ',') %>
          </p>
          <p class="text-xs <%= diff > 0 ? 'text-red-400' : 'text-emerald-400' %> mt-1">
            <%= diff > 0 ? 'Above benchmark' : diff < 0 ? 'Below benchmark' : 'On target' %>
          </p>
        </div>
      </div>
      <p class="text-xs text-faint mt-4">Source: JCTR BNNB <%= @bnnb_data.month.strftime('%B %Y') %>, <%= @bnnb_data.location %></p>
    </div>
  <% end %>

  <!-- Action Buttons -->
  <div class="flex flex-wrap items-center gap-4">
    <%= link_to export_category_payments_path(@category), class: "inline-flex items-center px-5 py-2.5 rounded-xl text-sm font-semibold bg-content/5 text-subtle border border-default hover:bg-content/10 transition" do %>
      <i class="fa-solid fa-file-csv mr-2"></i>
      Export CSV
    <% end %>
    <%= link_to edit_category_path(@category), class: "inline-flex items-center px-5 py-2.5 rounded-xl text-sm font-semibold bg-content/5 text-subtle border border-default hover:bg-content/10 transition" do %>
      <i class="fa-solid fa-pencil mr-2"></i>
      Edit category
    <% end %>
    <%= button_to category_path(@category), method: :delete, data: { turbo_confirm: "Are you sure? This will delete all payments in this category." }, class: "inline-flex items-center px-5 py-2.5 rounded-xl text-sm font-semibold bg-red-900/30 text-red-400 border border-red-700/30 hover:bg-red-800/30 transition" do %>
      <i class="fa-solid fa-trash mr-2"></i>
      Delete
    <% end %>
  </div>
</div>
