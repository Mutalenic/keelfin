<% content_for(:page_title) { "Categories" } %>
<% content_for(:skip_card_wrapper, true) %>

<% total_categories = @categories&.size.to_i %>
<% total_spend = (@category_spending&.values || []).compact.sum %>
<% top_category = @categories.max_by { |category| (@category_spending[category.id] || 0) } if @categories.present? %>

<div class="space-y-8">
  <!-- Hero Banner -->
  <div class="rounded-3xl p-6 sm:p-8 text-white shadow-[0_25px_80px_rgba(2,44,34,0.45)] border border-brand-400/20"
       style="background: linear-gradient(130deg, #022c22 0%, #065f46 55%, #059669 100%);">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
      <div>
        <p class="text-xs uppercase tracking-[0.3em] text-white/70 mb-3">Money map</p>
        <h1 class="text-2xl sm:text-3xl font-semibold tracking-tight">Spending categories</h1>
        <p class="mt-2 text-sm sm:text-base text-white/80 max-w-2xl">
          Create categories that fit your lifestyle so every transaction has a home.
        </p>
      </div>
      <div class="flex items-center gap-3">
        <a href="<%= new_category_path %>" class="inline-flex items-center px-5 py-3 rounded-2xl text-sm font-semibold bg-white text-brand-700 shadow-lg shadow-white/20">
          <i class="fa-solid fa-plus mr-2"></i>
          Add category
        </a>
        <a href="<%= new_category_payment_path(Category.first || :back) %>" class="inline-flex items-center px-5 py-3 rounded-2xl text-sm font-semibold border border-white/30 text-white/90 hover:bg-white/5 transition">
          <i class="fa-solid fa-receipt mr-2"></i>
          Quick payment
        </a>
      </div>
    </div>
  </div>

  <!-- Summary cards -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div class="rounded-2xl border border-brand-400/30 backdrop-blur-xl p-5 text-white shadow-lg"
         style="background: linear-gradient(150deg, rgba(5,150,105,0.9) 0%, rgba(4,120,87,0.85) 100%);">
      <p class="text-xs uppercase tracking-wide text-white/70">Categories</p>
      <p class="text-3xl font-semibold mt-3"><%= total_categories %></p>
      <p class="text-xs text-white/70 mt-1">active across budgets</p>
    </div>
    <div class="rounded-2xl border border-brand-400/30 backdrop-blur-xl p-5 text-white shadow-lg"
         style="background: linear-gradient(150deg, rgba(16,185,129,0.95) 0%, rgba(5,150,105,0.85) 100%);">
      <p class="text-xs uppercase tracking-wide text-white/70">YTD spend</p>
      <p class="text-3xl font-semibold mt-3">K<%= number_with_precision(total_spend, precision: 2) %></p>
      <p class="text-xs text-white/70 mt-1">captured in Keelfin</p>
    </div>
    <div class="rounded-2xl border border-brand-400/30 backdrop-blur-xl p-5 text-white shadow-lg"
         style="background: linear-gradient(150deg, rgba(6,95,70,0.95) 0%, rgba(4,78,56,0.85) 100%);">
      <p class="text-xs uppercase tracking-wide text-white/70">Top category</p>
      <p class="text-3xl font-semibold mt-3"><%= top_category&.name || 'N/A' %></p>
      <p class="text-xs text-white/70 mt-1">highest spend driver</p>
    </div>
  </div>

  <!-- Category type chips -->
  <div class="bg-surface border border-default backdrop-blur-2xl rounded-3xl shadow-xl p-4">
    <div class="flex flex-wrap gap-3">
      <% chip_index = 0 %>
      <% %w[All Groceries Fixed Variable Discretionary Essentials Luxury].each do |label| %>
        <% if chip_index == 0 %>
        <button class="px-4 py-2 rounded-2xl text-sm font-semibold bg-brand-600 text-white"><%= label %></button>
        <% else %>
        <button class="px-4 py-2 rounded-2xl text-sm font-semibold bg-content/5 text-subtle hover:bg-content/10"><%= label %></button>
        <% end %>
        <% chip_index += 1 %>
      <% end %>
    </div>
  </div>

  <!-- Categories grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% @categories.each do |category| %>
      <% color = category.color.presence || '#6366f1' %>
      <div class="rounded-3xl border border-default backdrop-blur-2xl bg-surface shadow-xl hover:shadow-2xl transition" style="--accent-color:<%= color %>;">
        <div class="p-6">
          <div class="flex items-center mb-4">
            <div class="w-12 h-12 rounded-2xl flex items-center justify-center text-white mr-4" style="background-color: <%= color %>;">
              <i class="<%= category.icon_name.presence || 'fa-solid fa-tag' %> text-xl"></i>
            </div>
            <div>
              <h3 class="text-xl font-bold text-content"><%= category.name %></h3>
              <span class="text-xs font-semibold inline-block py-1 px-2 rounded-full text-subtle bg-content/5 border border-default">
                <%= category.category_type&.capitalize || 'Uncategorized' %>
              </span>
            </div>
          </div>

          <% if category.description.present? %>
            <p class="text-subtle text-sm mb-4 line-clamp-2"><%= category.description %></p>
          <% end %>

          <div class="flex justify-between items-center mb-4">
            <div>
              <p class="text-faint text-sm">Total spend</p>
              <p class="text-xl font-bold text-content">K<%= number_with_precision(@category_spending[category.id] || 0, precision: 2) %></p>
            </div>
            <div class="text-right">
              <p class="text-faint text-sm">Transactions</p>
              <p class="text-xl font-bold text-content"><%= @category_counts[category.id] || 0 %></p>
            </div>
          </div>

          <div class="flex justify-between mt-4 text-sm font-semibold">
            <%= link_to "View details", category_path(category), class: "text-accent hover:text-accent-hover" %>
            <%= link_to "Add payment", new_category_payment_path(category), class: "text-accent hover:text-accent-hover" %>
          </div>
        </div>

        <div class="px-6 py-3 border-t border-default flex items-center justify-between text-xs text-faint">
          <div class="flex space-x-2">
            <a href="<%= edit_category_path(category) %>" class="p-2 rounded-lg bg-content/5 hover:bg-content/10 text-subtle">
              <i class="fa-solid fa-pencil"></i>
            </a>
            <form action="<%= category_path(category) %>" method="post" data-turbo-confirm="Delete this category?" style="display:inline">
              <%= hidden_field_tag :_method, :delete %>
              <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
              <button type="submit" class="p-2 rounded-lg bg-danger/10 text-danger hover:bg-danger/20 border-0">
                <i class="fa-solid fa-trash"></i>
              </button>
            </form>
          </div>
          <span>Created <%= time_ago_in_words(category.created_at) %> ago</span>
        </div>
      </div>
    <% end %>
  </div>

  <% if @categories.empty? %>
    <div class="bg-surface border border-default backdrop-blur-2xl rounded-3xl shadow-xl p-12 text-center">
      <div class="text-faint mb-4">
        <i class="fa-solid fa-folder-open text-5xl"></i>
      </div>
      <h3 class="text-xl font-bold text-content mb-2">No categories yet</h3>
      <p class="text-subtle mb-6">Create categories to organise your spending and track your budgets.</p>
      <%= link_to "Create your first category", new_category_path, class: "inline-flex items-center px-5 py-2.5 rounded-xl bg-brand-600 text-white font-semibold shadow hover:bg-brand-500" %>
    </div>
  <% end %>
</div>
