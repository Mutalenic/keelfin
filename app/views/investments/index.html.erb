<% content_for(:page_title) { "Investment Portfolio" } %>
<% content_for(:skip_card_wrapper, true) %>

<div class="space-y-8">
  <!-- Hero Banner -->
  <div class="rounded-3xl p-6 sm:p-8 text-white shadow-[0_25px_80px_rgba(15,23,42,0.45)] border border-white/10"
       style="background: linear-gradient(135deg, #06b6d4 0%, #0891b2 55%, #1e1b4b 100%);">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
      <div>
        <p class="text-xs uppercase tracking-[0.3em] text-white/70 mb-3">Investments</p>
        <h1 class="text-2xl sm:text-3xl font-semibold tracking-tight">Portfolio</h1>
        <p class="mt-2 text-sm sm:text-base text-white/80 max-w-2xl">
          Track your investments and monitor your returns.
        </p>
      </div>
      <div class="flex items-center gap-3">
        <%= link_to new_investment_path, class: "inline-flex items-center px-5 py-3 rounded-2xl text-sm font-semibold bg-white text-cyan-700 shadow-lg shadow-white/20" do %>
          <i class="fa-solid fa-plus mr-2"></i>
          New Investment
        <% end %>
      </div>
    </div>
  </div>

  <!-- Portfolio Summary -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
    <div class="rounded-2xl border border-white/15 backdrop-blur-xl p-5 text-white shadow-lg"
         style="background: linear-gradient(150deg, rgba(6,182,212,0.9) 0%, rgba(8,145,178,0.85) 100%);">
      <p class="text-xs uppercase tracking-wide text-white/60">Portfolio Value</p>
      <p class="text-2xl font-semibold mt-3">K<%= number_with_precision(@total_invested, precision: 2) %></p>
    </div>
      <h3 class="text-sm text-gray-600 mb-2">Total Portfolio Value</h3>
      <p class="text-3xl font-bold">K<%= number_with_precision(@total_invested, precision: 2) %></p>
    </div>
    
    <div class="rounded-2xl border border-white/15 backdrop-blur-xl p-5 text-white shadow-lg"
         style="background: linear-gradient(150deg, rgba(16,185,129,0.95) 0%, rgba(5,150,105,0.85) 100%);">
      <p class="text-xs uppercase tracking-wide text-white/60">Total Return</p>
      <p class="text-2xl font-semibold mt-3 <%= @total_return >= 0 ? 'text-white' : 'text-red-200' %>">
        <%= @total_return >= 0 ? '+' : '' %>K<%= number_with_precision(@total_return, precision: 2) %>
      </p>
    </div>

    <div class="rounded-2xl border border-white/15 backdrop-blur-xl p-5 text-white shadow-lg"
         style="background: linear-gradient(150deg, rgba(139,92,246,0.95) 0%, rgba(124,58,237,0.85) 100%);">
      <p class="text-xs uppercase tracking-wide text-white/60">Return %</p>
      <p class="text-2xl font-semibold mt-3 <%= @return_percentage >= 0 ? 'text-white' : 'text-red-200' %>">
        <%= @return_percentage >= 0 ? '+' : '' %><%= number_with_precision(@return_percentage, precision: 2) %>%
      </p>
    </div>

    <div class="rounded-2xl border border-white/15 backdrop-blur-xl p-5 text-white shadow-lg"
         style="background: linear-gradient(150deg, rgba(251,191,36,0.95) 0%, rgba(245,158,11,0.85) 100%);">
      <p class="text-xs uppercase tracking-wide text-white/60">Active</p>
      <p class="text-2xl font-semibold mt-3"><%= @investments.active.count %></p>
    </div>
  </div>

  <!-- Portfolio Allocation -->
  <div class="bg-white/95 border border-white/30 backdrop-blur-2xl rounded-3xl shadow-2xl p-6">
    <div class="flex justify-between items-center mb-6">
      <h2 class="text-xl font-semibold">Portfolio Allocation</h2>
      <div class="flex space-x-2">
        <button id="view-as-chart" class="bg-cyan-100 text-cyan-700 px-3 py-1 rounded-xl hover:bg-cyan-200">
          <i class="fa-solid fa-chart-pie mr-1"></i> Chart
        </button>
        <button id="view-as-table" class="bg-gray-100 text-gray-700 px-3 py-1 rounded-lg hover:bg-gray-200">
          <i class="fa-solid fa-table mr-1"></i> Table
        </button>
      </div>
    </div>
    
    <div id="allocation-chart" class="mb-6">
      <!-- Chart will be rendered here -->
      <div class="h-64">
        <canvas id="portfolio-allocation-chart"></canvas>
      </div>
    </div>
    
    <script>
      // Make portfolio allocation data available to the charts.js script
      const portfolioAllocationData = <%= json_escape(@portfolio_allocation.to_json) %>;
    </script>
    
    <div id="allocation-table" class="hidden">
      <% if @portfolio_allocation.any? %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Investment Type</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Value</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Allocation</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% @portfolio_allocation.each do |type, data| %>
                <tr>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="text-sm font-medium text-gray-900"><%= Investment.new(investment_type: type).investment_type_text %></div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="text-sm font-medium">K<%= number_with_precision(data[:total], precision: 2) %></div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="flex items-center">
                      <div class="w-full bg-gray-200 rounded-full h-2.5 mr-2 w-24">
                        <div class="bg-blue-600 h-2.5 rounded-full" style="width: <%= data[:percentage] %>%"></div>
                      </div>
                      <span class="text-sm font-medium"><%= number_with_precision(data[:percentage], precision: 1) %>%</span>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="text-gray-500 text-center py-4">No investment data available</p>
      <% end %>
    </div>
  </div>

  <!-- Investments List -->
  <div class="bg-white/95 border border-white/30 backdrop-blur-2xl rounded-3xl shadow-2xl p-6">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
      <div>
        <h2 class="text-xl font-semibold text-gray-900">Your Investments</h2>
        <p class="text-sm text-gray-500">All your active and inactive investments.</p>
      </div>
      <%= link_to new_investment_path, class: "inline-flex items-center px-4 py-2 rounded-xl text-sm font-semibold bg-cyan-600 text-white shadow hover:bg-cyan-500 transition" do %>
        <i class="fa-solid fa-plus mr-2"></i>
        New Investment
      <% end %>
    </div>
    
    <% if @investments.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Type</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Current Value</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Return</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Risk Level</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @investments.each do |investment| %>
              <tr class="hover:bg-gray-50 <%= investment.active? ? '' : 'bg-gray-100' %>">
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm font-medium text-gray-900"><%= link_to investment.name, investment_path(investment) %></div>
                  <div class="text-xs text-gray-500">
                    <% if investment.institution.present? %>
                      <%= investment.institution %>
                    <% end %>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm text-gray-900"><%= investment.investment_type_text %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm font-medium">K<%= number_with_precision(investment.current_value, precision: 2) %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <% return_value = investment.total_return %>
                  <% return_percentage = investment.return_percentage %>
                  <div class="text-sm font-medium <%= return_value >= 0 ? 'text-green-600' : 'text-red-600' %>">
                    <%= return_value >= 0 ? '+' : '' %>K<%= number_with_precision(return_value, precision: 2) %>
                  </div>
                  <div class="text-xs <%= return_percentage >= 0 ? 'text-green-600' : 'text-red-600' %>">
                    <%= return_percentage >= 0 ? '+' : '' %><%= number_with_precision(return_percentage, precision: 2) %>%
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <% if investment.risk_level %>
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full 
                      <%= case investment.risk_level
                          when 1 then 'bg-green-100 text-green-800'
                          when 2 then 'bg-blue-100 text-blue-800'
                          when 3 then 'bg-yellow-100 text-yellow-800'
                          when 4 then 'bg-orange-100 text-orange-800'
                          when 5 then 'bg-red-100 text-red-800'
                          end %>">
                      <%= investment.risk_level_text %>
                    </span>
                  <% else %>
                    <span class="text-gray-500">-</span>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                  <div class="flex items-center justify-end gap-2 text-xs font-semibold">
                  <%= link_to "View", investment_path(investment), class: "px-3 py-1.5 rounded-lg bg-cyan-50 text-cyan-700 hover:bg-cyan-100" %>
                  <%= link_to "Edit", edit_investment_path(investment), class: "px-3 py-1.5 rounded-lg bg-gray-100 text-gray-700 hover:bg-gray-200" %>
                  <%= link_to "Transactions", investment_investment_transactions_path(investment), class: "px-3 py-1.5 rounded-lg bg-emerald-50 text-emerald-700 hover:bg-emerald-100" %>
                </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="text-center py-12 bg-gray-50/80 rounded-2xl border border-dashed border-gray-200">
        <p class="text-gray-600 mb-4">You don't have any investments yet.</p>
        <%= link_to "Add Your First Investment", new_investment_path, class: "inline-flex items-center px-5 py-2.5 rounded-xl bg-cyan-600 text-white font-semibold shadow hover:bg-cyan-500" %>
      </div>
    <% end %>
  </div>
  
  <!-- Investment Tips -->
  <div class="rounded-3xl border border-white/15 backdrop-blur-xl p-6 text-white"
       style="background: linear-gradient(135deg, rgba(6,182,212,0.9) 0%, rgba(99,102,241,0.85) 100%);">
    <h2 class="text-lg font-semibold mb-4">Investment Tips</h2>
    
    <div class="space-y-4">
      <div class="flex items-start">
        <div class="mr-3 text-blue-500">
          <i class="fa-solid fa-lightbulb"></i>
        </div>
        <p class="text-sm">Diversify your portfolio across different asset classes to reduce risk.</p>
      </div>
      
      <div class="flex items-start">
        <div class="mr-3 text-blue-500">
          <i class="fa-solid fa-lightbulb"></i>
        </div>
        <p class="text-sm">Consider your time horizon and risk tolerance when choosing investments.</p>
      </div>
      
      <div class="flex items-start">
        <div class="mr-3 text-blue-500">
          <i class="fa-solid fa-lightbulb"></i>
        </div>
        <p class="text-sm">Regularly review and rebalance your portfolio to maintain your target asset allocation.</p>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const chartButton = document.getElementById('view-as-chart');
    const tableButton = document.getElementById('view-as-table');
    const chartDiv = document.getElementById('allocation-chart');
    const tableDiv = document.getElementById('allocation-table');
    
    chartButton.addEventListener('click', function() {
      chartDiv.classList.remove('hidden');
      tableDiv.classList.add('hidden');
      chartButton.classList.remove('bg-gray-100', 'text-gray-700');
      chartButton.classList.add('bg-blue-100', 'text-blue-700');
      tableButton.classList.remove('bg-blue-100', 'text-blue-700');
      tableButton.classList.add('bg-gray-100', 'text-gray-700');
    });
    
    tableButton.addEventListener('click', function() {
      chartDiv.classList.add('hidden');
      tableDiv.classList.remove('hidden');
      chartButton.classList.remove('bg-blue-100', 'text-blue-700');
      chartButton.classList.add('bg-gray-100', 'text-gray-700');
      tableButton.classList.remove('bg-gray-100', 'text-gray-700');
      tableButton.classList.add('bg-blue-100', 'text-blue-700');
    });
  });
</script>
