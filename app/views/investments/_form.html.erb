<%= form_with(model: investment, class: "space-y-6") do |form| %>
  <% if investment.errors.any? %>
    <div class="p-4 mb-6" style="background:rgba(248,81,73,0.1); border-left:4px solid #f85149; color:#ffa198;">
      <h2 class="font-bold mb-2"><%= pluralize(investment.errors.count, "error") %> prohibited this investment from being saved:</h2>
      <ul class="list-disc pl-5">
        <% investment.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <!-- Basic Information -->
    <div class="space-y-6">
      <h3 class="text-lg font-medium pb-2" style="border-bottom:1px solid #30363d;">Basic Information</h3>
      
      <div class="mb-4">
        <%= form.label :name, class: "block text-sm font-medium mb-1" %>
        <%= form.text_field :name, class: "mt-1 block w-full rounded-md", placeholder: "e.g., Retirement Fund" %>
      </div>
      
      <div class="mb-4">
        <%= form.label :investment_type, class: "block text-sm font-medium mb-1" %>
        <%= form.select :investment_type, 
          [
            ['Stocks', 'stocks'],
            ['Bonds', 'bonds'],
            ['Mutual Funds', 'mutual_funds'],
            ['ETFs', 'etfs'],
            ['Real Estate', 'real_estate'],
            ['Cryptocurrency', 'crypto'],
            ['Savings Account', 'savings'],
            ['Fixed Deposit', 'fixed_deposit'],
            ['Pension Fund', 'pension'],
            ['Other', 'other']
          ],
          { include_blank: 'Select investment type' },
          { class: "mt-1 block w-full rounded-md" }
        %>
      </div>
      
      <div class="mb-4">
        <%= form.label :risk_level, class: "block text-sm font-medium mb-1" %>
        <%= form.select :risk_level, 
          [
            ['Very Low (1)', 1],
            ['Low (2)', 2],
            ['Moderate (3)', 3],
            ['High (4)', 4],
            ['Very High (5)', 5]
          ],
          { include_blank: 'Select risk level' },
          { class: "mt-1 block w-full rounded-md" }
        %>
      </div>
      
      <div class="mb-4">
        <%= form.label :institution, "Financial Institution (Optional)", class: "block text-sm font-medium mb-1" %>
        <%= form.text_field :institution, class: "mt-1 block w-full rounded-md", placeholder: "e.g., Bank of Zambia" %>
      </div>
      
      <div class="mb-4">
        <%= form.label :account_number, "Account Number (Optional)", class: "block text-sm font-medium mb-1" %>
        <%= form.text_field :account_number, class: "mt-1 block w-full rounded-md", placeholder: "e.g., 123456789" %>
      </div>
      
      <% unless investment.new_record? %>
        <div class="flex items-center mb-4">
          <div class="flex items-center h-5">
            <%= form.check_box :active, class: "h-4 w-4 rounded" %>
          </div>
          <div class="ml-3 text-sm">
            <%= form.label :active, "Active", class: "font-medium" %>
            <p style="color:#8b949e;">Uncheck to mark this investment as inactive</p>
          </div>
        </div>
      <% end %>
    </div>
    
    <!-- Financial Details -->
    <div class="space-y-6">
      <h3 class="text-lg font-medium pb-2" style="border-bottom:1px solid #30363d;">Financial Details</h3>
      
      <div class="mb-4">
        <%= form.label :initial_amount, class: "block text-sm font-medium mb-1" %>
        <div class="mt-1 flex rounded-md">
          <span class="inline-flex items-center px-3 rounded-l-md text-sm font-medium" style="background:#30363d; border:1px solid #30363d; border-right:none; color:#8b949e;">K</span>
          <%= form.number_field :initial_amount, step: "0.01", min: "0", class: "flex-1 min-w-0 block w-full px-3 py-2 rounded-none rounded-r-md" %>
        </div>
        <p class="mt-1 text-sm" style="color:#8b949e;">The amount initially invested</p>
      </div>
      
      <% unless investment.new_record? %>
        <div class="mb-4">
          <%= form.label :current_value, class: "block text-sm font-medium mb-1" %>
          <div class="mt-1 flex rounded-md">
            <span class="inline-flex items-center px-3 rounded-l-md text-sm font-medium" style="background:#30363d; border:1px solid #30363d; border-right:none; color:#8b949e;">K</span>
            <%= form.number_field :current_value, step: "0.01", min: "0", class: "flex-1 min-w-0 block w-full px-3 py-2 rounded-none rounded-r-md" %>
          </div>
          <p class="mt-1 text-sm" style="color:#8b949e;">The current market value of the investment</p>
        </div>
      <% end %>
      
      <div class="mb-4">
        <%= form.label :target_value, "Target Value (Optional)", class: "block text-sm font-medium mb-1" %>
        <div class="mt-1 flex rounded-md">
          <span class="inline-flex items-center px-3 rounded-l-md text-sm font-medium" style="background:#30363d; border:1px solid #30363d; border-right:none; color:#8b949e;">K</span>
          <%= form.number_field :target_value, step: "0.01", min: "0", class: "flex-1 min-w-0 block w-full px-3 py-2 rounded-none rounded-r-md" %>
        </div>
        <p class="mt-1 text-sm" style="color:#8b949e;">Your target value for this investment</p>
      </div>
      
      <div class="mb-4">
        <%= form.label :start_date, "Start Date (Optional)", class: "block text-sm font-medium mb-1" %>
        <%= form.date_field :start_date, value: investment.start_date || Date.current, class: "mt-1 block w-full rounded-md" %>
      </div>
      
      <div class="mb-4">
        <%= form.label :target_date, "Target Date (Optional)", class: "block text-sm font-medium mb-1" %>
        <%= form.date_field :target_date, class: "mt-1 block w-full rounded-md" %>
        <p class="mt-1 text-sm" style="color:#8b949e;">When you plan to reach your target value</p>
      </div>
      
      <div class="mb-4">
        <%= form.label :notes, "Notes (Optional)", class: "block text-sm font-medium mb-1" %>
        <%= form.text_area :notes, rows: 3, class: "mt-1 block w-full rounded-md", placeholder: "Any additional notes about this investment" %>
      </div>
    </div>
  </div>
  
  <div class="pt-5" style="border-top:1px solid #30363d;">
    <div class="flex justify-end">
      <a href="<%= investment.new_record? ? investments_path : investment_path(investment) %>" class="py-2 px-4 rounded-md text-sm font-medium" style="background:#21262d; border:1px solid #30363d; color:#8b949e;">Cancel</a>
      <button type="submit" class="ml-3 inline-flex justify-center py-2 px-4 rounded-md text-sm font-medium text-white cursor-pointer" style="background:#238636; border:1px solid rgba(240,246,252,0.1);"><%= investment.new_record? ? "Create Investment" : "Update Investment" %></button>
    </div>
  </div>
<% end %>
