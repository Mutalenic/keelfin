<div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">
  <div class="text-center mb-8">
    <div class="inline-flex items-center justify-center w-16 h-16 bg-brand-100 rounded-2xl mb-4">
      <i class="fa-solid fa-wallet text-brand-600 text-2xl"></i>
    </div>
    <h2 class="text-2xl font-bold text-gray-900">Welcome to Keelfin, <%= current_user.name.split(' ').first %>!</h2>
    <p class="mt-2 text-gray-600">Let's set up your financial profile. First, tell us about your monthly income so we can help you budget effectively.</p>
  </div>

  <%= form_tag onboarding_path, method: :post, class: "space-y-6" do %>
    <%= hidden_field_tag :step, 'income' %>

    <div>
      <label for="monthly_income" class="block text-sm font-medium text-gray-700 mb-1">Monthly income (ZMW)</label>
      <div class="relative">
        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
          <span class="text-gray-500 font-semibold text-sm">K</span>
        </div>
        <input type="number" name="monthly_income" id="monthly_income" step="100" min="0"
               value="<%= current_user.monthly_income %>"
               placeholder="e.g. 5000"
               class="block w-full pl-10 pr-4 py-4 border border-gray-300 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-colors text-lg font-semibold" />
      </div>
      <p class="mt-2 text-xs text-gray-500">This helps us set realistic budget limits and track your financial health. You can change this later.</p>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-xl p-4">
      <div class="flex items-start">
        <i class="fa-solid fa-shield-halved text-blue-500 mt-0.5 mr-3"></i>
        <div>
          <p class="text-sm font-medium text-blue-800">Your data is private</p>
          <p class="text-xs text-blue-600 mt-1">We never share your financial information with anyone. Your income data is only used to provide personalized insights.</p>
        </div>
      </div>
    </div>

    <button type="submit" class="w-full flex items-center justify-center py-4 px-4 border border-transparent rounded-xl shadow-sm text-sm font-semibold text-white bg-brand-600 hover:bg-brand-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-500 transition-all cursor-pointer">
      Continue
      <i class="fa-solid fa-arrow-right ml-2"></i>
    </button>
  <% end %>
</div>
