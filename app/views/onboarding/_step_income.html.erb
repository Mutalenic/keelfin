<div class="bg-content/5 rounded-2xl shadow-sm border border-default p-8">
  <div class="text-center mb-8">
    <div class="inline-flex items-center justify-center w-16 h-16 bg-content/10 rounded-2xl mb-4">
      <i class="fa-solid fa-money-bill-wave text-subtle text-2xl"></i>
    </div>
    <h2 class="text-2xl font-bold text-content">Welcome to Keelfin, <%= current_user.name.split(' ').first %>!</h2>
    <p class="mt-2 text-subtle">Add your salary, business, side hustles, and allowances so you know what you're working with.</p>
  </div>

  <%= form_tag onboarding_path, method: :post, class: "space-y-5" do %>
    <%= hidden_field_tag :step, 'income' %>

    <div id="income-sources-list" class="space-y-3">
      <div class="income-source-row grid grid-cols-12 gap-2 items-end">
        <div class="col-span-5">
          <label class="block text-xs text-accent mb-1">Source name</label>
          <input type="text" name="income_sources[][name]" placeholder="e.g. Salary"
                 class="w-full bg-content/5 border border-default rounded-xl px-3 py-2.5 text-content placeholder-brand-500/60 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500" />
        </div>
        <div class="col-span-4">
          <label class="block text-xs text-accent mb-1">Monthly amount (K)</label>
          <input type="number" name="income_sources[][amount]" step="0.01" min="0" placeholder="0.00"
                 class="w-full bg-content/5 border border-default rounded-xl px-3 py-2.5 text-content placeholder-brand-500/60 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500" />
        </div>
        <div class="col-span-3">
          <label class="block text-xs text-accent mb-1">Frequency</label>
          <select name="income_sources[][frequency]"
                  class="w-full bg-content/5 border border-default rounded-xl px-3 py-2.5 text-content text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
            <option value="monthly">Monthly</option>
            <option value="weekly">Weekly</option>
            <option value="biweekly">Bi-weekly</option>
            <option value="quarterly">Quarterly</option>
            <option value="annually">Annually</option>
          </select>
        </div>
      </div>
    </div>

    <button type="button" onclick="addIncomeRow()" class="flex items-center gap-2 text-sm text-accent hover:text-subtle transition">
      <i class="fa-solid fa-plus-circle"></i> Add another income source
    </button>

    <div class="border-t border-default pt-4">
      <p class="text-xs text-accent mb-2">Or enter a single monthly total if you prefer:</p>
      <div class="relative">
        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
          <span class="text-accent font-semibold text-sm">K</span>
        </div>
        <input type="number" name="monthly_income" step="0.01" min="0"
               value="<%= current_user.monthly_income %>"
               placeholder="Monthly income total"
               class="block w-full pl-10 pr-4 py-3 bg-content/5 border border-default rounded-xl text-content placeholder-brand-500/50 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500" />
      </div>
    </div>

    <button type="submit" class="w-full flex items-center justify-center py-4 px-4 border border-transparent rounded-xl shadow-sm text-sm font-semibold text-white bg-brand-600 hover:bg-brand-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-500 transition-all cursor-pointer">
      Continue
      <i class="fa-solid fa-arrow-right ml-2"></i>
    </button>
  <% end %>
</div>

<script>
  function addIncomeRow() {
    const row = document.querySelector('.income-source-row').cloneNode(true);
    row.querySelectorAll('input').forEach(el => el.value = '');
    document.getElementById('income-sources-list').appendChild(row);
  }
</script>
