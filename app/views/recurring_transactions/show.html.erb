<% content_for(:page_title) { @recurring_transaction.name } %>
<% content_for(:skip_card_wrapper, true) %>

<div class="space-y-8">
  <!-- Hero Banner -->
  <div class="rounded-3xl p-6 sm:p-8 text-white shadow-[0_25px_80px_rgba(15,23,42,0.45)] border border-white/10"
       style="background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 55%, #1e1b4b 100%);">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
      <div>
        <p class="text-xs uppercase tracking-[0.3em] text-white/70 mb-3">Recurring Transaction</p>
        <h1 class="text-2xl sm:text-3xl font-semibold tracking-tight"><%= @recurring_transaction.name %></h1>
        <div class="mt-3 flex flex-wrap gap-2">
          <span class="inline-block px-3 py-1 rounded-full text-sm font-semibold bg-white/20 text-white">
            <%= @recurring_transaction.category.name %>
          </span>
          <% if @recurring_transaction.is_essential %>
          <span class="inline-block px-3 py-1 rounded-full text-sm font-semibold bg-emerald-400/30 text-white">
          <% else %>
          <span class="inline-block px-3 py-1 rounded-full text-sm font-semibold bg-amber-400/30 text-white">
          <% end %>
            <%= @recurring_transaction.is_essential ? 'Essential' : 'Non-essential' %>
          </span>
          <% if @recurring_transaction.payment_method.present? %>
            <span class="inline-block px-3 py-1 rounded-full text-sm font-semibold bg-white/20 text-white">
              <%= @recurring_transaction.payment_method.titleize %>
            </span>
          <% end %>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <%= link_to recurring_transactions_path, class: "inline-flex items-center px-5 py-3 rounded-2xl text-sm font-semibold border border-white/30 text-white/90 hover:bg-white/5 transition" do %>
          <i class="fa-solid fa-arrow-left mr-2"></i>
          Back to Recurring
        <% end %>
        <%= link_to edit_recurring_transaction_path(@recurring_transaction), class: "inline-flex items-center px-5 py-3 rounded-2xl text-sm font-semibold bg-white text-violet-700 shadow-lg shadow-white/20" do %>
          <i class="fa-solid fa-pencil mr-2"></i>
          Edit
        <% end %>
      </div>
    </div>
  </div>

  <!-- Transaction Details -->
  <div class="bg-surface border border-white/30 backdrop-blur-2xl rounded-3xl shadow-2xl p-6">
    <div class="flex justify-between items-start">
      <div class="flex items-center gap-3">
        <% if @recurring_transaction.active? %>
          <span class="inline-flex items-center px-4 py-2 rounded-xl text-sm font-bold bg-emerald-100 text-emerald-800">
            <i class="fa-solid fa-circle-notch mr-2"></i> Active
          </span>
        <% else %>
          <span class="inline-flex items-center px-4 py-2 rounded-xl text-sm font-bold bg-content/5 text-content">
            <i class="fa-solid fa-pause mr-2"></i> Inactive
          </span>
        <% end %>
      </div>
    </div>
    
    <div class="mt-6 grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="bg-content/5 rounded-lg p-4">
        <p class="text-sm text-subtle mb-1">Amount</p>
        <p class="text-2xl font-bold">K<%= number_with_precision(@recurring_transaction.amount, precision: 2) %></p>
      </div>
      
      <div class="bg-content/5 rounded-lg p-4">
        <p class="text-sm text-subtle mb-1">Frequency</p>
        <p class="text-2xl font-bold"><%= @recurring_transaction.human_readable_frequency %></p>
      </div>
      
      <div class="bg-content/5 rounded-lg p-4">
        <p class="text-sm text-subtle mb-1">Monthly Impact</p>
        <p class="text-2xl font-bold">K<%= number_with_precision(@recurring_transaction.estimated_monthly_impact, precision: 2) %></p>
      </div>
    </div>
    
    <div class="mt-6 grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <p class="text-sm text-subtle mb-1">Start Date</p>
        <p class="text-lg font-medium"><%= @recurring_transaction.start_date.strftime('%B %d, %Y') %></p>
      </div>
      
      <div>
        <p class="text-sm text-subtle mb-1">End Date</p>
        <p class="text-lg font-medium">
          <% if @recurring_transaction.end_date %>
            <%= @recurring_transaction.end_date.strftime('%B %d, %Y') %>
          <% else %>
            No end date
          <% end %>
        </p>
      </div>
      
      <div>
        <p class="text-sm text-subtle mb-1">Next Occurrence</p>
        <p class="text-lg font-medium">
          <% if @recurring_transaction.next_occurrence %>
            <%= @recurring_transaction.next_occurrence.strftime('%B %d, %Y') %>
            <% days_until = (@recurring_transaction.next_occurrence - Date.current).to_i %>
            <span class="text-sm <%= days_until <= 0 ? 'text-red-600 font-bold' : 'text-subtle' %>">
              (<%= days_until <= 0 ? 'Due today' : "in #{days_until} days" %>)
            </span>
          <% else %>
            Not scheduled
          <% end %>
        </p>
      </div>
      
      <div>
        <p class="text-sm text-subtle mb-1">Last Occurrence</p>
        <p class="text-lg font-medium">
          <% if @recurring_transaction.last_occurrence %>
            <%= @recurring_transaction.last_occurrence.strftime('%B %d, %Y') %>
          <% else %>
            Never processed
          <% end %>
        </p>
      </div>
    </div>
    
    <% if @recurring_transaction.notes.present? %>
      <div class="mt-6">
        <p class="text-sm text-subtle mb-1">Notes</p>
        <p class="text-lg"><%= @recurring_transaction.notes %></p>
      </div>
    <% end %>
  </div>
  
  <!-- Payment History -->
  <div class="bg-surface border border-white/30 backdrop-blur-2xl rounded-3xl shadow-2xl p-6">
    <h2 class="text-xl font-semibold mb-4">Payment History</h2>
    
    <% if @payment_history.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-default">
          <thead class="bg-content/5">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-subtle uppercase tracking-wider">Date</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-subtle uppercase tracking-wider">Name</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-subtle uppercase tracking-wider">Amount</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-subtle uppercase tracking-wider">Payment Method</th>
            </tr>
          </thead>
          <tbody class="bg-surface divide-y divide-default">
            <% @payment_history.each do |payment| %>
              <tr class="hover:bg-content/5">
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm text-content"><%= payment.created_at.strftime('%b %d, %Y') %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm font-medium text-content"><%= payment.name %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm font-medium">K<%= number_with_precision(payment.amount, precision: 2) %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm text-content"><%= payment.payment_method.present? ? payment.payment_method.titleize : 'N/A' %></div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="text-subtle italic">No payment history found for this recurring transaction.</p>
    <% end %>
  </div>
  
  <!-- Financial Impact -->
  <div class="bg-surface border border-white/30 backdrop-blur-2xl rounded-3xl shadow-2xl p-6">
    <h2 class="text-xl font-semibold mb-4">Financial Impact</h2>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="bg-content/5 rounded-lg p-4">
        <p class="text-sm text-subtle mb-1">Monthly Impact</p>
        <p class="text-2xl font-bold">K<%= number_with_precision(@recurring_transaction.estimated_monthly_impact, precision: 2) %></p>
        <p class="text-sm text-subtle mt-2">This is approximately <%= ((@recurring_transaction.estimated_monthly_impact / current_user.monthly_income) * 100).round(1) %>% of your monthly income.</p>
      </div>
      
      <div class="bg-content/5 rounded-lg p-4">
        <p class="text-sm text-subtle mb-1">Annual Impact</p>
        <p class="text-2xl font-bold">K<%= number_with_precision(@recurring_transaction.estimated_monthly_impact * 12, precision: 2) %></p>
      </div>
    </div>
    
    <div class="mt-6 bg-blue-50 border border-blue-200 rounded-lg p-4">
      <div class="flex items-center">
        <div class="mr-4 text-blue-500">
          <i class="fa-solid fa-lightbulb text-2xl"></i>
        </div>
        <div>
          <p class="font-medium">Financial Insight</p>
          <% if @recurring_transaction.is_essential %>
            <p class="text-sm">This is marked as an essential expense. Consider if there are ways to reduce this recurring cost while maintaining the service.</p>
          <% else %>
            <p class="text-sm">This is a non-essential expense. If you're looking to save money, consider if this recurring payment is bringing enough value.</p>
          <% end %>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Action Buttons -->
  <div class="flex justify-between">
    <%= link_to recurring_transactions_path, class: "inline-flex items-center px-5 py-3 rounded-2xl text-sm font-semibold border border-white/30 text-white/90 hover:bg-white/5 transition" do %>
      <i class="fa-solid fa-arrow-left mr-2"></i>
      Back to Recurring
    <% end %>

    <div class="flex items-center gap-3">
      <% if @recurring_transaction.active? %>
        <%= button_to "Pause", toggle_active_recurring_transaction_path(@recurring_transaction), method: :patch, class: "inline-flex items-center px-5 py-3 rounded-2xl text-sm font-semibold bg-amber-600 text-white shadow hover:bg-amber-500 transition" %>
      <% else %>
        <%= button_to "Activate", toggle_active_recurring_transaction_path(@recurring_transaction), method: :patch, class: "inline-flex items-center px-5 py-3 rounded-2xl text-sm font-semibold bg-emerald-600 text-white shadow hover:bg-emerald-500 transition" %>
      <% end %>
      <%= link_to edit_recurring_transaction_path(@recurring_transaction), class: "inline-flex items-center px-5 py-3 rounded-2xl text-sm font-semibold bg-violet-600 text-white shadow hover:bg-violet-500 transition" do %>
        <i class="fa-solid fa-pencil mr-2"></i>
        Edit
      <% end %>
      <%= button_to recurring_transaction_path(@recurring_transaction), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this recurring transaction?" }, class: "inline-flex items-center px-5 py-3 rounded-2xl text-sm font-semibold bg-red-600 text-white shadow hover:bg-red-500 transition" do %>
        <i class="fa-solid fa-trash mr-2"></i>
        Delete
      <% end %>
    </div>
  </div>
</div>
