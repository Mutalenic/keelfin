<% content_for(:page_title) { "New Debt" } %>
<% content_for(:skip_card_wrapper, true) %>

<div class="space-y-8">
  <!-- Hero Banner -->
  <div class="rounded-3xl p-6 sm:p-8 text-white shadow-[0_25px_80px_rgba(15,23,42,0.45)] border border-white/10"
       style="background: linear-gradient(135deg, #ef4444 0%, #f97316 55%, #1e1b4b 100%);">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
      <div>
        <p class="text-xs uppercase tracking-[0.3em] text-white/70 mb-3">Liability control</p>
        <h1 class="text-2xl sm:text-3xl font-semibold tracking-tight">Add new debt</h1>
        <p class="mt-2 text-sm sm:text-base text-white/80 max-w-2xl">
          Track loans, credit cards, and other liabilities to manage your debt-to-income ratio.
        </p>
      </div>
      <div class="flex items-center gap-3">
        <%= link_to debts_path, class: "inline-flex items-center px-5 py-3 rounded-2xl text-sm font-semibold border border-white/30 text-white/90 hover:bg-white/5 transition" do %>
          <i class="fa-solid fa-arrow-left mr-2"></i>
          Back to debts
        <% end %>
      </div>
    </div>
  </div>

  <div class="max-w-3xl mx-auto">
    <div class="bg-surface border border-default backdrop-blur-2xl rounded-3xl shadow-2xl p-6 sm:p-8">
      <%= form_with(model: @debt, local: true, class: "space-y-5") do |form| %>
        <% if @debt.errors.any? %>
          <div class="bg-red-50 border border-red-200 rounded-2xl p-4 mb-6">
            <h2 class="text-red-800 font-semibold mb-2"><%= pluralize(@debt.errors.count, "error") %> prohibited this from being saved:</h2>
            <ul class="text-red-700 list-disc list-inside text-sm">
              <% @debt.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <div>
            <%= form.label :lender_name, "Lender Name", class: "block text-sm font-medium text-content mb-2" %>
            <%= form.text_field :lender_name, class: "w-full px-4 py-3 border border-default rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-brand-500 text-sm", placeholder: "e.g., Bayport, Madison Finance" %>
          </div>

          <div>
            <%= form.label :principal_amount, "Principal Amount (ZMW)", class: "block text-sm font-medium text-content mb-2" %>
            <%= form.number_field :principal_amount, step: 0.01, class: "w-full px-4 py-3 border border-default rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-brand-500 text-sm", placeholder: "e.g., 50000.00" %>
          </div>

          <div>
            <%= form.label :interest_rate, "Interest Rate (%)", class: "block text-sm font-medium text-content mb-2" %>
            <%= form.number_field :interest_rate, step: 0.1, class: "w-full px-4 py-3 border border-default rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-brand-500 text-sm", placeholder: "e.g., 15.5" %>
          </div>

          <div>
            <%= form.label :monthly_payment, "Monthly Payment (ZMW)", class: "block text-sm font-medium text-content mb-2" %>
            <%= form.number_field :monthly_payment, step: 0.01, class: "w-full px-4 py-3 border border-default rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-brand-500 text-sm", placeholder: "e.g., 2500.00" %>
          </div>

          <div>
            <%= form.label :term, "Loan Term (months)", class: "block text-sm font-medium text-content mb-2" %>
            <%= form.number_field :term, class: "w-full px-4 py-3 border border-default rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-brand-500 text-sm", placeholder: "e.g., 24" %>
          </div>

          <div>
            <%= form.label :status, "Status", class: "block text-sm font-medium text-content mb-2" %>
            <%= form.select :status, [['Active', 'active'], ['Paid Off', 'paid_off']], {}, class: "w-full px-4 py-3 border border-default rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-brand-500 text-sm" %>
          </div>

          <div>
            <%= form.label :start_date, "Start Date", class: "block text-sm font-medium text-content mb-2" %>
            <%= form.date_field :start_date, class: "w-full px-4 py-3 border border-default rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-brand-500 text-sm" %>
          </div>

          <div>
            <%= form.label :end_date, "End Date", class: "block text-sm font-medium text-content mb-2" %>
            <%= form.date_field :end_date, class: "w-full px-4 py-3 border border-default rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-brand-500 text-sm" %>
          </div>
        </div>

        <div class="flex items-center gap-4 pt-4">
          <%= form.submit "Add Debt", class: "inline-flex items-center px-6 py-3 rounded-xl text-sm font-semibold bg-brand-600 text-white shadow hover:bg-brand-500 transition cursor-pointer" %>
          <%= link_to "Cancel", debts_path, class: "inline-flex items-center px-6 py-3 rounded-xl text-sm font-semibold bg-content/5 text-content hover:bg-content/10 transition" %>
        </div>
      <% end %>
    </div>

    <div class="mt-6 bg-amber-50 border border-amber-200 rounded-2xl p-5">
      <h3 class="font-semibold text-amber-800 mb-3 flex items-center gap-2">
        <i class="fa-solid fa-lightbulb text-amber-600"></i>
        Debt Management Tip
      </h3>
      <p class="text-sm text-amber-700">
        Keep your total debt payments below 40% of your monthly income to maintain financial health.
        Track all your debts here to avoid exceeding the safe threshold.
      </p>
    </div>
  </div>
</div>
