<% content_for(:page_title) { "Edit Debt" } %>
<% content_for(:skip_card_wrapper, true) %>

<div class="space-y-8">
  <!-- Hero Banner -->
  <div class="rounded-3xl p-6 sm:p-8 text-white shadow-[0_25px_80px_rgba(15,23,42,0.45)] border border-white/10"
       style="background: linear-gradient(135deg, #ef4444 0%, #f97316 55%, #1e1b4b 100%);">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
      <div>
        <p class="text-xs uppercase tracking-[0.3em] text-white/70 mb-3">Liability control</p>
        <h1 class="text-2xl sm:text-3xl font-semibold tracking-tight">Edit <%= @debt.lender_name %></h1>
        <p class="mt-2 text-sm sm:text-base text-white/80 max-w-2xl">
          Update your debt details and repayment schedule.
        </p>
      </div>
      <div class="flex items-center gap-3">
        <%= link_to @debt, class: "inline-flex items-center px-5 py-3 rounded-2xl text-sm font-semibold border border-white/30 text-white/90 hover:bg-white/5 transition" do %>
          <i class="fa-solid fa-arrow-left mr-2"></i>
          Back to debt
        <% end %>
      </div>
    </div>
  </div>

  <div class="max-w-3xl mx-auto">
    <div class="bg-white/95 border border-white/30 backdrop-blur-2xl rounded-3xl shadow-2xl p-6 sm:p-8">
      <%= form_with(model: @debt, local: true, class: "space-y-5") do |f| %>
        <% if @debt.errors.any? %>
          <div class="bg-red-50 border border-red-200 rounded-2xl p-4 mb-6">
            <h2 class="text-red-800 font-semibold mb-2">
              <%= pluralize(@debt.errors.count, "error") %> prohibited this debt from being saved:
            </h2>
            <ul class="text-red-700 list-disc list-inside text-sm">
              <% @debt.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <div>
            <%= f.label :lender_name, class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= f.text_field :lender_name, class: "w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-brand-500 text-sm", placeholder: "e.g., Bayport, Madison" %>
          </div>

          <div>
            <%= f.label :principal_amount, class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= f.number_field :principal_amount, class: "w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-brand-500 text-sm", placeholder: "e.g., 50000", step: "0.01" %>
          </div>

          <div>
            <%= f.label :interest_rate, class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= f.number_field :interest_rate, class: "w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-brand-500 text-sm", placeholder: "e.g., 15.5", step: "0.01" %>
          </div>

          <div>
            <%= f.label :monthly_payment, class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= f.number_field :monthly_payment, class: "w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-brand-500 text-sm", placeholder: "e.g., 2500", step: "0.01" %>
          </div>

          <div>
            <%= f.label :start_date, class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= f.date_field :start_date, class: "w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-brand-500 text-sm" %>
          </div>

          <div>
            <%= f.label :end_date, class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= f.date_field :end_date, class: "w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-brand-500 text-sm" %>
          </div>

          <div>
            <%= f.label :status, class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= f.select :status,
                        options_for_select([['Active', 'active'], ['Paid Off', 'paid_off']], @debt.status),
                        { prompt: 'Select status' },
                        { class: "w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-brand-500 text-sm" } %>
          </div>

          <div>
            <%= f.label :term, class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= f.number_field :term, class: "w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-brand-500 text-sm", placeholder: "e.g., 24 (months)" %>
          </div>
        </div>

        <div class="flex items-center gap-4 pt-4">
          <%= f.submit "Update Debt", class: "inline-flex items-center px-6 py-3 rounded-xl text-sm font-semibold bg-brand-600 text-white shadow hover:bg-brand-500 transition cursor-pointer" %>
          <%= link_to "Cancel", @debt, class: "inline-flex items-center px-6 py-3 rounded-xl text-sm font-semibold bg-gray-100 text-gray-700 hover:bg-gray-200 transition" %>
        </div>
      <% end %>
    </div>

    <div class="mt-6 bg-amber-50 border border-amber-200 rounded-2xl p-5">
      <h3 class="font-semibold text-amber-800 mb-3 flex items-center gap-2">
        <i class="fa-solid fa-lightbulb text-amber-600"></i>
        Debt Management Tips
      </h3>
      <ul class="text-sm text-amber-700 space-y-2 list-disc list-inside">
        <li>Keep your debt-to-income ratio below 30% for financial health</li>
        <li>Consider paying off high-interest loans first (avalanche method)</li>
        <li>Track your progress by updating payments regularly</li>
        <li>Set realistic end dates based on your monthly payment capacity</li>
      </ul>
    </div>
  </div>
</div>
