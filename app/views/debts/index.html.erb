<% content_for(:page_title) { "Debts" } %>

<div class="space-y-8">
  <!-- Hero -->
  <div class="rounded-3xl p-6 sm:p-8 text-white shadow-[0_25px_80px_rgba(15,23,42,0.45)] border border-white/10"
       style="background: linear-gradient(135deg, #991b1b 0%, #ef4444 45%, #f97316 100%);">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
      <div>
        <p class="text-xs uppercase tracking-[0.3em] text-white/80 mb-3">Liability control</p>
        <h1 class="text-2xl sm:text-3xl font-semibold tracking-tight">Debt management</h1>
        <p class="mt-2 text-sm sm:text-base text-white/90 max-w-2xl">
          Compare payroll deductions vs side-hustle income, watch your debt-to-income, and act before banks flag your profile.
        </p>
      </div>
      <div class="flex items-center gap-3">
        <%= link_to new_debt_path, class: "inline-flex items-center px-5 py-3 rounded-2xl text-sm font-semibold bg-white text-red-700 shadow-lg shadow-white/20" do %>
          <i class="fa-solid fa-plus mr-2"></i>
          Add new debt
        <% end %>
        <%= link_to coming_soon_path(feature: 'debt-consolidation'), class: "inline-flex items-center px-5 py-3 rounded-2xl text-sm font-semibold border border-white/30 text-white/90 hover:bg-white/5 transition" do %>
          <i class="fa-solid fa-arrow-trend-down mr-2"></i>
          Consolidation offers
        <% end %>
      </div>
    </div>
  </div>

  <!-- KPI cards -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div class="rounded-2xl border border-white/15 backdrop-blur-xl p-5 text-white shadow-lg"
         style="background: linear-gradient(150deg, rgba(239,68,68,0.95) 0%, rgba(248,113,113,0.85) 100%);">
      <p class="text-xs uppercase tracking-wide text-white/70">Total debt</p>
      <p class="text-3xl font-semibold mt-3">K<%= number_with_precision(@analysis[:total_debt], precision: 2) %></p>
      <p class="text-xs text-white/70 mt-1">across all lenders</p>
    </div>
    <div class="rounded-2xl border border-white/15 backdrop-blur-xl p-5 text-white shadow-lg"
         style="background: linear-gradient(150deg, rgba(59,130,246,0.95) 0%, rgba(14,165,233,0.9) 100%);">
      <p class="text-xs uppercase tracking-wide text-white/70">Monthly payments</p>
      <p class="text-3xl font-semibold mt-3">K<%= number_with_precision(@analysis[:monthly_payments], precision: 2) %></p>
      <p class="text-xs text-white/70 mt-1">due this month</p>
    </div>
    <div class="rounded-2xl border border-white/15 backdrop-blur-xl p-5 text-white shadow-lg"
         style="background: linear-gradient(150deg, rgba(245,158,11,0.95) 0%, rgba(249,115,22,0.9) 100%);">
      <p class="text-xs uppercase tracking-wide text-white/70">Debt-to-income</p>
      <p class="text-3xl font-semibold mt-3"><%= number_with_precision(@analysis[:debt_to_income], precision: 1) %>%</p>
      <p class="text-xs text-white/70 mt-1">Safe threshold ≤ 40%</p>
    </div>
  </div>

  <% if @analysis[:is_over_indebted] %>
    <div class="bg-red-500/10 border border-red-400/40 rounded-3xl p-6 text-red-800">
      <div class="flex items-center gap-3 mb-3">
        <i class="fa-solid fa-triangle-exclamation"></i>
        <h2 class="text-lg font-semibold">Over-indebtedness alert</h2>
      </div>
      <p class="text-sm mb-2">Your debt-to-income ratio is <strong><%= @analysis[:debt_to_income] %>%</strong>, exceeding the recommended threshold. Consider renegotiating payroll deductions or consolidating loans.</p>
      <p class="text-xs text-red-700/80">Civil service payroll, microfinance, and MoMo advance products are most likely culprits.</p>
    </div>
  <% end %>

  <% if @analysis[:recommendations].any? %>
    <div class="bg-white/95 border border-white/30 backdrop-blur-2xl rounded-3xl shadow-2xl p-6">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">Recommendations</h2>
      <ul class="space-y-2 text-sm text-gray-600 list-disc list-inside">
        <% @analysis[:recommendations].each do |recommendation| %>
          <li><%= recommendation %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% if @analysis[:payoff_strategies][:avalanche].any? || @analysis[:payoff_strategies][:snowball].any? %>
    <div class="bg-white/95 border border-white/30 backdrop-blur-2xl rounded-3xl shadow-2xl p-6">
      <div class="flex items-center gap-3 mb-4">
        <i class="fa-solid fa-chart-line text-brand-600"></i>
        <h2 class="text-xl font-semibold text-gray-900">Suggested payoff strategies</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <h3 class="font-semibold text-gray-900 mb-2">Avalanche (highest interest first)</h3>
          <p class="text-sm text-gray-500 mb-3">Minimise interest by attacking the most expensive debt first.</p>
          <div class="space-y-1 text-sm text-gray-700">
            <% @analysis[:payoff_strategies][:avalanche].each do |lender, rate| %>
              <div class="flex justify-between"><span><%= lender %></span><span><%= number_with_precision(rate, precision: 1) %>%</span></div>
            <% end %>
          </div>
        </div>
        <div>
          <h3 class="font-semibold text-gray-900 mb-2">Snowball (smallest balance)</h3>
          <p class="text-sm text-gray-500 mb-3">Create momentum by clearing the smallest debts first.</p>
          <div class="space-y-1 text-sm text-gray-700">
            <% @analysis[:payoff_strategies][:snowball].each do |lender, amount| %>
              <div class="flex justify-between"><span><%= lender %></span><span>K<%= number_with_precision(amount, precision: 2) %></span></div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div class="bg-white/95 border border-white/30 backdrop-blur-2xl rounded-3xl shadow-2xl p-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-xl font-semibold text-gray-900">Your debts</h2>
      <%= link_to new_debt_path, class: "inline-flex items-center px-4 py-2 rounded-xl text-sm font-semibold bg-red-600 text-white shadow hover:bg-red-500 transition" do %>
        <i class="fa-solid fa-plus mr-2"></i>
        Add debt
      <% end %>
    </div>

    <% if @debts.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-100 text-sm">
          <thead>
            <tr class="text-left text-gray-500 uppercase text-xs tracking-wider">
              <th class="px-6 py-3">Lender</th>
              <th class="px-6 py-3">Principal</th>
              <th class="px-6 py-3">Interest</th>
              <th class="px-6 py-3">Monthly payment</th>
              <th class="px-6 py-3">Status</th>
              <th class="px-6 py-3 text-right">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% @debts.each do |debt| %>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 font-semibold text-gray-900"><%= debt.lender_name %></td>
                <td class="px-6 py-4 text-gray-900">K<%= number_with_precision(debt.principal_amount, precision: 2) %></td>
                <td class="px-6 py-4 text-gray-900"><%= debt.interest_rate ? "#{number_with_precision(debt.interest_rate, precision: 1)}%" : 'N/A' %></td>
                <td class="px-6 py-4 text-gray-900"><%= debt.monthly_payment ? "K#{number_with_precision(debt.monthly_payment, precision: 2)}" : 'N/A' %></td>
                <td class="px-6 py-4">
                  <span class="px-2 py-1 rounded-full text-xs font-semibold <%= debt.status == 'active' ? 'bg-red-100 text-red-700' : 'bg-green-100 text-green-700' %>">
                    <%= debt.status.titleize %>
                  </span>
                </td>
                <td class="px-6 py-4 text-right">
                  <div class="flex items-center justify-end gap-2 text-xs font-semibold">
                    <%= link_to "View", debt_path(debt), class: "px-3 py-1 rounded-lg bg-gray-100 text-gray-700 hover:bg-gray-200" %>
                    <%= link_to "Edit", edit_debt_path(debt), class: "px-3 py-1 rounded-lg bg-brand-50 text-brand-700 hover:bg-brand-100" %>
                    <%= link_to "Delete", debt_path(debt), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "px-3 py-1 rounded-lg bg-red-50 text-red-600 hover:bg-red-100" %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="text-center py-12 bg-gray-50 rounded-2xl border border-dashed border-gray-200">
        <p class="text-gray-600 mb-4">No debts recorded yet.</p>
        <%= link_to "Add new debt", new_debt_path, class: "inline-flex items-center px-5 py-2.5 rounded-xl bg-red-600 text-white font-semibold shadow hover:bg-red-500" %>
      </div>
    <% end %>
  </div>

  <div class="text-sm">
    <%= link_to "Back to dashboard", dashboard_path, class: "text-white/80 hover:text-white" %>
  </div>
</div>
