<!DOCTYPE html>
<html class="h-full bg-brand-950">
  <head>
    <title>Keelfin</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.1.1/css/all.min.css" integrity="sha512-KfkfwYDsLkIlwQp6LFnl8zNdLGxu9YAA1QvwINks4PhcElQSvqcyVLLD9aMhXd13uQjoXtEKNosOWaZqXgel0g==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <script src="https://cdn.tailwindcss.com" nonce="<%= content_security_policy_nonce %>"></script>
    <script nonce="<%= content_security_policy_nonce %>">
      tailwind.config = {
        safelist: [
          { pattern: /bg-brand-(50|100|200|300|400|500|600|700|800|900|950)(\/\d+)?/ },
          { pattern: /text-brand-(50|100|200|300|400|500|600|700|800|900|950)(\/\d+)?/ },
          { pattern: /border-brand-(50|100|200|300|400|500|600|700|800|900|950)(\/\d+)?/ },
          { pattern: /ring-brand-(50|100|200|300|400|500|600|700|800|900|950)(\/\d+)?/ },
          { pattern: /hover:bg-brand-(50|100|200|300|400|500|600|700|800|900|950)(\/\d+)?/ },
          { pattern: /hover:text-brand-(50|100|200|300|400|500|600|700|800|900|950)(\/\d+)?/ },
          { pattern: /focus:ring-brand-(50|100|200|300|400|500|600|700|800|900|950)(\/\d+)?/ },
          { pattern: /from-brand-(50|100|200|300|400|500|600|700|800|900|950)/ },
          { pattern: /to-brand-(50|100|200|300|400|500|600|700|800|900|950)/ },
          { pattern: /shadow-brand-(50|100|200|300|400|500|600|700|800|900|950)(\/\d+)?/ },
          { pattern: /divide-brand-(50|100|200|300|400|500|600|700|800|900|950)(\/\d+)?/ },
        ],
        theme: {
          extend: {
            colors: {
              brand: {
                50:  '#e6edf3', 100: '#cae8ff', 200: '#7ee787', 300: '#56d364',
                400: '#3fb950', 500: '#2ea043', 600: '#238636', 700: '#30363d',
                800: '#21262d', 900: '#161b22', 950: '#0d1117',
              }
            }
          }
        }
      }
    </script>

    <%= favicon_link_tag 'favicon.svg', type: 'image/svg+xml' %>

    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"
            integrity="sha256-IGtui7APx7uix+6AykHbPp4FunvgqjWr66nP1TV/XQ4="
            crossorigin="anonymous"
            nonce="<%= content_security_policy_nonce %>"></script>
    <%= javascript_include_tag "application", nonce: true %>

    <style>
      [data-sidebar-toggle]:checked ~ .sidebar-overlay { display: block; }
      [data-sidebar-toggle]:checked ~ .sidebar-panel { transform: translateX(0); }
      html, body { background-color: #0d1117 !important; }
      main { background-color: #0d1117 !important; }
      /* ── Global dark-theme form overrides ─────────────────────────── */
      input:not([type=checkbox]):not([type=radio]):not([type=submit]):not([type=button]),
      select, textarea {
        background-color: #21262d !important;
        border: 1px solid #30363d !important;
        color: #e6edf3 !important;
        color-scheme: dark;
        border-radius: 0.75rem;
      }
      input::placeholder, textarea::placeholder { color: #6e7681 !important; }
      label { color: #cae8ff !important; }
      input:focus, select:focus, textarea:focus {
        outline: none !important;
        border-color: #238636 !important;
        box-shadow: 0 0 0 3px rgba(35,134,54,0.25) !important;
      }
      /* Cancel / secondary buttons that use gray */
      .btn-cancel, a.btn-cancel {
        background-color: #21262d !important;
        color: #8b949e !important;
        border: 1px solid #30363d !important;
      }
      /* White card overrides */
      .card-form {
        background-color: #161b22 !important;
        border: 1px solid #30363d !important;
        color: #e6edf3 !important;
      }
    </style>
  </head>

  <body class="min-h-screen" style="background: linear-gradient(135deg, #0d1117 0%, #161b22 60%, #21262d 100%); color: #e6edf3;">
    <div class="absolute inset-0 pointer-events-none">
      <div class="h-full w-full opacity-40"
           style="background-image: radial-gradient(circle at 20% 20%, rgba(46,160,67,0.12) 0, transparent 45%),
                                  radial-gradient(circle at 80% 10%, rgba(35,134,54,0.08) 0, transparent 40%),
                                  radial-gradient(circle at 10% 80%, rgba(56,189,248,0.06) 0, transparent 40%);"></div>
    </div>

    <div class="relative flex min-h-screen">
      <!-- Mobile sidebar toggle (hidden checkbox trick) -->
      <input type="checkbox" id="sidebar-toggle" class="hidden" data-sidebar-toggle />

      <!-- Mobile overlay -->
      <label for="sidebar-toggle" class="sidebar-overlay hidden fixed inset-0 bg-gray-900/50 z-30 lg:hidden"></label>

      <!-- Sidebar -->
      <aside class="sidebar-panel fixed inset-y-0 left-0 z-40 w-64 backdrop-blur-2xl transform -translate-x-full lg:translate-x-0 lg:static lg:flex lg:flex-col transition-transform duration-200 ease-in-out" style="background:#161b22; border-right:1px solid #30363d; box-shadow:4px 0 24px rgba(0,0,0,0.4);">
        <div class="flex flex-col h-full">
          <!-- Logo -->
          <div class="flex items-center justify-between h-16 px-5" style="border-bottom:1px solid #30363d; background:#0d1117;">
            <a href="<%= root_path %>" class="flex items-center space-x-2.5">
              <div class="w-8 h-8 bg-gradient-to-br from-brand-500 to-brand-700 rounded-xl flex items-center justify-center shadow-inner shadow-brand-900/30">
                <i class="fa-solid fa-wallet text-white text-sm"></i>
              </div>
              <span class="text-lg font-bold text-white tracking-tight">Keelfin</span>
            </a>
            <label for="sidebar-toggle" class="lg:hidden p-1 rounded-md hover:bg-white/10 cursor-pointer text-white/70">
              <i class="fa-solid fa-xmark"></i>
            </label>
          </div>

          <!-- Navigation -->
          <nav class="flex-1 px-3 py-4 space-y-1 overflow-y-auto text-white/80">
            <p class="px-3 text-xs font-semibold text-white/50 uppercase tracking-wider mb-2">Overview</p>
            <%= sidebar_link 'Dashboard', dashboard_path, 'fa-solid fa-grid-2', 'dashboard' %>

            <p class="px-3 pt-5 text-xs font-semibold text-white/50 uppercase tracking-wider mb-2">Money</p>
            <%= sidebar_link 'Income', income_sources_path, 'fa-solid fa-money-bill-wave', 'income_sources' %>
            <%= sidebar_link 'Categories', categories_path, 'fa-solid fa-tags', 'categories' %>
            <%= sidebar_link 'Budgets', budgets_path, 'fa-solid fa-chart-pie', 'budgets' %>
            <%= sidebar_link 'Annual View', annual_overview_path, 'fa-solid fa-calendar-days', 'annual_overview' %>
            <%= sidebar_link 'Recurring', recurring_transactions_path, 'fa-solid fa-repeat', 'recurring_transactions' %>

            <%= sidebar_link 'Analysis', financial_analysis_path, 'fa-solid fa-magnifying-glass-chart', 'financial_analysis' %>

            <p class="px-3 pt-5 text-xs font-semibold text-white/50 uppercase tracking-wider mb-2">Wealth</p>
            <%= sidebar_link 'Debts', debts_path, 'fa-solid fa-credit-card', 'debts' %>
            <%= sidebar_link 'Goals', financial_goals_path, 'fa-solid fa-bullseye', 'financial_goals' %>
            <%= sidebar_link 'Investments', investments_path, 'fa-solid fa-chart-line', 'investments' %>

            <!-- Global Add Transaction Button -->
            <div class="pt-4">
              <button onclick="document.getElementById('global-add-transaction').classList.remove('hidden')" class="w-full flex items-center justify-center gap-2 px-4 py-2.5 rounded-2xl text-sm font-semibold bg-brand-600 text-white hover:bg-brand-500 transition">
                <i class="fa-solid fa-plus"></i> Add Transaction
              </button>
            </div>

            <p class="px-3 pt-5 text-xs font-semibold text-white/50 uppercase tracking-wider mb-2">Account</p>
            <%= sidebar_link 'Subscription', subscription_path, 'fa-solid fa-crown', 'subscriptions' %>
            <% if current_user&.admin? %>
              <%= sidebar_link 'Admin', admin_root_path, 'fa-solid fa-shield-halved', 'admin' %>
            <% end %>
          </nav>

          <!-- User Footer -->
          <div class="p-4" style="border-top:1px solid #30363d; background:#0d1117;">
            <div class="flex items-center">
              <div class="w-9 h-9 bg-white/20 rounded-full flex items-center justify-center">
                <span class="text-sm font-bold text-white"><%= current_user&.name&.first(2)&.upcase %></span>
              </div>
              <div class="ml-3 flex-1 min-w-0">
                <p class="text-sm font-medium text-white truncate"><%= current_user&.name %></p>
                <p class="text-xs text-white/60 truncate"><%= current_user&.email %></p>
              </div>
              <div class="flex items-center space-x-1">
                <a href="<%= edit_user_registration_path %>" class="p-1.5 rounded-md hover:bg-white/10 text-white/60 hover:text-white transition-colors" title="Settings">
                  <i class="fa-solid fa-gear text-sm"></i>
                </a>
                <a href="<%= destroy_user_session_path %>" data-turbo-method="delete" class="p-1.5 rounded-md hover:bg-red-500/10 text-white/60 hover:text-red-300 transition-colors" title="Sign out">
                  <i class="fa-solid fa-right-from-bracket text-sm"></i>
                </a>
              </div>
            </div>
          </div>
        </div>
      </aside>

      <!-- Main Content -->
      <div class="flex-1 flex flex-col min-w-0">
        <!-- Top Bar -->
        <header class="sticky top-0 z-20 backdrop-blur-2xl" style="background:rgba(13,17,23,0.85); border-bottom:1px solid #30363d; box-shadow:0 4px 24px rgba(0,0,0,0.3);">
          <div class="flex items-center justify-between h-16 px-4 sm:px-6 lg:px-8">
            <div class="flex items-center">
              <label for="sidebar-toggle" class="lg:hidden p-2 -ml-2 rounded-md hover:bg-white/10 cursor-pointer mr-3 text-white/70">
                <i class="fa-solid fa-bars"></i>
              </label>
              <h1 class="text-lg font-semibold text-white"><%= yield(:page_title) if content_for?(:page_title) %></h1>
            </div>
            <div class="flex items-center space-x-3">
              <% if current_user && !current_user.confirmed_at %>
                <div class="hidden sm:flex items-center bg-amber-400/20 text-amber-100 px-3 py-1.5 rounded-lg text-xs font-medium border border-amber-200/20">
                  <i class="fa-solid fa-envelope mr-1.5"></i>
                  Please verify your email
                </div>
              <% end %>
              <% if current_user&.premium? %>
                <span class="hidden sm:flex items-center bg-gradient-to-r from-amber-400/30 to-yellow-300/30 text-amber-100 px-3 py-1.5 rounded-lg text-xs font-semibold border border-amber-200/20">
                  <i class="fa-solid fa-crown mr-1.5 text-amber-200"></i> Premium
                </span>
              <% end %>
            </div>
          </div>
        </header>

        <!-- Flash Messages -->
        <% if notice.present? %>
          <div class="mx-4 sm:mx-6 lg:mx-8 mt-4">
            <div class="bg-emerald-900/30 border border-emerald-700/40 text-emerald-300 rounded-xl px-4 py-3 text-sm flex items-start" role="alert">
              <i class="fa-solid fa-circle-check text-emerald-400 mt-0.5 mr-3 flex-shrink-0"></i>
              <span><%= notice %></span>
            </div>
          </div>
        <% end %>
        <% if alert.present? %>
          <div class="mx-4 sm:mx-6 lg:mx-8 mt-4">
            <div class="bg-red-900/30 border border-red-700/40 text-red-300 rounded-xl px-4 py-3 text-sm flex items-start" role="alert">
              <i class="fa-solid fa-circle-exclamation text-red-400 mt-0.5 mr-3 flex-shrink-0"></i>
              <span><%= alert %></span>
            </div>
          </div>
        <% end %>

        <!-- Page Content -->
        <main class="flex-1 overflow-y-auto" style="background-color: #0d1117;">
          <div class="px-4 sm:px-6 lg:px-8 py-6">
            <%= yield %>
          </div>
        </main>
      </div>
    </div>

    <!-- Global Add Transaction Modal -->
    <div id="global-add-transaction" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
      <div class="absolute inset-0 backdrop-blur-sm" style="background:rgba(0,0,0,0.70)" onclick="document.getElementById('global-add-transaction').classList.add('hidden')"></div>
      <div class="relative rounded-2xl shadow-2xl p-6 w-full max-w-md" style="background:#161b22; border:1px solid #30363d;">
        <div class="flex items-center justify-between mb-5">
          <h2 class="text-lg font-semibold text-brand-100">Add Transaction</h2>
          <button onclick="document.getElementById('global-add-transaction').classList.add('hidden')" class="p-2 rounded-xl hover:bg-brand-800 text-brand-400 hover:text-brand-200 transition">
            <i class="fa-solid fa-xmark"></i>
          </button>
        </div>
        <form action="<%= global_payments_path %>" method="post" class="space-y-4" accept-charset="UTF-8">
          <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
          <div class="grid grid-cols-2 gap-3">
            <div class="col-span-2">
              <label class="block text-xs text-brand-400 mb-1">Name / Description</label>
              <input type="text" name="payment[name]" placeholder="e.g. Groceries at Shoprite" class="w-full bg-brand-800/60 border border-brand-600/40 text-brand-100 rounded-xl px-4 py-2.5 text-sm placeholder-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-500">
            </div>
            <div>
              <label class="block text-xs text-brand-400 mb-1">Amount (ZMW)</label>
              <input type="number" name="payment[amount]" step="0.01" min="0.01" placeholder="0.00" class="w-full bg-brand-800/60 border border-brand-600/40 text-brand-100 rounded-xl px-4 py-2.5 text-sm placeholder-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-500">
            </div>
            <div>
              <label class="block text-xs text-brand-400 mb-1">Date</label>
              <input type="date" name="payment[created_at]" value="<%= Date.current %>" class="w-full bg-brand-800/60 border border-brand-600/40 text-brand-100 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
            </div>
            <div class="col-span-2">
              <label class="block text-xs text-brand-400 mb-1">Category</label>
              <% if current_user&.categories&.any? %>
                <select name="payment[category_id]" class="w-full bg-brand-800/60 border border-brand-600/40 text-brand-100 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
                  <option value="">Select a category</option>
                  <% current_user.categories.order(:name).each do |c| %>
                    <option value="<%= c.id %>"><%= c.name %></option>
                  <% end %>
                </select>
              <% else %>
                <p class="text-sm text-brand-400">No categories yet. <a href="<%= categories_path %>" class="text-brand-300 underline">Add one first</a>.</p>
              <% end %>
            </div>
            <div>
              <label class="block text-xs text-brand-400 mb-1">Payment Method</label>
              <select name="payment[payment_method]" class="w-full bg-brand-800/60 border border-brand-600/40 text-brand-100 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
                <% [["Cash","cash"],["Airtel Money","airtel_money"],["MTN MoMo","mtn_momo"],["Bank Transfer","bank_transfer"],["Card","card"],["Other","other"]].each do |label, val| %>
                  <option value="<%= val %>" <%= "selected" if val == "cash" %>><%= label %></option>
                <% end %>
              </select>
            </div>
            <div>
              <label class="block text-xs text-brand-400 mb-1">Essential?</label>
              <select name="payment[is_essential]" class="w-full bg-brand-800/60 border border-brand-600/40 text-brand-100 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
                <option value="1" selected>Yes — essential</option>
                <option value="0">No — discretionary</option>
              </select>
            </div>
          </div>
          <div class="flex gap-3 pt-1">
            <button type="submit" class="flex-1 py-3 rounded-2xl text-sm font-semibold bg-brand-600 text-white hover:bg-brand-500 transition cursor-pointer">Add Transaction</button>
            <button type="button" onclick="document.getElementById('global-add-transaction').classList.add('hidden')" class="px-5 py-3 rounded-2xl text-sm font-semibold border border-brand-600/40 text-brand-300 hover:bg-brand-800 transition">
              Cancel
            </button>
          </div>
        </form>
      </div>
    </div>
  </body>
</html>
