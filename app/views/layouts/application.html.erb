<!DOCTYPE html>
<html class="h-full bg-gray-50">
  <head>
    <title>Keelfin</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.1.1/css/all.min.css" integrity="sha512-KfkfwYDsLkIlwQp6LFnl8zNdLGxu9YAA1QvwINks4PhcElQSvqcyVLLD9aMhXd13uQjoXtEKNosOWaZqXgel0g==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              brand: {
                50: '#eef2ff', 100: '#e0e7ff', 200: '#c7d2fe', 300: '#a5b4fc',
                400: '#818cf8', 500: '#6366f1', 600: '#4f46e5', 700: '#4338ca',
                800: '#3730a3', 900: '#312e81', 950: '#1e1b4b',
              }
            }
          }
        }
      }
    </script>

    <%= favicon_link_tag 'favicon.svg', type: 'image/svg+xml' %>

    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"
            integrity="sha256-IGtui7APx7uix+6AykHbPp4FunvgqjWr66nP1TV/XQ4="
            crossorigin="anonymous"></script>
    <%= javascript_include_tag "application" %>

    <style>
      [data-sidebar-toggle]:checked ~ .sidebar-overlay { display: block; }
      [data-sidebar-toggle]:checked ~ .sidebar-panel { transform: translateX(0); }
    </style>
  </head>

  <body class="h-full">
    <div class="flex h-full">
      <!-- Mobile sidebar toggle (hidden checkbox trick) -->
      <input type="checkbox" id="sidebar-toggle" class="hidden" data-sidebar-toggle />

      <!-- Mobile overlay -->
      <label for="sidebar-toggle" class="sidebar-overlay hidden fixed inset-0 bg-gray-900/50 z-30 lg:hidden"></label>

      <!-- Sidebar -->
      <aside class="sidebar-panel fixed inset-y-0 left-0 z-40 w-64 bg-white border-r border-gray-200 transform -translate-x-full lg:translate-x-0 lg:static lg:flex lg:flex-col transition-transform duration-200 ease-in-out">
        <div class="flex flex-col h-full">
          <!-- Logo -->
          <div class="flex items-center justify-between h-16 px-5 border-b border-gray-100">
            <%= link_to root_path, class: 'flex items-center space-x-2.5' do %>
              <div class="w-8 h-8 bg-brand-600 rounded-lg flex items-center justify-center">
                <i class="fa-solid fa-wallet text-white text-sm"></i>
              </div>
              <span class="text-lg font-bold text-gray-900 tracking-tight">Keelfin</span>
            <% end %>
            <label for="sidebar-toggle" class="lg:hidden p-1 rounded-md hover:bg-gray-100 cursor-pointer">
              <i class="fa-solid fa-xmark text-gray-500"></i>
            </label>
          </div>

          <!-- Navigation -->
          <nav class="flex-1 px-3 py-4 space-y-1 overflow-y-auto">
            <p class="px-3 text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Overview</p>
            <%= sidebar_link 'Dashboard', dashboard_path, 'fa-solid fa-grid-2', 'dashboard' %>

            <p class="px-3 pt-5 text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Money</p>
            <%= sidebar_link 'Categories', categories_path, 'fa-solid fa-tags', 'categories' %>
            <%= sidebar_link 'Budgets', budgets_path, 'fa-solid fa-chart-pie', 'budgets' %>
            <%= sidebar_link 'Recurring', recurring_transactions_path, 'fa-solid fa-repeat', 'recurring_transactions' %>

            <p class="px-3 pt-5 text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Wealth</p>
            <%= sidebar_link 'Debts', debts_path, 'fa-solid fa-credit-card', 'debts' %>
            <%= sidebar_link 'Goals', financial_goals_path, 'fa-solid fa-bullseye', 'financial_goals' %>
            <%= sidebar_link 'Investments', investments_path, 'fa-solid fa-chart-line', 'investments' %>

            <p class="px-3 pt-5 text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Account</p>
            <%= sidebar_link 'Subscription', subscription_path, 'fa-solid fa-crown', 'subscriptions' %>
            <% if current_user&.admin? %>
              <%= sidebar_link 'Admin', admin_root_path, 'fa-solid fa-shield-halved', 'admin' %>
            <% end %>
          </nav>

          <!-- User Footer -->
          <div class="border-t border-gray-100 p-4">
            <div class="flex items-center">
              <div class="w-9 h-9 bg-brand-100 rounded-full flex items-center justify-center">
                <span class="text-sm font-bold text-brand-700"><%= current_user&.name&.first(2)&.upcase %></span>
              </div>
              <div class="ml-3 flex-1 min-w-0">
                <p class="text-sm font-medium text-gray-900 truncate"><%= current_user&.name %></p>
                <p class="text-xs text-gray-500 truncate"><%= current_user&.email %></p>
              </div>
              <div class="flex items-center space-x-1">
                <%= link_to edit_user_registration_path, class: 'p-1.5 rounded-md hover:bg-gray-100 text-gray-400 hover:text-gray-600 transition-colors', title: 'Settings' do %>
                  <i class="fa-solid fa-gear text-sm"></i>
                <% end %>
                <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: 'p-1.5 rounded-md hover:bg-red-50 text-gray-400 hover:text-red-600 transition-colors', title: 'Sign out' do %>
                  <i class="fa-solid fa-right-from-bracket text-sm"></i>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </aside>

      <!-- Main Content -->
      <div class="flex-1 flex flex-col min-w-0">
        <!-- Top Bar -->
        <header class="sticky top-0 z-20 bg-white/80 backdrop-blur-md border-b border-gray-200">
          <div class="flex items-center justify-between h-16 px-4 sm:px-6 lg:px-8">
            <div class="flex items-center">
              <label for="sidebar-toggle" class="lg:hidden p-2 -ml-2 rounded-md hover:bg-gray-100 cursor-pointer mr-3">
                <i class="fa-solid fa-bars text-gray-600"></i>
              </label>
              <h1 class="text-lg font-semibold text-gray-900"><%= yield(:page_title) if content_for?(:page_title) %></h1>
            </div>
            <div class="flex items-center space-x-3">
              <% if current_user && !current_user.confirmed_at %>
                <div class="hidden sm:flex items-center bg-amber-50 text-amber-700 px-3 py-1.5 rounded-lg text-xs font-medium">
                  <i class="fa-solid fa-envelope mr-1.5"></i>
                  Please verify your email
                </div>
              <% end %>
              <% if current_user&.premium? %>
                <span class="hidden sm:flex items-center bg-gradient-to-r from-amber-100 to-yellow-100 text-amber-800 px-3 py-1.5 rounded-lg text-xs font-semibold">
                  <i class="fa-solid fa-crown mr-1.5 text-amber-500"></i> Premium
                </span>
              <% end %>
            </div>
          </div>
        </header>

        <!-- Flash Messages -->
        <% if notice.present? %>
          <div class="mx-4 sm:mx-6 lg:mx-8 mt-4">
            <div class="bg-emerald-50 border border-emerald-200 text-emerald-700 rounded-xl px-4 py-3 text-sm flex items-start" role="alert">
              <i class="fa-solid fa-circle-check text-emerald-500 mt-0.5 mr-3 flex-shrink-0"></i>
              <span><%= notice %></span>
            </div>
          </div>
        <% end %>
        <% if alert.present? %>
          <div class="mx-4 sm:mx-6 lg:mx-8 mt-4">
            <div class="bg-red-50 border border-red-200 text-red-700 rounded-xl px-4 py-3 text-sm flex items-start" role="alert">
              <i class="fa-solid fa-circle-exclamation text-red-500 mt-0.5 mr-3 flex-shrink-0"></i>
              <span><%= alert %></span>
            </div>
          </div>
        <% end %>

        <!-- Page Content -->
        <main class="flex-1 overflow-y-auto">
          <%= yield %>
        </main>
      </div>
    </div>
  </body>
</html>
