<!DOCTYPE html>
<html class="h-full bg-brand-950">
  <head>
    <title>Keelfin Admin</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "tailwind", as: "style" %>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.1.1/css/all.min.css" integrity="sha512-KfkfwYDsLkIlwQp6LFnl8zNdLGxu9YAA1QvwInks4PhcElQSvqcyVLLD9aMhXd13uQjoXtEKNosOWaZqXgel0g==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <%= favicon_link_tag 'favicon.svg', type: 'image/svg+xml' %>
    <%= javascript_include_tag "application" %>

    <style>
      [data-sidebar-toggle]:checked ~ .sidebar-overlay { display: block; }
      [data-sidebar-toggle]:checked ~ .sidebar-panel { transform: translateX(0); }
    </style>
  </head>

  <body class="h-full bg-brand-950">
    <div class="flex h-full">
      <input type="checkbox" id="sidebar-toggle" class="hidden" data-sidebar-toggle />
      <label for="sidebar-toggle" class="sidebar-overlay hidden fixed inset-0 bg-brand-950/80 z-30 lg:hidden"></label>

      <!-- Admin Sidebar -->
      <aside class="sidebar-panel fixed inset-y-0 left-0 z-40 w-64 bg-brand-900 transform -translate-x-full lg:translate-x-0 lg:static lg:flex lg:flex-col transition-transform duration-200 ease-in-out border-r border-brand-800">
        <div class="flex flex-col h-full">
          <!-- Logo -->
          <div class="flex items-center justify-between h-16 px-5 border-b border-brand-800 bg-brand-900">
            <%= link_to admin_root_path, class: 'flex items-center space-x-2.5' do %>
              <div class="w-8 h-8 bg-gradient-to-br from-brand-500 to-brand-700 rounded-lg flex items-center justify-center shadow-inner shadow-brand-900/30">
                <i class="fa-solid fa-shield-halved text-white text-sm"></i>
              </div>
              <div>
                <span class="text-base font-bold text-white tracking-tight">Keelfin</span>
                <span class="text-[10px] font-semibold text-brand-400 uppercase tracking-widest ml-1">Admin</span>
              </div>
            <% end %>
            <label for="sidebar-toggle" class="lg:hidden p-1 rounded-md hover:bg-white/10 cursor-pointer text-brand-400">
              <i class="fa-solid fa-xmark"></i>
            </label>
          </div>

          <!-- Navigation -->
          <nav class="flex-1 px-3 py-4 space-y-1 overflow-y-auto">
            <p class="px-3 text-[10px] font-semibold text-brand-500 uppercase tracking-widest mb-2">Overview</p>
            <%= admin_sidebar_link 'Dashboard', admin_root_path, 'fa-solid fa-grid-2', 'dashboard' %>

            <p class="px-3 pt-5 text-[10px] font-semibold text-brand-500 uppercase tracking-widest mb-2">Management</p>
            <%= admin_sidebar_link 'Users', admin_users_path, 'fa-solid fa-users', 'users' %>
            <%= admin_sidebar_link 'Subscriptions', admin_subscriptions_path, 'fa-solid fa-crown', 'subscriptions' %>

            <p class="px-3 pt-5 text-[10px] font-semibold text-brand-500 uppercase tracking-widest mb-2">Content</p>
            <%= admin_sidebar_link 'Category Presets', admin_category_presets_path, 'fa-solid fa-tags', 'category_presets' %>
            <%= admin_sidebar_link 'Economic Data', admin_economic_indicators_path, 'fa-solid fa-chart-column', 'economic_indicators' %>
            <%= admin_sidebar_link 'BNNB Data', admin_bnnb_datas_path, 'fa-solid fa-basket-shopping', 'bnnb_datas' %>

            <div class="pt-6">
              <%= link_to root_path, class: 'flex items-center px-3 py-2.5 rounded-xl text-sm font-medium text-brand-400 hover:bg-brand-800 hover:text-brand-200 transition-all' do %>
                <i class="fa-solid fa-arrow-left w-5 text-center text-brand-500"></i>
                <span class="ml-3">Back to App</span>
              <% end %>
            </div>
          </nav>

          <!-- Admin User Footer -->
          <div class="border-t border-brand-800 p-4 bg-brand-900/50">
            <div class="flex items-center">
              <div class="w-9 h-9 bg-brand-700 rounded-full flex items-center justify-center">
                <span class="text-xs font-bold text-white"><%= current_user&.name&.first(2)&.upcase %></span>
              </div>
              <div class="ml-3 flex-1 min-w-0">
                <p class="text-sm font-medium text-white truncate"><%= current_user&.name %></p>
                <p class="text-xs text-brand-400 truncate">Administrator</p>
              </div>
            </div>
          </div>
        </div>
      </aside>

      <!-- Main Content -->
      <div class="flex-1 flex flex-col min-w-0">
        <header class="sticky top-0 z-20 bg-brand-900/80 backdrop-blur-xl border-b border-brand-800">
          <div class="flex items-center justify-between h-16 px-4 sm:px-6 lg:px-8">
            <div class="flex items-center">
              <label for="sidebar-toggle" class="lg:hidden p-2 -ml-2 rounded-md hover:bg-white/10 cursor-pointer mr-3 text-brand-300">
                <i class="fa-solid fa-bars"></i>
              </label>
              <h1 class="text-lg font-semibold text-brand-100"><%= yield(:page_title) if content_for?(:page_title) %></h1>
            </div>
            <div class="flex items-center space-x-3">
              <span class="text-xs font-medium text-brand-400 bg-brand-800/60 px-3 py-1.5 rounded-lg border border-brand-700/40">
                <i class="fa-solid fa-shield-halved mr-1 text-brand-500"></i> Admin Mode
              </span>
            </div>
          </div>
        </header>

        <% if notice.present? %>
          <div class="mx-4 sm:mx-6 lg:mx-8 mt-4">
            <div class="bg-emerald-900/30 border border-emerald-700/40 text-emerald-300 rounded-xl px-4 py-3 text-sm flex items-start" role="alert">
              <i class="fa-solid fa-circle-check text-emerald-400 mt-0.5 mr-3 flex-shrink-0"></i>
              <span><%= notice %></span>
            </div>
          </div>
        <% end %>
        <% if alert.present? %>
          <div class="mx-4 sm:mx-6 lg:mx-8 mt-4">
            <div class="bg-red-900/30 border border-red-700/40 text-red-300 rounded-xl px-4 py-3 text-sm flex items-start" role="alert">
              <i class="fa-solid fa-circle-exclamation text-red-400 mt-0.5 mr-3 flex-shrink-0"></i>
              <span><%= alert %></span>
            </div>
          </div>
        <% end %>

        <main class="flex-1 overflow-y-auto">
          <%= yield %>
        </main>
      </div>
    </div>
  </body>
</html>
