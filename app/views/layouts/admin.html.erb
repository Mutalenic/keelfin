<!DOCTYPE html>
<html class="h-full bg-gray-50">
  <head>
    <title>Keelfin Admin</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.1.1/css/all.min.css" integrity="sha512-KfkfwYDsLkIlwQp6LFnl8zNdLGxu9YAA1QvwINks4PhcElQSvqcyVLLD9aMhXd13uQjoXtEKNosOWaZqXgel0g==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              brand: {
                50: '#eef2ff', 100: '#e0e7ff', 200: '#c7d2fe', 300: '#a5b4fc',
                400: '#818cf8', 500: '#6366f1', 600: '#4f46e5', 700: '#4338ca',
                800: '#3730a3', 900: '#312e81', 950: '#1e1b4b',
              }
            }
          }
        }
      }
    </script>
    <%= favicon_link_tag 'favicon.svg', type: 'image/svg+xml' %>
    <%= javascript_include_tag "application" %>

    <style>
      [data-sidebar-toggle]:checked ~ .sidebar-overlay { display: block; }
      [data-sidebar-toggle]:checked ~ .sidebar-panel { transform: translateX(0); }
    </style>
  </head>

  <body class="h-full">
    <div class="flex h-full">
      <input type="checkbox" id="sidebar-toggle" class="hidden" data-sidebar-toggle />
      <label for="sidebar-toggle" class="sidebar-overlay hidden fixed inset-0 bg-gray-900/50 z-30 lg:hidden"></label>

      <!-- Admin Sidebar -->
      <aside class="sidebar-panel fixed inset-y-0 left-0 z-40 w-64 bg-gray-900 transform -translate-x-full lg:translate-x-0 lg:static lg:flex lg:flex-col transition-transform duration-200 ease-in-out">
        <div class="flex flex-col h-full">
          <!-- Logo -->
          <div class="flex items-center justify-between h-16 px-5 border-b border-gray-800">
            <%= link_to admin_root_path, class: 'flex items-center space-x-2.5' do %>
              <div class="w-8 h-8 bg-brand-500 rounded-lg flex items-center justify-center">
                <i class="fa-solid fa-shield-halved text-white text-sm"></i>
              </div>
              <div>
                <span class="text-base font-bold text-white tracking-tight">Keelfin</span>
                <span class="text-[10px] font-semibold text-brand-400 uppercase tracking-widest ml-1">Admin</span>
              </div>
            <% end %>
            <label for="sidebar-toggle" class="lg:hidden p-1 rounded-md hover:bg-gray-800 cursor-pointer">
              <i class="fa-solid fa-xmark text-gray-400"></i>
            </label>
          </div>

          <!-- Navigation -->
          <nav class="flex-1 px-3 py-4 space-y-1 overflow-y-auto">
            <p class="px-3 text-[10px] font-semibold text-gray-500 uppercase tracking-widest mb-2">Overview</p>
            <%= admin_sidebar_link 'Dashboard', admin_root_path, 'fa-solid fa-grid-2', 'dashboard' %>

            <p class="px-3 pt-5 text-[10px] font-semibold text-gray-500 uppercase tracking-widest mb-2">Management</p>
            <%= admin_sidebar_link 'Users', admin_users_path, 'fa-solid fa-users', 'users' %>
            <%= admin_sidebar_link 'Subscriptions', admin_subscriptions_path, 'fa-solid fa-crown', 'subscriptions' %>

            <p class="px-3 pt-5 text-[10px] font-semibold text-gray-500 uppercase tracking-widest mb-2">Content</p>
            <%= admin_sidebar_link 'Category Presets', admin_category_presets_path, 'fa-solid fa-tags', 'category_presets' %>
            <%= admin_sidebar_link 'Economic Data', admin_economic_indicators_path, 'fa-solid fa-chart-column', 'economic_indicators' %>
            <%= admin_sidebar_link 'BNNB Data', admin_bnnb_datas_path, 'fa-solid fa-basket-shopping', 'bnnb_datas' %>

            <div class="pt-6">
              <%= link_to root_path, class: 'flex items-center px-3 py-2.5 rounded-xl text-sm font-medium text-gray-400 hover:bg-gray-800 hover:text-white transition-all' do %>
                <i class="fa-solid fa-arrow-left w-5 text-center text-gray-500"></i>
                <span class="ml-3">Back to App</span>
              <% end %>
            </div>
          </nav>

          <!-- Admin User Footer -->
          <div class="border-t border-gray-800 p-4">
            <div class="flex items-center">
              <div class="w-9 h-9 bg-brand-600 rounded-full flex items-center justify-center">
                <span class="text-xs font-bold text-white"><%= current_user&.name&.first(2)&.upcase %></span>
              </div>
              <div class="ml-3 flex-1 min-w-0">
                <p class="text-sm font-medium text-white truncate"><%= current_user&.name %></p>
                <p class="text-xs text-gray-500 truncate">Administrator</p>
              </div>
            </div>
          </div>
        </div>
      </aside>

      <!-- Main Content -->
      <div class="flex-1 flex flex-col min-w-0">
        <header class="sticky top-0 z-20 bg-white border-b border-gray-200">
          <div class="flex items-center justify-between h-16 px-4 sm:px-6 lg:px-8">
            <div class="flex items-center">
              <label for="sidebar-toggle" class="lg:hidden p-2 -ml-2 rounded-md hover:bg-gray-100 cursor-pointer mr-3">
                <i class="fa-solid fa-bars text-gray-600"></i>
              </label>
              <h1 class="text-lg font-semibold text-gray-900"><%= yield(:page_title) if content_for?(:page_title) %></h1>
            </div>
            <div class="flex items-center space-x-3">
              <span class="text-xs font-medium text-gray-500 bg-gray-100 px-3 py-1.5 rounded-lg">
                <i class="fa-solid fa-shield-halved mr-1 text-brand-500"></i> Admin Mode
              </span>
            </div>
          </div>
        </header>

        <% if notice.present? %>
          <div class="mx-4 sm:mx-6 lg:mx-8 mt-4">
            <div class="bg-emerald-50 border border-emerald-200 text-emerald-700 rounded-xl px-4 py-3 text-sm flex items-start" role="alert">
              <i class="fa-solid fa-circle-check text-emerald-500 mt-0.5 mr-3 flex-shrink-0"></i>
              <span><%= notice %></span>
            </div>
          </div>
        <% end %>
        <% if alert.present? %>
          <div class="mx-4 sm:mx-6 lg:mx-8 mt-4">
            <div class="bg-red-50 border border-red-200 text-red-700 rounded-xl px-4 py-3 text-sm flex items-start" role="alert">
              <i class="fa-solid fa-circle-exclamation text-red-500 mt-0.5 mr-3 flex-shrink-0"></i>
              <span><%= alert %></span>
            </div>
          </div>
        <% end %>

        <main class="flex-1 overflow-y-auto">
          <%= yield %>
        </main>
      </div>
    </div>
  </body>
</html>
