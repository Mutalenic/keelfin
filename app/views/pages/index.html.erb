<% content_for(:page_title) { "Welcome" } %>
<% content_for(:skip_card_wrapper, true) %>

<div class="min-h-screen flex items-center justify-center p-4">
  <div class="max-w-md w-full space-y-8">
    <!-- Logo -->
    <div class="text-center">
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-3xl mb-6"
           style="background: linear-gradient(135deg, #4f46e5 0%, #4338ca 100%);">
        <i class="fa-solid fa-wallet text-4xl text-white"></i>
      </div>
      <h1 class="text-4xl font-bold text-white mb-2">Keelfin</h1>
      <p class="text-white/60">Smart Financial Management</p>
    </div>

    <% if user_signed_in? %>
      <!-- Logged in state -->
      <div class="bg-white/95 border border-white/30 backdrop-blur-2xl rounded-3xl shadow-2xl p-8 space-y-4">
        <div class="text-center mb-6">
          <h2 class="text-2xl font-semibold text-gray-900">Welcome back!</h2>
          <p class="text-gray-500">Continue managing your finances</p>
        </div>

        <%= link_to categories_path, class: "w-full flex items-center justify-center px-6 py-4 rounded-xl text-sm font-semibold bg-brand-600 text-white shadow hover:bg-brand-500 transition" do %>
          <i class="fa-solid fa-tags mr-2"></i>
          Go to Categories
        <% end %>

        <%= link_to root_path, class: "w-full flex items-center justify-center px-6 py-4 rounded-xl text-sm font-semibold bg-gray-100 text-gray-700 hover:bg-gray-200 transition" do %>
          <i class="fa-solid fa-gauge mr-2"></i>
          Dashboard
        <% end %>

        <%= button_to destroy_user_session_path, method: :delete, class: "w-full flex items-center justify-center px-6 py-4 rounded-xl text-sm font-semibold bg-red-50 text-red-600 hover:bg-red-100 transition" do %>
          <i class="fa-solid fa-right-from-bracket mr-2"></i>
          Log out
        <% end %>
      </div>
    <% else %>
      <!-- Logged out state -->
      <div class="bg-white/95 border border-white/30 backdrop-blur-2xl rounded-3xl shadow-2xl p-8 space-y-4">
        <div class="text-center mb-6">
          <h2 class="text-2xl font-semibold text-gray-900">Get Started</h2>
          <p class="text-gray-500">Sign in to manage your finances</p>
        </div>

        <%= link_to new_user_session_path, class: "w-full flex items-center justify-center px-6 py-4 rounded-xl text-sm font-semibold bg-brand-600 text-white shadow hover:bg-brand-500 transition" do %>
          <i class="fa-solid fa-right-to-bracket mr-2"></i>
          Log in
        <% end %>

        <div class="relative py-2">
          <div class="absolute inset-0 flex items-center">
            <div class="w-full border-t border-gray-200"></div>
          </div>
          <div class="relative flex justify-center">
            <span class="bg-white px-4 text-sm text-gray-500">or</span>
          </div>
        </div>

        <%= link_to new_user_registration_path, class: "w-full flex items-center justify-center px-6 py-4 rounded-xl text-sm font-semibold border-2 border-brand-200 text-brand-700 hover:bg-brand-50 transition" do %>
          <i class="fa-solid fa-user-plus mr-2"></i>
          Sign Up
        <% end %>
      </div>
    <% end %>
  </div>
</div>


