<% content_for(:page_title) { "Edit Subscription: #{@subscription.user.name}" } %>

<div class="p-4 sm:p-6 lg:p-8">
  <div class="max-w-2xl">
    <div class="mb-6">
      <%= link_to admin_subscription_path(@subscription), class: "text-sm text-gray-500 hover:text-gray-700 transition-colors" do %>
        <i class="fa-solid fa-arrow-left mr-1"></i> Back to subscription
      <% end %>
    </div>

    <div class="bg-white rounded-2xl border border-gray-200 p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-6">Edit Subscription</h2>

      <%= form_with(model: [:admin, @subscription], class: "space-y-5") do |f| %>
        <div>
          <%= f.label :plan_name, "Plan", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.select :plan_name, [['Free', 'free'], ['Standard', 'standard'], ['Premium', 'premium']], {}, class: "block w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500" %>
        </div>

        <div>
          <%= f.label :status, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.select :status, [['Active', 'active'], ['Canceled', 'canceled'], ['Expired', 'expired']], {}, class: "block w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500" %>
        </div>

        <div>
          <%= f.label :amount, "Amount (ZMW)", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.number_field :amount, step: 0.01, min: 0, class: "block w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500" %>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <%= f.label :start_date, class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.date_field :start_date, class: "block w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500" %>
          </div>
          <div>
            <%= f.label :end_date, class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.date_field :end_date, class: "block w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500" %>
          </div>
        </div>

        <div class="flex items-center space-x-3 pt-4">
          <%= f.submit "Save changes", class: "px-6 py-3 bg-brand-600 text-white text-sm font-semibold rounded-xl hover:bg-brand-700 transition-colors cursor-pointer" %>
          <%= link_to "Cancel", admin_subscription_path(@subscription), class: "px-6 py-3 text-sm font-medium text-gray-600 hover:text-gray-800 transition-colors" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
