<% content_for(:page_title) { "Subscriptions" } %>

<div class="p-4 sm:p-6 lg:p-8">
  <!-- Filters -->
  <div class="bg-white rounded-2xl border border-gray-200 p-4 mb-6">
    <%= form_tag admin_subscriptions_path, method: :get, class: "flex flex-col sm:flex-row items-center gap-3" do %>
      <select name="plan" class="border border-gray-300 rounded-xl text-sm py-2.5 px-3 focus:outline-none focus:ring-2 focus:ring-brand-500">
        <option value="">All Plans</option>
        <option value="free" <%= 'selected' if params[:plan] == 'free' %>>Free</option>
        <option value="standard" <%= 'selected' if params[:plan] == 'standard' %>>Standard</option>
        <option value="premium" <%= 'selected' if params[:plan] == 'premium' %>>Premium</option>
      </select>
      <select name="status" class="border border-gray-300 rounded-xl text-sm py-2.5 px-3 focus:outline-none focus:ring-2 focus:ring-brand-500">
        <option value="">All Statuses</option>
        <option value="active" <%= 'selected' if params[:status] == 'active' %>>Active</option>
        <option value="canceled" <%= 'selected' if params[:status] == 'canceled' %>>Canceled</option>
        <option value="expired" <%= 'selected' if params[:status] == 'expired' %>>Expired</option>
      </select>
      <button type="submit" class="px-5 py-2.5 bg-brand-600 text-white text-sm font-semibold rounded-xl hover:bg-brand-700 transition-colors">Filter</button>
    <% end %>
  </div>

  <!-- Subscriptions Table -->
  <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">User</th>
            <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Plan</th>
            <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
            <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Amount</th>
            <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Period</th>
            <th class="px-5 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @subscriptions.each do |sub| %>
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="px-5 py-4">
                <div class="flex items-center">
                  <div class="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center text-xs font-bold text-gray-600">
                    <%= sub.user.name.first(2).upcase %>
                  </div>
                  <div class="ml-3">
                    <p class="text-sm font-medium text-gray-900"><%= sub.user.name %></p>
                    <p class="text-xs text-gray-500"><%= sub.user.email %></p>
                  </div>
                </div>
              </td>
              <td class="px-5 py-4">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-semibold
                  <%= case sub.plan_name
                      when 'premium' then 'bg-amber-100 text-amber-700'
                      when 'standard' then 'bg-blue-100 text-blue-700'
                      else 'bg-gray-100 text-gray-600'
                      end %>">
                  <%= sub.plan_name.capitalize %>
                </span>
              </td>
              <td class="px-5 py-4">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-semibold
                  <%= case sub.status
                      when 'active' then 'bg-emerald-100 text-emerald-700'
                      when 'canceled' then 'bg-red-100 text-red-700'
                      else 'bg-gray-100 text-gray-600'
                      end %>">
                  <%= sub.status.capitalize %>
                </span>
              </td>
              <td class="px-5 py-4 text-sm text-gray-700">K<%= number_with_precision(sub.amount, precision: 2) %></td>
              <td class="px-5 py-4 text-sm text-gray-500">
                <%= sub.start_date&.strftime('%b %d') %> - <%= sub.end_date&.strftime('%b %d, %Y') %>
              </td>
              <td class="px-5 py-4 text-right">
                <%= link_to edit_admin_subscription_path(sub), class: "text-brand-600 hover:text-brand-800 text-sm font-medium" do %>
                  Edit <i class="fa-solid fa-pen-to-square ml-1 text-xs"></i>
                <% end %>
              </td>
            </tr>
          <% end %>
          <% if @subscriptions.empty? %>
            <tr><td colspan="6" class="px-5 py-8 text-center text-sm text-gray-500">No subscriptions found.</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
