<% content_for(:page_title) { "Edit User: #{@user.name}" } %>

<div class="p-4 sm:p-6 lg:p-8">
  <div class="max-w-2xl">
    <div class="mb-6">
      <%= link_to admin_user_path(@user), class: "text-sm text-gray-500 hover:text-gray-700 transition-colors" do %>
        <i class="fa-solid fa-arrow-left mr-1"></i> Back to user
      <% end %>
    </div>

    <div class="bg-white rounded-2xl border border-gray-200 p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-6">Edit User</h2>

      <%= form_with(model: [:admin, @user], class: "space-y-5") do |f| %>
        <div>
          <%= f.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :name, class: "block w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500" %>
        </div>

        <div>
          <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.email_field :email, class: "block w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500" %>
        </div>

        <div>
          <%= f.label :monthly_income, "Monthly Income (ZMW)", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.number_field :monthly_income, step: 0.01, min: 0, class: "block w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500" %>
        </div>

        <div>
          <%= f.label :phone_number, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :phone_number, placeholder: "+260XXXXXXXXX", class: "block w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500" %>
        </div>

        <div>
          <%= f.label :role, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.select :role, [['Default', 'default'], ['Admin', 'admin']], {}, class: "block w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500" %>
        </div>

        <div>
          <%= f.label :currency, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.select :currency, [['ZMW (Zambian Kwacha)', 'ZMW'], ['USD (US Dollar)', 'USD']], {}, class: "block w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500" %>
        </div>

        <div class="flex items-center space-x-3 pt-4">
          <%= f.submit "Save changes", class: "px-6 py-3 bg-brand-600 text-white text-sm font-semibold rounded-xl hover:bg-brand-700 transition-colors cursor-pointer" %>
          <%= link_to "Cancel", admin_user_path(@user), class: "px-6 py-3 text-sm font-medium text-gray-600 hover:text-gray-800 transition-colors" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
