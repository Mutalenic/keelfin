<% content_for(:page_title) { "Economic Indicator: #{@indicator.date.strftime('%B %d, %Y')}" } %>

<div class="p-4 sm:p-6 lg:p-8">
  <div class="max-w-2xl">
    <div class="mb-6">
      <%= link_to admin_economic_indicators_path, class: "text-sm text-gray-500 hover:text-gray-700 transition-colors" do %>
        <i class="fa-solid fa-arrow-left mr-1"></i> Back
      <% end %>
    </div>
    <div class="bg-white rounded-2xl border border-gray-200 p-6">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-lg font-semibold text-gray-900"><%= @indicator.date.strftime('%B %d, %Y') %></h2>
        <div class="flex items-center space-x-2">
          <%= link_to edit_admin_economic_indicator_path(@indicator), class: "px-4 py-2 bg-white border border-gray-300 rounded-xl text-sm font-medium text-gray-700 hover:bg-gray-50" do %>
            <i class="fa-solid fa-pen-to-square mr-1.5"></i> Edit
          <% end %>
          <%= button_to admin_economic_indicator_path(@indicator), method: :delete, class: "px-4 py-2 border border-red-200 rounded-xl text-sm font-medium text-red-700 bg-red-50 hover:bg-red-100",
              data: { turbo_confirm: "Delete this entry?" } do %>
            <i class="fa-solid fa-trash mr-1.5"></i> Delete
          <% end %>
        </div>
      </div>
      <dl class="space-y-4">
        <div class="flex justify-between py-3 border-b border-gray-100">
          <dt class="text-sm text-gray-500">Inflation Rate</dt>
          <dd class="text-sm font-medium text-gray-900"><%= number_with_precision(@indicator.inflation_rate, precision: 2) %>%</dd>
        </div>
        <div class="flex justify-between py-3 border-b border-gray-100">
          <dt class="text-sm text-gray-500">USD/ZMW Exchange Rate</dt>
          <dd class="text-sm font-medium text-gray-900">K<%= number_with_precision(@indicator.usd_zmw_rate, precision: 2) %></dd>
        </div>
        <div class="flex justify-between py-3">
          <dt class="text-sm text-gray-500">Source</dt>
          <dd class="text-sm text-gray-900"><%= @indicator.source || '—' %></dd>
        </div>
      </dl>
    </div>
  </div>
</div>
