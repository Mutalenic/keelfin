<% content_for(:page_title) { "Economic Indicators" } %>

<div class="p-4 sm:p-6 lg:p-8">
  <div class="flex items-center justify-between mb-6">
    <p class="text-sm text-gray-500">Manage daily economic data for Zambia (inflation, exchange rates).</p>
    <%= link_to new_admin_economic_indicator_path, class: "px-5 py-2.5 bg-brand-600 text-white text-sm font-semibold rounded-xl hover:bg-brand-700 transition-colors" do %>
      <i class="fa-solid fa-plus mr-1.5"></i> New Entry
    <% end %>
  </div>

  <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Date</th>
            <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Inflation Rate</th>
            <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">USD/ZMW Rate</th>
            <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Source</th>
            <th class="px-5 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @indicators.each do |indicator| %>
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="px-5 py-4 text-sm font-medium text-gray-900"><%= indicator.date.strftime('%B %d, %Y') %></td>
              <td class="px-5 py-4 text-sm text-gray-700"><%= number_with_precision(indicator.inflation_rate, precision: 2) %>%</td>
              <td class="px-5 py-4 text-sm text-gray-700">K<%= number_with_precision(indicator.usd_zmw_rate, precision: 2) %></td>
              <td class="px-5 py-4 text-sm text-gray-500"><%= indicator.source || '—' %></td>
              <td class="px-5 py-4 text-right space-x-2">
                <%= link_to edit_admin_economic_indicator_path(indicator), class: "text-brand-600 hover:text-brand-800 text-sm font-medium" do %>
                  Edit
                <% end %>
                <%= button_to admin_economic_indicator_path(indicator), method: :delete, class: "text-red-600 hover:text-red-800 text-sm font-medium",
                    data: { turbo_confirm: "Delete this entry?" } do %>
                  Delete
                <% end %>
              </td>
            </tr>
          <% end %>
          <% if @indicators.empty? %>
            <tr><td colspan="5" class="px-5 py-8 text-center text-sm text-gray-500">No economic indicator data yet.</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
