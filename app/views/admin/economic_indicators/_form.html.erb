<%= form_with(model: [:admin, indicator], class: "space-y-5") do |f| %>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <%= f.label :date, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.date_field :date, class: "block w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500" %>
    </div>
    <div>
      <%= f.label :source, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :source, placeholder: "e.g. Bank of Zambia", class: "block w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500" %>
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <%= f.label :inflation_rate, "Inflation Rate (%)", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :inflation_rate, step: 0.01, class: "block w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500" %>
    </div>
    <div>
      <%= f.label :usd_zmw_rate, "USD/ZMW Exchange Rate", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :usd_zmw_rate, step: 0.01, class: "block w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500" %>
    </div>
  </div>

  <div class="flex items-center space-x-3 pt-4">
    <%= f.submit class: "px-6 py-3 bg-brand-600 text-white text-sm font-semibold rounded-xl hover:bg-brand-700 transition-colors cursor-pointer" %>
    <%= link_to "Cancel", admin_economic_indicators_path, class: "px-6 py-3 text-sm font-medium text-gray-600 hover:text-gray-800 transition-colors" %>
  </div>
<% end %>
