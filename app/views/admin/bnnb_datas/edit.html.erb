<% content_for(:page_title) { "Edit BNNB Data" } %>

<div class="p-4 sm:p-6 lg:p-8">
  <div class="max-w-2xl">
    <div class="mb-6">
      <%= link_to admin_bnnb_datas_path, class: "text-sm text-gray-500 hover:text-gray-700 transition-colors" do %>
        <i class="fa-solid fa-arrow-left mr-1"></i> Back
      <% end %>
    </div>
    <div class="bg-white rounded-2xl border border-gray-200 p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-6">Edit BNNB Data Entry</h2>
      <%= render 'form', bnnb_data: @bnnb_data %>
    </div>
  </div>
</div>
