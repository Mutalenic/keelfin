<%= form_with(model: [:admin, bnnb_data], class: "space-y-5") do |f| %>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <%= f.label :month, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.date_field :month, class: "block w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500" %>
    </div>
    <div>
      <%= f.label :location, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :location, placeholder: "e.g. Lusaka", class: "block w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500" %>
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    <div>
      <%= f.label :total_basket, "Total Basket (ZMW)", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :total_basket, step: 0.01, min: 0, class: "block w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500" %>
    </div>
    <div>
      <%= f.label :food_basket, "Food Basket (ZMW)", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :food_basket, step: 0.01, min: 0, class: "block w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500" %>
    </div>
    <div>
      <%= f.label :non_food_basket, "Non-Food Basket (ZMW)", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :non_food_basket, step: 0.01, min: 0, class: "block w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500" %>
    </div>
  </div>

  <div class="flex items-center space-x-3 pt-4">
    <%= f.submit class: "px-6 py-3 bg-brand-600 text-white text-sm font-semibold rounded-xl hover:bg-brand-700 transition-colors cursor-pointer" %>
    <%= link_to "Cancel", admin_bnnb_datas_path, class: "px-6 py-3 text-sm font-medium text-gray-600 hover:text-gray-800 transition-colors" %>
  </div>
<% end %>
