<% content_for(:page_title) { "Category Presets" } %>

<div class="p-4 sm:p-6 lg:p-8">
  <div class="flex items-center justify-between mb-6">
    <div>
      <p class="text-sm text-gray-500">Manage default categories available to all users during onboarding.</p>
    </div>
    <%= link_to new_admin_category_preset_path, class: "px-5 py-2.5 bg-brand-600 text-white text-sm font-semibold rounded-xl hover:bg-brand-700 transition-colors" do %>
      <i class="fa-solid fa-plus mr-1.5"></i> New Preset
    <% end %>
  </div>

  <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Category</th>
            <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Type</th>
            <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Default</th>
            <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Order</th>
            <th class="px-5 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @presets.each do |preset| %>
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="px-5 py-4">
                <div class="flex items-center">
                  <div class="w-9 h-9 rounded-lg flex items-center justify-center" style="background-color: <%= preset.color %>20;">
                    <i class="<%= preset.icon_name || 'fa-solid fa-tag' %> text-sm" style="color: <%= preset.color %>;"></i>
                  </div>
                  <div class="ml-3">
                    <p class="text-sm font-medium text-gray-900"><%= preset.name %></p>
                    <p class="text-xs text-gray-500"><%= preset.description %></p>
                  </div>
                </div>
              </td>
              <td class="px-5 py-4">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-semibold bg-gray-100 text-gray-600"><%= preset.category_type&.titleize %></span>
              </td>
              <td class="px-5 py-4">
                <% if preset.is_default %>
                  <span class="text-emerald-500"><i class="fa-solid fa-circle-check"></i></span>
                <% else %>
                  <span class="text-gray-300"><i class="fa-regular fa-circle"></i></span>
                <% end %>
              </td>
              <td class="px-5 py-4 text-sm text-gray-500"><%= preset.display_order %></td>
              <td class="px-5 py-4 text-right space-x-2">
                <%= link_to edit_admin_category_preset_path(preset), class: "text-brand-600 hover:text-brand-800 text-sm font-medium" do %>
                  Edit
                <% end %>
                <%= button_to admin_category_preset_path(preset), method: :delete, class: "text-red-600 hover:text-red-800 text-sm font-medium",
                    data: { turbo_confirm: "Delete #{preset.name}?" } do %>
                  Delete
                <% end %>
              </td>
            </tr>
          <% end %>
          <% if @presets.empty? %>
            <tr><td colspan="5" class="px-5 py-8 text-center text-sm text-gray-500">No category presets yet.</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
