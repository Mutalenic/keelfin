<% content_for(:page_title) { "Coming Soon" } %>
<% content_for(:skip_card_wrapper, true) %>

<div class="space-y-8 max-w-3xl mx-auto">
  <!-- Hero Banner -->
  <div class="rounded-3xl p-6 sm:p-8 text-white shadow-[0_25px_80px_rgba(15,23,42,0.45)] border border-white/10 text-center"
       style="background: linear-gradient(135deg, #4f46e5 0%, #4338ca 55%, #1e1b4b 100%);">
    <div class="mb-6">
      <i class="fa-solid fa-rocket text-6xl text-white/90"></i>
    </div>
    <h1 class="text-3xl font-bold mb-4">Coming Soon</h1>
    <p class="text-white/80 max-w-lg mx-auto">
      <%= @feature_name %> is on our roadmap and will be landing in Keelfin shortly.
    </p>
  </div>

  <div class="bg-white/95 border border-white/30 backdrop-blur-2xl rounded-3xl shadow-2xl p-6 sm:p-8">
    <% if @premium_only %>
      <div class="bg-amber-50 border border-amber-200 rounded-2xl p-6 mb-6">
        <div class="flex items-center justify-center mb-3">
          <i class="fa-solid fa-crown text-amber-500 text-3xl mr-2"></i>
          <h2 class="text-xl font-bold text-amber-800">Premium Feature</h2>
        </div>
        <p class="text-gray-700 mb-4 text-center">
          <%= @feature_name %> is available exclusively to Premium subscribers.
        </p>
        <%= link_to "Upgrade to Premium", plans_subscription_path, class: "inline-flex items-center justify-center w-full px-6 py-3 rounded-xl text-sm font-semibold bg-gradient-to-r from-amber-400 to-yellow-500 text-amber-950 shadow hover:from-amber-500 hover:to-yellow-600 transition" %>
      </div>
    <% else %>
      <div class="text-center mb-8">
        <p class="text-gray-600 text-lg">
          <%= @feature_name %> is currently under development and will be available soon.
        </p>
      </div>

      <div class="bg-brand-50 border border-brand-200 rounded-2xl p-6 mb-6">
        <h3 class="font-semibold text-brand-800 mb-4 flex items-center gap-2">
          <i class="fa-solid fa-sparkles text-brand-600"></i>
          What to expect
        </h3>
        <ul class="space-y-3 text-gray-700">
          <li class="flex items-start">
            <i class="fa-solid fa-check text-emerald-500 mr-3 mt-1"></i>
            <span>Enhanced functionality and user experience</span>
          </li>
          <li class="flex items-start">
            <i class="fa-solid fa-check text-emerald-500 mr-3 mt-1"></i>
            <span>Seamless integration with existing features</span>
          </li>
          <li class="flex items-start">
            <i class="fa-solid fa-check text-emerald-500 mr-3 mt-1"></i>
            <span>Regular updates and improvements</span>
          </li>
        </ul>
      </div>
    <% end %>

    <div class="mt-8">
      <p class="text-sm text-gray-500 mb-4 text-center">In the meantime, explore our other features:</p>
      <div class="flex flex-wrap justify-center gap-3">
        <%= link_to root_path, class: "inline-flex items-center px-4 py-2 rounded-xl text-sm font-semibold bg-brand-600 text-white shadow hover:bg-brand-500 transition" do %>
          <i class="fa-solid fa-grid-2 mr-2"></i> Dashboard
        <% end %>
        <%= link_to categories_path, class: "inline-flex items-center px-4 py-2 rounded-xl text-sm font-semibold bg-emerald-600 text-white shadow hover:bg-emerald-500 transition" do %>
          <i class="fa-solid fa-tags mr-2"></i> Categories
        <% end %>
        <%= link_to budgets_path, class: "inline-flex items-center px-4 py-2 rounded-xl text-sm font-semibold bg-purple-600 text-white shadow hover:bg-purple-500 transition" do %>
          <i class="fa-solid fa-chart-pie mr-2"></i> Budgets
        <% end %>
        <%= link_to debts_path, class: "inline-flex items-center px-4 py-2 rounded-xl text-sm font-semibold bg-red-600 text-white shadow hover:bg-red-500 transition" do %>
          <i class="fa-solid fa-credit-card mr-2"></i> Debts
        <% end %>
      </div>
    </div>
  </div>
</div>
